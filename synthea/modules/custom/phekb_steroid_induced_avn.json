{
  "name": "PheKB Steroid-Induced Osteonecrosis",
  "remarks": [
    "Custom Synthea module for drug-induced osteonecrosis (avascular necrosis), most commonly steroid-induced.",
    "First iatrogenic bone disease phenotype.",
    "",
    "Generates THREE patient paths:",
    "  Path A (60%): AVN dx + chronic prednisone (steroid is presumed cause)",
    "  Path B (30%): AVN dx only (other cause — alcohol, trauma — not modeled but valid)",
    "  Path C (10%): chronic prednisone without AVN dx (TRICKY — most prednisone users do not develop AVN; tests LLM ability to find a complication phenotype within a much larger drug-exposed population)",
    "",
    "Age guard: >=30."
  ],
  "states": {
    "Initial": { "type": "Initial", "direct_transition": "Age_Guard" },
    "Age_Guard": { "type": "Guard", "allow": { "condition_type": "Age", "operator": ">=", "quantity": 30, "unit": "years" }, "direct_transition": "Set_Avn_Flag" },
    "Set_Avn_Flag": { "type": "SetAttribute", "attribute": "avn_positive", "value": true, "direct_transition": "Choose_Patient_Path" },
    "Choose_Patient_Path": {
      "type": "Simple",
      "distributed_transition": [
        { "transition": "Set_Path_A", "distribution": 0.60 },
        { "transition": "Set_Path_B", "distribution": 0.30 },
        { "transition": "Set_Path_C", "distribution": 0.10 }
      ]
    },
    "Set_Path_A": { "type": "SetAttribute", "attribute": "avn_has_dx", "value": true, "direct_transition": "Set_Path_A_Med" },
    "Set_Path_A_Med": { "type": "SetAttribute", "attribute": "avn_has_med", "value": true, "direct_transition": "Set_Needs_First_Visit" },
    "Set_Path_B": { "type": "SetAttribute", "attribute": "avn_has_dx", "value": true, "direct_transition": "Set_Path_B_Med" },
    "Set_Path_B_Med": { "type": "SetAttribute", "attribute": "avn_has_med", "value": false, "direct_transition": "Set_Needs_First_Visit" },
    "Set_Path_C": { "type": "SetAttribute", "remarks": ["TRICKY: prednisone without AVN dx"], "attribute": "avn_has_dx", "value": false, "direct_transition": "Set_Path_C_Med" },
    "Set_Path_C_Med": { "type": "SetAttribute", "attribute": "avn_has_med", "value": true, "direct_transition": "Set_Needs_First_Visit" },

    "Set_Needs_First_Visit": { "type": "SetAttribute", "attribute": "avn_needs_first_visit", "value": true, "direct_transition": "Wellness_Encounter" },
    "Wellness_Encounter": { "type": "Encounter", "wellness": true, "direct_transition": "Check_First_Visit" },
    "Check_First_Visit": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "avn_needs_first_visit", "operator": "==", "value": true }, "transition": "Check_Has_Diagnosis" },
        { "transition": "End_Wellness_Encounter" }
      ]
    },
    "Check_Has_Diagnosis": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "avn_has_dx", "operator": "==", "value": true }, "transition": "Diagnose_Avn" },
        { "transition": "Check_Med_NoDx" }
      ]
    },
    "Diagnose_Avn": { "type": "ConditionOnset", "assign_to_attribute": "avn_condition", "codes": [{ "system": "SNOMED-CT", "code": "203483005", "display": "Osteonecrosis caused by drug" }], "direct_transition": "Check_Med_WithDx" },

    "Check_Med_WithDx": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "avn_has_med", "operator": "==", "value": true }, "transition": "Prescribe_Pred_WithDx" },
        { "transition": "Clear_First_Visit_Flag" }
      ]
    },
    "Prescribe_Pred_WithDx": { "type": "MedicationOrder", "codes": [{ "system": "RxNorm", "code": "8640", "display": "prednisone" }], "reason": "avn_condition", "direct_transition": "Clear_First_Visit_Flag" },

    "Check_Med_NoDx": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "avn_has_med", "operator": "==", "value": true }, "transition": "Prescribe_Pred_NoDx" },
        { "transition": "Clear_First_Visit_Flag" }
      ]
    },
    "Prescribe_Pred_NoDx": { "type": "MedicationOrder", "codes": [{ "system": "RxNorm", "code": "8640", "display": "prednisone" }], "direct_transition": "Clear_First_Visit_Flag" },

    "Clear_First_Visit_Flag": { "type": "SetAttribute", "attribute": "avn_needs_first_visit", "value": false, "direct_transition": "End_Wellness_Encounter" },
    "End_Wellness_Encounter": { "type": "EncounterEnd", "direct_transition": "Followup_Delay" },
    "Followup_Delay": { "type": "Delay", "range": { "low": 6, "high": 12, "unit": "months" }, "direct_transition": "Wellness_Encounter" }
  },
  "gmf_version": 2
}
