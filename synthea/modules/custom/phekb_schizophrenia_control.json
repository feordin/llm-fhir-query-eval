{
  "name": "PheKB Schizophrenia Control",
  "remarks": [
    "Control module for schizophrenia. Generates adult patients without schizophrenia dx or antipsychotic Rx."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 18,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "schizo_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Schizoaffective_disorder"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Schizoaffective_disorder": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Schizoaffective_disorder",
          "distribution": 0.15
        },
        {
          "transition": "Maybe_Mimicker_Bipolar_disorder",
          "distribution": 0.85
        }
      ]
    },
    "Diagnose_Mimicker_Schizoaffective_disorder": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "68890003",
          "display": "Schizoaffective disorder"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Bipolar_disorder"
    },
    "Maybe_Mimicker_Bipolar_disorder": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Bipolar_disorder",
          "distribution": 0.1
        },
        {
          "transition": "Maybe_Mimicker_Delusional_disorder",
          "distribution": 0.9
        }
      ]
    },
    "Diagnose_Mimicker_Bipolar_disorder": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "13746004",
          "display": "Bipolar disorder"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Delusional_disorder"
    },
    "Maybe_Mimicker_Delusional_disorder": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Delusional_disorder",
          "distribution": 0.05
        },
        {
          "transition": "Maybe_Mimicker_Drug_induced_psychosis",
          "distribution": 0.95
        }
      ]
    },
    "Diagnose_Mimicker_Delusional_disorder": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "48500005",
          "display": "Delusional disorder"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Drug_induced_psychosis"
    },
    "Maybe_Mimicker_Drug_induced_psychosis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Drug_induced_psychosis",
          "distribution": 0.05
        },
        {
          "transition": "End_Wellness_Encounter",
          "distribution": 0.95
        }
      ]
    },
    "Diagnose_Mimicker_Drug_induced_psychosis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "191483003",
          "display": "Drug-induced psychosis"
        }
      ],
      "direct_transition": "End_Wellness_Encounter"
    }
  },
  "gmf_version": 2
}
