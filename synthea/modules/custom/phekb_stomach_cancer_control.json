{
  "name": "PheKB Stomach Cancer Control",
  "remarks": [
    "Control module for stomach cancer. Generates patients age 50+ without stomach cancer dx."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 50,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "stomach_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Peptic_ulcer"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Peptic_ulcer": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Peptic_ulcer",
          "distribution": 0.2
        },
        {
          "transition": "Maybe_Mimicker_Gastritis",
          "distribution": 0.8
        }
      ]
    },
    "Diagnose_Mimicker_Peptic_ulcer": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "13200003",
          "display": "Peptic ulcer"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Gastritis"
    },
    "Maybe_Mimicker_Gastritis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Gastritis",
          "distribution": 0.25
        },
        {
          "transition": "Maybe_Mimicker_Gastroesophageal_reflux_disease",
          "distribution": 0.75
        }
      ]
    },
    "Diagnose_Mimicker_Gastritis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "4556007",
          "display": "Gastritis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Gastroesophageal_reflux_disease"
    },
    "Maybe_Mimicker_Gastroesophageal_reflux_disease": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Gastroesophageal_reflux_disease",
          "distribution": 0.3
        },
        {
          "transition": "Maybe_Mimicker_Infection_caused_by_Helicobacter_pylori",
          "distribution": 0.7
        }
      ]
    },
    "Diagnose_Mimicker_Gastroesophageal_reflux_disease": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "235595009",
          "display": "Gastroesophageal reflux disease"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Infection_caused_by_Helicobacter_pylori"
    },
    "Maybe_Mimicker_Infection_caused_by_Helicobacter_pylori": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Infection_caused_by_Helicobacter_pylori",
          "distribution": 0.15
        },
        {
          "transition": "Maybe_Mimicker_Gastric_polyposis",
          "distribution": 0.85
        }
      ]
    },
    "Diagnose_Mimicker_Infection_caused_by_Helicobacter_pylori": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "721730009",
          "display": "Infection caused by Helicobacter pylori"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Gastric_polyposis"
    },
    "Maybe_Mimicker_Gastric_polyposis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Gastric_polyposis",
          "distribution": 0.05
        },
        {
          "transition": "End_Wellness_Encounter",
          "distribution": 0.95
        }
      ]
    },
    "Diagnose_Mimicker_Gastric_polyposis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "87252009",
          "display": "Gastric polyposis"
        }
      ],
      "direct_transition": "End_Wellness_Encounter"
    }
  },
  "gmf_version": 2
}
