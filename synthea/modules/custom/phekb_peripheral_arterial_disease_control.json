{
  "name": "PheKB Peripheral Arterial Disease Control",
  "remarks": [
    "Control module for PheKB PAD phenotype.",
    "Generates patients without PAD."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 50,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "pad_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Peripheral_venous_insufficiency"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Peripheral_venous_insufficiency": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Peripheral_venous_insufficiency",
          "distribution": 0.2
        },
        {
          "transition": "Maybe_Mimicker_Diabetic_peripheral_neuropathy",
          "distribution": 0.8
        }
      ]
    },
    "Diagnose_Mimicker_Peripheral_venous_insufficiency": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "20696009",
          "display": "Peripheral venous insufficiency"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Diabetic_peripheral_neuropathy"
    },
    "Maybe_Mimicker_Diabetic_peripheral_neuropathy": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Diabetic_peripheral_neuropathy",
          "distribution": 0.25
        },
        {
          "transition": "Maybe_Mimicker_Spinal_stenosis_of_lumbar_region",
          "distribution": 0.75
        }
      ]
    },
    "Diagnose_Mimicker_Diabetic_peripheral_neuropathy": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "424736006",
          "display": "Diabetic peripheral neuropathy"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Spinal_stenosis_of_lumbar_region"
    },
    "Maybe_Mimicker_Spinal_stenosis_of_lumbar_region": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Spinal_stenosis_of_lumbar_region",
          "distribution": 0.15
        },
        {
          "transition": "Maybe_Mimicker_Deep_venous_thrombosis",
          "distribution": 0.85
        }
      ]
    },
    "Diagnose_Mimicker_Spinal_stenosis_of_lumbar_region": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "18347007",
          "display": "Spinal stenosis of lumbar region"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Deep_venous_thrombosis"
    },
    "Maybe_Mimicker_Deep_venous_thrombosis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Deep_venous_thrombosis",
          "distribution": 0.05
        },
        {
          "transition": "Maybe_Mimicker_Cellulitis",
          "distribution": 0.95
        }
      ]
    },
    "Diagnose_Mimicker_Deep_venous_thrombosis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "128053003",
          "display": "Deep venous thrombosis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Cellulitis"
    },
    "Maybe_Mimicker_Cellulitis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Cellulitis",
          "distribution": 0.08
        },
        {
          "transition": "End_Wellness_Encounter",
          "distribution": 0.92
        }
      ]
    },
    "Diagnose_Mimicker_Cellulitis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "128045006",
          "display": "Cellulitis"
        }
      ],
      "direct_transition": "End_Wellness_Encounter"
    }
  },
  "gmf_version": 2
}
