{
  "name": "PheKB Hyperthyroidism Control",
  "remarks": [
    "Control module for hyperthyroidism. Generates adult patients with normal TSH (0.4-4.0 mIU/L)."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 18,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "hyper_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Generalized_anxiety_disorder"
    },
    "Record_Normal_TSH": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "mIU/L",
      "codes": [
        {
          "system": "LOINC",
          "code": "3016-3",
          "display": "Thyrotropin [Units/volume] in Serum or Plasma"
        }
      ],
      "range": {
        "low": 0.5,
        "high": 4.0
      },
      "direct_transition": "End_Wellness_Encounter"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Generalized_anxiety_disorder": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Generalized_anxiety_disorder",
          "distribution": 0.15
        },
        {
          "transition": "Maybe_Mimicker_Pheochromocytoma",
          "distribution": 0.85
        }
      ]
    },
    "Diagnose_Mimicker_Generalized_anxiety_disorder": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "21897009",
          "display": "Generalized anxiety disorder"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Pheochromocytoma"
    },
    "Maybe_Mimicker_Pheochromocytoma": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Pheochromocytoma",
          "distribution": 0.001
        },
        {
          "transition": "Maybe_Mimicker_Cocaine_abuse",
          "distribution": 0.999
        }
      ]
    },
    "Diagnose_Mimicker_Pheochromocytoma": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "253032007",
          "display": "Benign pheochromocytoma"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Cocaine_abuse"
    },
    "Maybe_Mimicker_Cocaine_abuse": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Cocaine_abuse",
          "distribution": 0.02
        },
        {
          "transition": "Record_Normal_TSH",
          "distribution": 0.98
        }
      ]
    },
    "Diagnose_Mimicker_Cocaine_abuse": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "78267003",
          "display": "Harmful pattern of use of cocaine"
        }
      ],
      "direct_transition": "Record_Normal_TSH"
    }
  },
  "gmf_version": 2
}
