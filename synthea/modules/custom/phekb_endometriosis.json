{
  "name": "PheKB Endometriosis",
  "remarks": [
    "Custom Synthea module for endometriosis.",
    "First female non-cancer reproductive phenotype.",
    "",
    "Generates THREE patient paths:",
    "  Path A (60%): Endometriosis dx + leuprolide (GnRH agonist)",
    "  Path B (30%): Endometriosis dx only (managed with NSAIDs/oral contraceptives, not modeled)",
    "  Path C (10%): leuprolide without endometriosis dx (TRICKY — also indicated for prostate cancer ADT, central precocious puberty; here female-restricted so cross-indication is rare)",
    "",
    "Sex guard: F only. Age guard: 18-50 (reproductive years)."
  ],
  "states": {
    "Initial": { "type": "Initial", "direct_transition": "Sex_Guard" },
    "Sex_Guard": { "type": "Guard", "allow": { "condition_type": "Gender", "gender": "F" }, "direct_transition": "Age_Guard" },
    "Age_Guard": { "type": "Guard", "allow": { "condition_type": "Age", "operator": ">=", "quantity": 18, "unit": "years" }, "direct_transition": "Age_Upper_Guard" },
    "Age_Upper_Guard": { "type": "Guard", "allow": { "condition_type": "Age", "operator": "<=", "quantity": 50, "unit": "years" }, "direct_transition": "Set_Endo_Flag" },
    "Set_Endo_Flag": { "type": "SetAttribute", "attribute": "endo_positive", "value": true, "direct_transition": "Choose_Patient_Path" },
    "Choose_Patient_Path": {
      "type": "Simple",
      "distributed_transition": [
        { "transition": "Set_Path_A", "distribution": 0.60 },
        { "transition": "Set_Path_B", "distribution": 0.30 },
        { "transition": "Set_Path_C", "distribution": 0.10 }
      ]
    },
    "Set_Path_A": { "type": "SetAttribute", "attribute": "endo_has_dx", "value": true, "direct_transition": "Set_Path_A_Med" },
    "Set_Path_A_Med": { "type": "SetAttribute", "attribute": "endo_has_med", "value": true, "direct_transition": "Set_Needs_First_Visit" },
    "Set_Path_B": { "type": "SetAttribute", "attribute": "endo_has_dx", "value": true, "direct_transition": "Set_Path_B_Med" },
    "Set_Path_B_Med": { "type": "SetAttribute", "attribute": "endo_has_med", "value": false, "direct_transition": "Set_Needs_First_Visit" },
    "Set_Path_C": { "type": "SetAttribute", "remarks": ["TRICKY: leuprolide without endometriosis dx"], "attribute": "endo_has_dx", "value": false, "direct_transition": "Set_Path_C_Med" },
    "Set_Path_C_Med": { "type": "SetAttribute", "attribute": "endo_has_med", "value": true, "direct_transition": "Set_Needs_First_Visit" },

    "Set_Needs_First_Visit": { "type": "SetAttribute", "attribute": "endo_needs_first_visit", "value": true, "direct_transition": "Wellness_Encounter" },
    "Wellness_Encounter": { "type": "Encounter", "wellness": true, "direct_transition": "Check_First_Visit" },
    "Check_First_Visit": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "endo_needs_first_visit", "operator": "==", "value": true }, "transition": "Check_Has_Diagnosis" },
        { "transition": "End_Wellness_Encounter" }
      ]
    },
    "Check_Has_Diagnosis": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "endo_has_dx", "operator": "==", "value": true }, "transition": "Diagnose_Endo" },
        { "transition": "Check_Med_NoDx" }
      ]
    },
    "Diagnose_Endo": { "type": "ConditionOnset", "assign_to_attribute": "endo_condition", "codes": [{ "system": "SNOMED-CT", "code": "76376003", "display": "Endometriosis of uterus" }], "direct_transition": "Check_Med_WithDx" },

    "Check_Med_WithDx": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "endo_has_med", "operator": "==", "value": true }, "transition": "Prescribe_Leuprolide_WithDx" },
        { "transition": "Clear_First_Visit_Flag" }
      ]
    },
    "Prescribe_Leuprolide_WithDx": { "type": "MedicationOrder", "codes": [{ "system": "RxNorm", "code": "752899", "display": "0.25 ML leuprolide acetate 30 MG/ML Prefilled Syringe" }], "reason": "endo_condition", "direct_transition": "Clear_First_Visit_Flag" },

    "Check_Med_NoDx": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "endo_has_med", "operator": "==", "value": true }, "transition": "Prescribe_Leuprolide_NoDx" },
        { "transition": "Clear_First_Visit_Flag" }
      ]
    },
    "Prescribe_Leuprolide_NoDx": { "type": "MedicationOrder", "codes": [{ "system": "RxNorm", "code": "752899", "display": "0.25 ML leuprolide acetate 30 MG/ML Prefilled Syringe" }], "direct_transition": "Clear_First_Visit_Flag" },

    "Clear_First_Visit_Flag": { "type": "SetAttribute", "attribute": "endo_needs_first_visit", "value": false, "direct_transition": "End_Wellness_Encounter" },
    "End_Wellness_Encounter": { "type": "EncounterEnd", "direct_transition": "Followup_Delay" },
    "Followup_Delay": { "type": "Delay", "range": { "low": 6, "high": 12, "unit": "months" }, "direct_transition": "Wellness_Encounter" }
  },
  "gmf_version": 2
}
