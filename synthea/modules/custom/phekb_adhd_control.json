          "distribution": 0.94
        }
      ]
    },
    "Diagnose_Mimicker_Depressive_disorder": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "35489007",
          "display": "Depressive disorder"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Oppositional_defiant_disorder"
    },
    "Maybe_Mimicker_Oppositional_defiant_disorder": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Oppositional_defiant_disorder",
          "distribution": 0.04
        },
        {
          "transition": "Check_Other_Conditions",
          "distribution": 0.96
        }
      ]
    },
    "Diagnose_Mimicker_Oppositional_defiant_disorder": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "18941000",
          "display": "Oppositional defiant disorder"
        }
      ],
      "direct_transition": "Check_Other_Conditions"
    },
    "Maybe_Mimicker_Pervasive_developmental_disorder": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Pervasive_developmental_disorder",
          "distribution": 0.04
        },
        {
          "transition": "Maybe_Mimicker_Anxiety_disorder",
          "distribution": 0.96
        }
      ]
    },
    "Diagnose_Mimicker_Pervasive_developmental_disorder": {
