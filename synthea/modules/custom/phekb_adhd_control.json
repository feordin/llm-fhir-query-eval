{
  "name": "PheKB ADHD Control (Non-ADHD)",
  "remarks": [
    "Control module for ADHD phenotype testing",
    "Generates patients who should NOT match ADHD criteria",
    "",
    "Control Criteria (exclusion from ADHD):",
    "- No ADHD diagnosis codes",
    "- No ADHD/stimulant medications",
    "- Age 4+ with 2+ visits in past 5 years",
    "- No psychiatric/neurological diagnoses or medications",
    "",
    "Some control patients have unrelated conditions for variety.",
    "These patients should NOT be returned by ADHD queries."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 4,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "adhd_control",
      "value": true,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Developmental_academic_disorder"
    },
    "Check_Other_Conditions": {
      "type": "Simple",
      "remarks": [
        "Some control patients have non-ADHD conditions for variety"
      ],
      "distributed_transition": [
        {
          "transition": "Diagnose_Common_Cold",
          "distribution": 0.25
        },
        {
          "transition": "Diagnose_Otitis_Media",
          "distribution": 0.2
        },
        {
          "transition": "Diagnose_Allergic_Rhinitis",
          "distribution": 0.15
        },
        {
          "transition": "End_Wellness_Encounter",
          "distribution": 0.4
        }
      ]
    },
    "Diagnose_Common_Cold": {
      "type": "ConditionOnset",
      "assign_to_attribute": "common_cold",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "82272006",
          "display": "Common cold"
        }
      ],
      "remarks": [
        "Non-ADHD condition for control population variety"
      ],
      "direct_transition": "End_Wellness_Encounter"
    },
    "Diagnose_Otitis_Media": {
      "type": "ConditionOnset",
      "assign_to_attribute": "otitis_media",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "65363002",
          "display": "Otitis media"
        }
      ],
      "remarks": [
        "Non-ADHD condition - ear infection, common in pediatric population"
      ],
      "direct_transition": "Prescribe_Amoxicillin"
    },
    "Prescribe_Amoxicillin": {
      "type": "MedicationOrder",
      "codes": [
        {
          "system": "RxNorm",
          "code": "308182",
          "display": "amoxicillin 250 MG Oral Capsule"
        }
      ],
      "reason": "otitis_media",
      "direct_transition": "End_Wellness_Encounter"
    },
    "Diagnose_Allergic_Rhinitis": {
      "type": "ConditionOnset",
      "assign_to_attribute": "allergic_rhinitis",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "61582004",
          "display": "Allergic rhinitis"
        }
      ],
      "remarks": [
        "Non-ADHD condition for control population variety"
      ],
      "direct_transition": "Prescribe_Cetirizine"
    },
    "Prescribe_Cetirizine": {
      "type": "MedicationOrder",
      "codes": [
        {
          "system": "RxNorm",
          "code": "1014678",
          "display": "cetirizine hydrochloride 10 MG Oral Tablet"
        }
      ],
      "reason": "allergic_rhinitis",
      "direct_transition": "End_Wellness_Encounter"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Terminal_Control"
    },
    "Terminal_Control": {
      "type": "Terminal",
      "remarks": [
        "Control patient - should NOT be found by ADHD phenotype query"
      ]
    },
    "Maybe_Mimicker_Anxiety_disorder": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Anxiety_disorder",
          "distribution": 0.15
        },
        {
          "transition": "Maybe_Mimicker_Learning_disability",
          "distribution": 0.85
        }
      ]
    },
    "Diagnose_Mimicker_Anxiety_disorder": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "197480006",
          "display": "Anxiety disorder"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Learning_disability"
    },
    "Maybe_Mimicker_Learning_disability": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Learning_disability",
          "distribution": 0.08
        },
        {
          "transition": "Maybe_Mimicker_Depressive_disorder",
          "distribution": 0.92
        }
      ]
    },
    "Diagnose_Mimicker_Learning_disability": {
