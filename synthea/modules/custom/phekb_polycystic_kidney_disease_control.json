{
  "name": "PheKB Polycystic Kidney Disease Control",
  "remarks": [
    "Control module for PKD. Generates adult patients without PKD dx."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 18,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "pkd_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Cyst_of_kidney"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Cyst_of_kidney": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Cyst_of_kidney",
          "distribution": 0.4
        },
        {
          "transition": "Maybe_Mimicker_Chronic_kidney_disease",
          "distribution": 0.6
        }
      ]
    },
    "Diagnose_Mimicker_Cyst_of_kidney": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "722223000",
          "display": "Cyst of kidney"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Chronic_kidney_disease"
    },
    "Maybe_Mimicker_Chronic_kidney_disease": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Chronic_kidney_disease",
          "distribution": 0.2
        },
        {
          "transition": "Maybe_Mimicker_Renal_cell_carcinoma",
          "distribution": 0.8
        }
      ]
    },
    "Diagnose_Mimicker_Chronic_kidney_disease": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "709044004",
          "display": "Chronic kidney disease"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Renal_cell_carcinoma"
    },
    "Maybe_Mimicker_Renal_cell_carcinoma": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Renal_cell_carcinoma",
          "distribution": 0.05
        },
        {
          "transition": "Maybe_Mimicker_Multicystic_renal_dysplasia",
          "distribution": 0.95
        }
      ]
    },
    "Diagnose_Mimicker_Renal_cell_carcinoma": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "702391001",
          "display": "Renal cell carcinoma"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Multicystic_renal_dysplasia"
    },
    "Maybe_Mimicker_Multicystic_renal_dysplasia": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Multicystic_renal_dysplasia",
          "distribution": 0.03
        },
        {
          "transition": "Maybe_Mimicker_Pyelonephritis",
          "distribution": 0.97
        }
      ]
    },
    "Diagnose_Mimicker_Multicystic_renal_dysplasia": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "737562008",
          "display": "Multicystic renal dysplasia"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Pyelonephritis"
    },
    "Maybe_Mimicker_Pyelonephritis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Pyelonephritis",
          "distribution": 0.1
        },
        {
          "transition": "End_Wellness_Encounter",
          "distribution": 0.9
        }
      ]
    },
    "Diagnose_Mimicker_Pyelonephritis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "45816000",
          "display": "Pyelonephritis"
        }
      ],
      "direct_transition": "End_Wellness_Encounter"
    }
  },
  "gmf_version": 2
}
