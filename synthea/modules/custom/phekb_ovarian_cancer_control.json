{
  "name": "PheKB Ovarian Cancer Control",
  "remarks": [
    "Control module for PheKB ovarian cancer phenotype. Generates female patients without ovarian cancer. Normal CA-125 (5-25 U/mL)."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Sex_Guard"
    },
    "Sex_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Gender",
        "gender": "F"
      },
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 45,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "ovca_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Cyst_of_ovary"
    },
    "Record_Normal_CA125": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "U/mL",
      "codes": [
        {
          "system": "LOINC",
          "code": "10334-1",
          "display": "Cancer Ag 125 [Units/volume] in Serum or Plasma"
        }
      ],
      "range": {
        "low": 5,
        "high": 25
      },
      "direct_transition": "End_Wellness_Encounter"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Cyst_of_ovary": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Cyst_of_ovary",
          "distribution": 0.35
        },
        {
          "transition": "Maybe_Mimicker_Endometriosis",
          "distribution": 0.65
        }
      ]
    },
    "Diagnose_Mimicker_Cyst_of_ovary": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "79883001",
          "display": "Cyst of ovary"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Endometriosis"
    },
    "Maybe_Mimicker_Endometriosis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Endometriosis",
          "distribution": 0.15
        },
        {
          "transition": "Maybe_Mimicker_Malignant_neoplasm_of_endometrium_of_corpus_uteri",
          "distribution": 0.85
        }
      ]
    },
    "Diagnose_Mimicker_Endometriosis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "396224008",
          "display": "Endometriosis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Malignant_neoplasm_of_endometrium_of_corpus_uteri"
    },
    "Maybe_Mimicker_Malignant_neoplasm_of_endometrium_of_corpus_uteri": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Malignant_neoplasm_of_endometrium_of_corpus_uteri",
          "distribution": 0.08
        },
        {
          "transition": "Maybe_Mimicker_Malignant_neoplasm_of_fallopian_tube",
          "distribution": 0.92
        }
      ]
    },
    "Diagnose_Mimicker_Malignant_neoplasm_of_endometrium_of_corpus_uteri": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "188192002",
          "display": "Malignant neoplasm of endometrium of corpus uteri"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Malignant_neoplasm_of_fallopian_tube"
    },
    "Maybe_Mimicker_Malignant_neoplasm_of_fallopian_tube": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Malignant_neoplasm_of_fallopian_tube",
          "distribution": 0.03
        },
        {
          "transition": "Maybe_Mimicker_Female_pelvic_inflammatory_disease",
          "distribution": 0.97
        }
      ]
    },
    "Diagnose_Mimicker_Malignant_neoplasm_of_fallopian_tube": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "363444001",
          "display": "Malignant neoplasm of fallopian tube"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Female_pelvic_inflammatory_disease"
    },
    "Maybe_Mimicker_Female_pelvic_inflammatory_disease": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Female_pelvic_inflammatory_disease",
          "distribution": 0.05
        },
        {
          "transition": "Record_Normal_CA125",
          "distribution": 0.95
        }
      ]
    },
    "Diagnose_Mimicker_Female_pelvic_inflammatory_disease": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "198130006",
          "display": "Female pelvic inflammatory disease"
        }
      ],
      "direct_transition": "Record_Normal_CA125"
    }
  },
  "gmf_version": 2
}
