{
  "name": "PheKB Ovarian Cancer Control",
  "remarks": ["Control module for PheKB ovarian cancer phenotype. Generates female patients without ovarian cancer. Normal CA-125 (5-25 U/mL)."],
  "states": {
    "Initial": { "type": "Initial", "direct_transition": "Sex_Guard" },
    "Sex_Guard": { "type": "Guard", "allow": { "condition_type": "Gender", "gender": "F" }, "direct_transition": "Age_Guard" },
    "Age_Guard": { "type": "Guard", "allow": { "condition_type": "Age", "operator": ">=", "quantity": 45, "unit": "years" }, "direct_transition": "Set_Control_Flag" },
    "Set_Control_Flag": { "type": "SetAttribute", "attribute": "ovca_positive", "value": false, "direct_transition": "Wellness_Encounter" },
    "Wellness_Encounter": { "type": "Encounter", "wellness": true, "direct_transition": "Record_Normal_CA125" },
    "Record_Normal_CA125": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "U/mL",
      "codes": [{ "system": "LOINC", "code": "10334-1", "display": "Cancer Ag 125 [Units/volume] in Serum or Plasma" }],
      "range": { "low": 5, "high": 25 },
      "direct_transition": "End_Wellness_Encounter"
    },
    "End_Wellness_Encounter": { "type": "EncounterEnd", "direct_transition": "Followup_Delay" },
    "Followup_Delay": { "type": "Delay", "range": { "low": 12, "high": 24, "unit": "months" }, "direct_transition": "Wellness_Encounter" }
  },
  "gmf_version": 2
}
