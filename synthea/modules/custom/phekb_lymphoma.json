{
  "name": "PheKB Lymphoma",
  "remarks": [
    "Custom Synthea module for lymphoma.",
    "17th cancer phenotype, second hematologic malignancy. Uses 'Malignant lymphoma' SNOMED covering Hodgkin and non-Hodgkin lymphoma.",
    "Single-path: 100% have lymphoma dx. Age guard: >=18."
  ],
  "states": {
    "Initial": { "type": "Initial", "direct_transition": "Age_Guard" },
    "Age_Guard": { "type": "Guard", "allow": { "condition_type": "Age", "operator": ">=", "quantity": 18, "unit": "years" }, "direct_transition": "Set_Lym_Flag" },
    "Set_Lym_Flag": { "type": "SetAttribute", "attribute": "lym_positive", "value": true, "direct_transition": "Set_Needs_First_Visit" },
    "Set_Needs_First_Visit": { "type": "SetAttribute", "attribute": "lym_needs_first_visit", "value": true, "direct_transition": "Wellness_Encounter" },
    "Wellness_Encounter": { "type": "Encounter", "wellness": true, "direct_transition": "Check_First_Visit" },
    "Check_First_Visit": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "lym_needs_first_visit", "operator": "==", "value": true }, "transition": "Diagnose_Lym" },
        { "transition": "End_Wellness_Encounter" }
      ]
    },
    "Diagnose_Lym": { "type": "ConditionOnset", "assign_to_attribute": "lym_condition", "codes": [{ "system": "SNOMED-CT", "code": "118600007", "display": "Malignant lymphoma" }], "direct_transition": "Clear_First_Visit_Flag" },
    "Clear_First_Visit_Flag": { "type": "SetAttribute", "attribute": "lym_needs_first_visit", "value": false, "direct_transition": "End_Wellness_Encounter" },
    "End_Wellness_Encounter": { "type": "EncounterEnd", "direct_transition": "Followup_Delay" },
    "Followup_Delay": { "type": "Delay", "range": { "low": 6, "high": 12, "unit": "months" }, "direct_transition": "Wellness_Encounter" }
  },
  "gmf_version": 2
}
