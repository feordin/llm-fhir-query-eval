{
  "name": "PheKB Familial Hypercholesterolemia Control",
  "remarks": [
    "Control module for PheKB FH phenotype.",
    "Generates patients who do NOT have FH.",
    "",
    "Controls per Geisinger PheKB FH algorithm must:",
    "  - Have no FH diagnosis",
    "  - Have LDL < 155 mg/dL (algorithm cutoff for FH controls)",
    "  - Have no statin therapy",
    "",
    "Lab values (intentionally below the case threshold of LDL >= 190):",
    "  Control LDL range: 70-145 mg/dL"
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 25,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "fh_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Hyperlipidemia_group_A"
    },
    "Record_Normal_LDL": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "mg/dL",
      "codes": [
        {
          "system": "LOINC",
          "code": "2089-1",
          "display": "Cholesterol in LDL [Mass/volume] in Serum or Plasma"
        }
      ],
      "range": {
        "low": 70,
        "high": 145
      },
      "direct_transition": "End_Wellness_Encounter"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Hyperlipidemia_group_A": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Hyperlipidemia_group_A",
          "distribution": 0.3
        },
        {
          "transition": "Maybe_Mimicker_Mixed_hyperlipidemia",
          "distribution": 0.7
        }
      ]
    },
    "Diagnose_Mimicker_Hyperlipidemia_group_A": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "190774002",
          "display": "Hyperlipidemia, group A"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Mixed_hyperlipidemia"
    },
    "Maybe_Mimicker_Mixed_hyperlipidemia": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Mixed_hyperlipidemia",
          "distribution": 0.2
        },
        {
          "transition": "Maybe_Mimicker_Type_2_diabetes_mellitus",
          "distribution": 0.8
        }
      ]
    },
    "Diagnose_Mimicker_Mixed_hyperlipidemia": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "267434003",
          "display": "Mixed hyperlipidemia"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Type_2_diabetes_mellitus"
    },
    "Maybe_Mimicker_Type_2_diabetes_mellitus": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Type_2_diabetes_mellitus",
          "distribution": 0.15
        },
        {
          "transition": "Maybe_Mimicker_Hypothyroidism",
          "distribution": 0.85
        }
      ]
    },
    "Diagnose_Mimicker_Type_2_diabetes_mellitus": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "44054006",
          "display": "Type 2 diabetes mellitus"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Hypothyroidism"
    },
    "Maybe_Mimicker_Hypothyroidism": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Hypothyroidism",
          "distribution": 0.1
        },
        {
          "transition": "Maybe_Mimicker_Nephrotic_syndrome",
          "distribution": 0.9
        }
      ]
    },
    "Diagnose_Mimicker_Hypothyroidism": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "40930008",
          "display": "Hypothyroidism"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Nephrotic_syndrome"
    },
    "Maybe_Mimicker_Nephrotic_syndrome": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Nephrotic_syndrome",
          "distribution": 0.02
        },
        {
          "transition": "Record_Normal_LDL",
          "distribution": 0.98
        }
      ]
    },
    "Diagnose_Mimicker_Nephrotic_syndrome": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "52254009",
          "display": "Nephrotic syndrome"
        }
      ],
      "direct_transition": "Record_Normal_LDL"
    }
  },
  "gmf_version": 2
}
