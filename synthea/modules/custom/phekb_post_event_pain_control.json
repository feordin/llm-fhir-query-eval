{
  "name": "PheKB Post-event Pain Control",
  "remarks": ["Control: pediatric age 6-21 without scoliosis surgery or pain assessments."],
  "states": {
    "Initial": { "type": "Initial", "direct_transition": "Age_Lower_Guard" },
    "Age_Lower_Guard": { "type": "Guard", "allow": { "condition_type": "Age", "operator": ">=", "quantity": 6, "unit": "years" }, "direct_transition": "Age_Upper_Guard" },
    "Age_Upper_Guard": { "type": "Guard", "allow": { "condition_type": "Age", "operator": "<=", "quantity": 21, "unit": "years" }, "direct_transition": "Set_Control_Flag" },
    "Set_Control_Flag": { "type": "SetAttribute", "attribute": "pop_positive", "value": false, "direct_transition": "Wellness_Encounter" },
    "Wellness_Encounter": { "type": "Encounter", "wellness": true, "direct_transition": "End_Wellness_Encounter" },
    "End_Wellness_Encounter": { "type": "EncounterEnd", "direct_transition": "Followup_Delay" },
    "Followup_Delay": { "type": "Delay", "range": { "low": 12, "high": 24, "unit": "months" }, "direct_transition": "Wellness_Encounter" }
  },
  "gmf_version": 2
}
