{
  "name": "PheKB Post-event Pain Control",
  "remarks": [
    "Control: pediatric age 6-21 without scoliosis surgery or pain assessments."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Lower_Guard"
    },
    "Age_Lower_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 6,
        "unit": "years"
      },
      "direct_transition": "Age_Upper_Guard"
    },
    "Age_Upper_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": "<=",
        "quantity": 21,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "pop_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Headache"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Headache": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Headache",
          "distribution": 0.3
        },
        {
          "transition": "Maybe_Mimicker_Abdominal_pain",
          "distribution": 0.7
        }
      ]
    },
    "Diagnose_Mimicker_Headache": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "25064002",
          "display": "Headache"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Abdominal_pain"
    },
    "Maybe_Mimicker_Abdominal_pain": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Abdominal_pain",
          "distribution": 0.2
        },
        {
          "transition": "Maybe_Mimicker_Migraine",
          "distribution": 0.8
        }
      ]
    },
    "Diagnose_Mimicker_Abdominal_pain": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "21522001",
          "display": "Abdominal pain"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Migraine"
    },
    "Maybe_Mimicker_Migraine": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Migraine",
          "distribution": 0.1
        },
        {
          "transition": "Maybe_Mimicker_Low_back_pain",
          "distribution": 0.9
        }
      ]
    },
    "Diagnose_Mimicker_Migraine": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "37796009",
          "display": "Migraine"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Low_back_pain"
    },
    "Maybe_Mimicker_Low_back_pain": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Low_back_pain",
          "distribution": 0.15
        },
        {
          "transition": "Maybe_Mimicker_Juvenile_idiopathic_arthritis",
          "distribution": 0.85
        }
      ]
    },
    "Diagnose_Mimicker_Low_back_pain": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "279039007",
          "display": "Low back pain"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Juvenile_idiopathic_arthritis"
    },
    "Maybe_Mimicker_Juvenile_idiopathic_arthritis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Juvenile_idiopathic_arthritis",
          "distribution": 0.04
        },
        {
          "transition": "End_Wellness_Encounter",
          "distribution": 0.96
        }
      ]
    },
    "Diagnose_Mimicker_Juvenile_idiopathic_arthritis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "410502007",
          "display": "Juvenile idiopathic arthritis"
        }
      ],
      "direct_transition": "End_Wellness_Encounter"
    }
  },
  "gmf_version": 2
}
