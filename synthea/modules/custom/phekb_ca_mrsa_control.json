{
  "name": "PheKB Community-Acquired MRSA Control",
  "remarks": [
    "Control module. Generates patients age 18+ without CA-MRSA dx or clindamycin/linezolid."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 18,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "mrsa_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Cellulitis"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Cellulitis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Cellulitis",
          "distribution": 0.2
        },
        {
          "transition": "Maybe_Mimicker_Abscess_of_skin_and_or_subcutaneous_tissue",
          "distribution": 0.8
        }
      ]
    },
    "Diagnose_Mimicker_Cellulitis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "128045006",
          "display": "Cellulitis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Abscess_of_skin_and_or_subcutaneous_tissue"
    },
    "Maybe_Mimicker_Abscess_of_skin_and_or_subcutaneous_tissue": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Abscess_of_skin_and_or_subcutaneous_tissue",
          "distribution": 0.15
        },
        {
          "transition": "Maybe_Mimicker_Streptococcal_cellulitis",
          "distribution": 0.85
        }
      ]
    },
    "Diagnose_Mimicker_Abscess_of_skin_and_or_subcutaneous_tissue": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "31928004",
          "display": "Abscess of skin and/or subcutaneous tissue"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Streptococcal_cellulitis"
    },
    "Maybe_Mimicker_Streptococcal_cellulitis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Streptococcal_cellulitis",
          "distribution": 0.08
        },
        {
          "transition": "Maybe_Mimicker_Infection_by_methicillin_sensitive_Staphylococcus_aureus",
          "distribution": 0.92
        }
      ]
    },
    "Diagnose_Mimicker_Streptococcal_cellulitis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "278037002",
          "display": "Streptococcal cellulitis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Infection_by_methicillin_sensitive_Staphylococcus_aureus"
    },
    "Maybe_Mimicker_Infection_by_methicillin_sensitive_Staphylococcus_aureus": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Infection_by_methicillin_sensitive_Staphylococcus_aureus",
          "distribution": 0.05
        },
        {
          "transition": "Maybe_Mimicker_Furuncle",
          "distribution": 0.95
        }
      ]
    },
    "Diagnose_Mimicker_Infection_by_methicillin_sensitive_Staphylococcus_aureus": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "442073005",
          "display": "Infection by methicillin sensitive Staphylococcus aureus"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Furuncle"
    },
    "Maybe_Mimicker_Furuncle": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Furuncle",
          "distribution": 0.04
        },
        {
          "transition": "End_Wellness_Encounter",
          "distribution": 0.96
        }
      ]
    },
    "Diagnose_Mimicker_Furuncle": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "416675009",
          "display": "Furuncle"
        }
      ],
      "direct_transition": "End_Wellness_Encounter"
    }
  },
  "gmf_version": 2
}
