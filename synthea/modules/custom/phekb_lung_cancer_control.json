{
  "name": "PheKB Lung Cancer Control",
  "remarks": [
    "Control module for lung cancer. Generates patients age 50+ without lung cancer dx."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 50,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "lung_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Chronic_obstructive_pulmonary_disease"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Chronic_obstructive_pulmonary_disease": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Chronic_obstructive_pulmonary_disease",
          "distribution": 0.3
        },
        {
          "transition": "Maybe_Mimicker_Nodule_of_lung",
          "distribution": 0.7
        }
      ]
    },
    "Diagnose_Mimicker_Chronic_obstructive_pulmonary_disease": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "13645005",
          "display": "Chronic obstructive pulmonary disease"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Nodule_of_lung"
    },
    "Maybe_Mimicker_Nodule_of_lung": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Nodule_of_lung",
          "distribution": 0.2
        },
        {
          "transition": "Maybe_Mimicker_Pneumonia",
          "distribution": 0.8
        }
      ]
    },
    "Diagnose_Mimicker_Nodule_of_lung": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "786838002",
          "display": "Nodule of lung"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Pneumonia"
    },
    "Maybe_Mimicker_Pneumonia": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Pneumonia",
          "distribution": 0.15
        },
        {
          "transition": "Maybe_Mimicker_Pulmonary_tuberculosis",
          "distribution": 0.85
        }
      ]
    },
    "Diagnose_Mimicker_Pneumonia": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "233604007",
          "display": "Pneumonia"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Pulmonary_tuberculosis"
    },
    "Maybe_Mimicker_Pulmonary_tuberculosis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Pulmonary_tuberculosis",
          "distribution": 0.04
        },
        {
          "transition": "Maybe_Mimicker_Sarcoidosis",
          "distribution": 0.96
        }
      ]
    },
    "Diagnose_Mimicker_Pulmonary_tuberculosis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "154283005",
          "display": "Pulmonary tuberculosis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Sarcoidosis"
    },
    "Maybe_Mimicker_Sarcoidosis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Sarcoidosis",
          "distribution": 0.03
        },
        {
          "transition": "End_Wellness_Encounter",
          "distribution": 0.97
        }
      ]
    },
    "Diagnose_Mimicker_Sarcoidosis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "31541009",
          "display": "Sarcoidosis"
        }
      ],
      "direct_transition": "End_Wellness_Encounter"
    }
  },
  "gmf_version": 2
}
