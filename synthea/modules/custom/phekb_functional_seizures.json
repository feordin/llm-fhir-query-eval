{
  "name": "PheKB Functional Seizures (PNES)",
  "remarks": [
    "Custom Synthea module for psychogenic non-epileptic seizures (PNES, also called dissociative convulsions or functional seizures).",
    "First psychogenic neurologic phenotype, distinct from epilepsy.",
    "",
    "Single-path module: dx-only, no specific medications (managed by psychotherapy / cognitive behavioral therapy).",
    "Distinct from epilepsy because PNES patients often have NO antiseizure medications by design.",
    "",
    "Age guard: >=18 (typical adult onset)."
  ],
  "states": {
    "Initial": { "type": "Initial", "direct_transition": "Age_Guard" },
    "Age_Guard": { "type": "Guard", "allow": { "condition_type": "Age", "operator": ">=", "quantity": 18, "unit": "years" }, "direct_transition": "Set_Pnes_Flag" },
    "Set_Pnes_Flag": { "type": "SetAttribute", "attribute": "pnes_positive", "value": true, "direct_transition": "Set_Needs_First_Visit" },
    "Set_Needs_First_Visit": { "type": "SetAttribute", "attribute": "pnes_needs_first_visit", "value": true, "direct_transition": "Wellness_Encounter" },
    "Wellness_Encounter": { "type": "Encounter", "wellness": true, "direct_transition": "Check_First_Visit" },
    "Check_First_Visit": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "pnes_needs_first_visit", "operator": "==", "value": true }, "transition": "Diagnose_Pnes" },
        { "transition": "End_Wellness_Encounter" }
      ]
    },
    "Diagnose_Pnes": { "type": "ConditionOnset", "assign_to_attribute": "pnes_condition", "codes": [{ "system": "SNOMED-CT", "code": "191714002", "display": "Dissociative convulsions" }], "direct_transition": "Clear_First_Visit_Flag" },
    "Clear_First_Visit_Flag": { "type": "SetAttribute", "attribute": "pnes_needs_first_visit", "value": false, "direct_transition": "End_Wellness_Encounter" },
    "End_Wellness_Encounter": { "type": "EncounterEnd", "direct_transition": "Followup_Delay" },
    "Followup_Delay": { "type": "Delay", "range": { "low": 12, "high": 24, "unit": "months" }, "direct_transition": "Wellness_Encounter" }
  },
  "gmf_version": 2
}
