{
  "name": "PheKB Fibromyalgia Control",
  "remarks": [
    "Control module for fibromyalgia. Generates adult patients without fibromyalgia dx or duloxetine/gabapentin/amitriptyline."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 18,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "fm_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Chronic_fatigue_syndrome"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Chronic_fatigue_syndrome": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Chronic_fatigue_syndrome",
          "distribution": 0.15
        },
        {
          "transition": "Maybe_Mimicker_Polymyalgia_rheumatica",
          "distribution": 0.85
        }
      ]
    },
    "Diagnose_Mimicker_Chronic_fatigue_syndrome": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "52702003",
          "display": "Chronic fatigue syndrome"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Polymyalgia_rheumatica"
    },
    "Maybe_Mimicker_Polymyalgia_rheumatica": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Polymyalgia_rheumatica",
          "distribution": 0.08
        },
        {
          "transition": "Maybe_Mimicker_Hypothyroidism",
          "distribution": 0.92
        }
      ]
    },
    "Diagnose_Mimicker_Polymyalgia_rheumatica": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "65323003",
          "display": "Polymyalgia rheumatica"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Hypothyroidism"
    },
    "Maybe_Mimicker_Hypothyroidism": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Hypothyroidism",
          "distribution": 0.1
        },
        {
          "transition": "End_Wellness_Encounter",
          "distribution": 0.9
        }
      ]
    },
    "Diagnose_Mimicker_Hypothyroidism": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "40930008",
          "display": "Hypothyroidism"
        }
      ],
      "direct_transition": "End_Wellness_Encounter"
    }
  },
  "gmf_version": 2
}
