{
  "name": "PheKB Ulcerative Colitis Control",
  "remarks": [
    "Control module for UC. Generates patients age 15+ without UC dx or steroids."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 15,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "uc_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Crohn_s_disease"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Crohn_s_disease": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Crohn_s_disease",
          "distribution": 0.15
        },
        {
          "transition": "Maybe_Mimicker_Infectious_colitis",
          "distribution": 0.85
        }
      ]
    },
    "Diagnose_Mimicker_Crohn_s_disease": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "34000006",
          "display": "Crohn's disease"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Infectious_colitis"
    },
    "Maybe_Mimicker_Infectious_colitis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Infectious_colitis",
          "distribution": 0.1
        },
        {
          "transition": "Maybe_Mimicker_Ischemic_colitis",
          "distribution": 0.9
        }
      ]
    },
    "Diagnose_Mimicker_Infectious_colitis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "39341005",
          "display": "Infectious colitis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Ischemic_colitis"
    },
    "Maybe_Mimicker_Ischemic_colitis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Ischemic_colitis",
          "distribution": 0.05
        },
        {
          "transition": "Maybe_Mimicker_Irritable_bowel_syndrome",
          "distribution": 0.95
        }
      ]
    },
    "Diagnose_Mimicker_Ischemic_colitis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "30588004",
          "display": "Ischemic colitis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Irritable_bowel_syndrome"
    },
    "Maybe_Mimicker_Irritable_bowel_syndrome": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Irritable_bowel_syndrome",
          "distribution": 0.2
        },
        {
          "transition": "End_Wellness_Encounter",
          "distribution": 0.8
        }
      ]
    },
    "Diagnose_Mimicker_Irritable_bowel_syndrome": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "10743008",
          "display": "Irritable bowel syndrome"
        }
      ],
      "direct_transition": "End_Wellness_Encounter"
    }
  },
  "gmf_version": 2
}
