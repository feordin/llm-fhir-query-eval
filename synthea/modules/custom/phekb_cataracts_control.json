{
  "name": "PheKB Cataracts Control",
  "remarks": [
    "Control module for cataracts. Generates patients without cataracts."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 60,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "cat_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Disorder_of_refraction"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Disorder_of_refraction": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Disorder_of_refraction",
          "distribution": 0.4
        },
        {
          "transition": "Maybe_Mimicker_Presbyopia",
          "distribution": 0.6
        }
      ]
    },
    "Diagnose_Mimicker_Disorder_of_refraction": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "39021009",
          "display": "Disorder of refraction"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Presbyopia"
    },
    "Maybe_Mimicker_Presbyopia": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Presbyopia",
          "distribution": 0.3
        },
        {
          "transition": "Maybe_Mimicker_Open_angle_glaucoma",
          "distribution": 0.7
        }
      ]
    },
    "Diagnose_Mimicker_Presbyopia": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "41256004",
          "display": "Presbyopia"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Open_angle_glaucoma"
    },
    "Maybe_Mimicker_Open_angle_glaucoma": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Open_angle_glaucoma",
          "distribution": 0.1
        },
        {
          "transition": "Maybe_Mimicker_Age_related_macular_degeneration",
          "distribution": 0.9
        }
      ]
    },
    "Diagnose_Mimicker_Open_angle_glaucoma": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "84494001",
          "display": "Open-angle glaucoma"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Age_related_macular_degeneration"
    },
    "Maybe_Mimicker_Age_related_macular_degeneration": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Age_related_macular_degeneration",
          "distribution": 0.08
        },
        {
          "transition": "Maybe_Mimicker_Pterygium",
          "distribution": 0.92
        }
      ]
    },
    "Diagnose_Mimicker_Age_related_macular_degeneration": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "267718000",
          "display": "Age related macular degeneration"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Pterygium"
    },
    "Maybe_Mimicker_Pterygium": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Pterygium",
          "distribution": 0.03
        },
        {
          "transition": "End_Wellness_Encounter",
          "distribution": 0.97
        }
      ]
    },
    "Diagnose_Mimicker_Pterygium": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "77489003",
          "display": "Pterygium"
        }
      ],
      "direct_transition": "End_Wellness_Encounter"
    }
  },
  "gmf_version": 2
}
