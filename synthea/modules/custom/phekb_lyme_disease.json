{
  "name": "PheKB Lyme Disease",
  "remarks": [
    "Custom Synthea module for Lyme disease.",
    "First vector-borne/tick-borne infectious phenotype.",
    "",
    "Generates THREE patient paths:",
    "  Path A (60%): Lyme dx + doxycycline Rx",
    "  Path B (25%): Lyme dx, no antibiotic recorded (mild)",
    "  Path C (15%): Doxycycline without Lyme dx (TRICKY — many other indications: acne, RMSF, chlamydia, atypical pneumonia)",
    "",
    "Age guard: >=1."
  ],
  "states": {
    "Initial": { "type": "Initial", "direct_transition": "Age_Guard" },
    "Age_Guard": { "type": "Guard", "allow": { "condition_type": "Age", "operator": ">=", "quantity": 1, "unit": "years" }, "direct_transition": "Set_Lyme_Flag" },
    "Set_Lyme_Flag": { "type": "SetAttribute", "attribute": "lyme_positive", "value": true, "direct_transition": "Choose_Patient_Path" },
    "Choose_Patient_Path": {
      "type": "Simple",
      "distributed_transition": [
        { "transition": "Set_Path_A", "distribution": 0.60 },
        { "transition": "Set_Path_B", "distribution": 0.25 },
        { "transition": "Set_Path_C", "distribution": 0.15 }
      ]
    },
    "Set_Path_A": { "type": "SetAttribute", "attribute": "lyme_has_dx", "value": true, "direct_transition": "Set_Path_A_Med" },
    "Set_Path_A_Med": { "type": "SetAttribute", "attribute": "lyme_has_med", "value": true, "direct_transition": "Set_Needs_First_Visit" },
    "Set_Path_B": { "type": "SetAttribute", "attribute": "lyme_has_dx", "value": true, "direct_transition": "Set_Path_B_Med" },
    "Set_Path_B_Med": { "type": "SetAttribute", "attribute": "lyme_has_med", "value": false, "direct_transition": "Set_Needs_First_Visit" },
    "Set_Path_C": { "type": "SetAttribute", "remarks": ["TRICKY: doxycycline without Lyme dx"], "attribute": "lyme_has_dx", "value": false, "direct_transition": "Set_Path_C_Med" },
    "Set_Path_C_Med": { "type": "SetAttribute", "attribute": "lyme_has_med", "value": true, "direct_transition": "Set_Needs_First_Visit" },

    "Set_Needs_First_Visit": { "type": "SetAttribute", "attribute": "lyme_needs_first_visit", "value": true, "direct_transition": "Wellness_Encounter" },
    "Wellness_Encounter": { "type": "Encounter", "wellness": true, "direct_transition": "Check_First_Visit" },
    "Check_First_Visit": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "lyme_needs_first_visit", "operator": "==", "value": true }, "transition": "Check_Has_Diagnosis" },
        { "transition": "End_Wellness_Encounter" }
      ]
    },
    "Check_Has_Diagnosis": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "lyme_has_dx", "operator": "==", "value": true }, "transition": "Diagnose_Lyme" },
        { "transition": "Check_Med_NoDx" }
      ]
    },
    "Diagnose_Lyme": { "type": "ConditionOnset", "assign_to_attribute": "lyme_condition", "codes": [{ "system": "SNOMED-CT", "code": "23502006", "display": "Lyme disease" }], "direct_transition": "Check_Med_WithDx" },

    "Check_Med_WithDx": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "lyme_has_med", "operator": "==", "value": true }, "transition": "Prescribe_Doxycycline_WithDx" },
        { "transition": "Clear_First_Visit_Flag" }
      ]
    },
    "Prescribe_Doxycycline_WithDx": { "type": "MedicationOrder", "codes": [{ "system": "RxNorm", "code": "3640", "display": "doxycycline" }], "reason": "lyme_condition", "direct_transition": "Clear_First_Visit_Flag" },

    "Check_Med_NoDx": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "lyme_has_med", "operator": "==", "value": true }, "transition": "Prescribe_Doxycycline_NoDx" },
        { "transition": "Clear_First_Visit_Flag" }
      ]
    },
    "Prescribe_Doxycycline_NoDx": { "type": "MedicationOrder", "codes": [{ "system": "RxNorm", "code": "3640", "display": "doxycycline" }], "direct_transition": "Clear_First_Visit_Flag" },

    "Clear_First_Visit_Flag": { "type": "SetAttribute", "attribute": "lyme_needs_first_visit", "value": false, "direct_transition": "End_Wellness_Encounter" },
    "End_Wellness_Encounter": { "type": "EncounterEnd", "direct_transition": "Followup_Delay" },
    "Followup_Delay": { "type": "Delay", "range": { "low": 6, "high": 12, "unit": "months" }, "direct_transition": "Wellness_Encounter" }
  },
  "gmf_version": 2
}
