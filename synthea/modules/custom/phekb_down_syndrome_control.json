{
  "name": "PheKB Down Syndrome Control",
  "remarks": [
    "Control module for Down syndrome. Generates patients age 1+ without Down syndrome dx."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 1,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "ds_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Intellectual_disability"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Intellectual_disability": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Intellectual_disability",
          "distribution": 0.4
        },
        {
          "transition": "Maybe_Mimicker_Global_developmental_delay",
          "distribution": 0.6
        }
      ]
    },
    "Diagnose_Mimicker_Intellectual_disability": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "110359009",
          "display": "Intellectual disability"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Global_developmental_delay"
    },
    "Maybe_Mimicker_Global_developmental_delay": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Global_developmental_delay",
          "distribution": 0.25
        },
        {
          "transition": "Maybe_Mimicker_Congenital_heart_disease",
          "distribution": 0.75
        }
      ]
    },
    "Diagnose_Mimicker_Global_developmental_delay": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "224958001",
          "display": "Global developmental delay"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Congenital_heart_disease"
    },
    "Maybe_Mimicker_Congenital_heart_disease": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Congenital_heart_disease",
          "distribution": 0.15
        },
        {
          "transition": "Maybe_Mimicker_Decreased_muscle_tone",
          "distribution": 0.85
        }
      ]
    },
    "Diagnose_Mimicker_Congenital_heart_disease": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "13213009",
          "display": "Congenital heart disease"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Decreased_muscle_tone"
    },
    "Maybe_Mimicker_Decreased_muscle_tone": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Decreased_muscle_tone",
          "distribution": 0.2
        },
        {
          "transition": "Maybe_Mimicker_Hypothyroidism",
          "distribution": 0.8
        }
      ]
    },
    "Diagnose_Mimicker_Decreased_muscle_tone": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "398151007",
          "display": "Decreased muscle tone"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Hypothyroidism"
    },
    "Maybe_Mimicker_Hypothyroidism": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Hypothyroidism",
          "distribution": 0.1
        },
        {
          "transition": "End_Wellness_Encounter",
          "distribution": 0.9
        }
      ]
    },
    "Diagnose_Mimicker_Hypothyroidism": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "40930008",
          "display": "Hypothyroidism"
        }
      ],
      "direct_transition": "End_Wellness_Encounter"
    }
  },
  "gmf_version": 2
}
