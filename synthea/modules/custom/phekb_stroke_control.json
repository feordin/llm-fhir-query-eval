{
  "name": "PheKB Stroke Control",
  "remarks": [
    "Control module for stroke. Generates patients age 50+ without stroke dx, alteplase, or antiplatelet meds."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 50,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "stroke_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Transient_ischemic_attack"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Transient_ischemic_attack": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Transient_ischemic_attack",
          "distribution": 0.15
        },
        {
          "transition": "Maybe_Mimicker_Migraine_with_aura",
          "distribution": 0.85
        }
      ]
    },
    "Diagnose_Mimicker_Transient_ischemic_attack": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "266257000",
          "display": "Transient cerebral ischemia"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Migraine_with_aura"
    },
    "Maybe_Mimicker_Migraine_with_aura": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Migraine_with_aura",
          "distribution": 0.1
        },
        {
          "transition": "Maybe_Mimicker_Bell_palsy",
          "distribution": 0.9
        }
      ]
    },
    "Diagnose_Mimicker_Migraine_with_aura": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "4473006",
          "display": "Migraine with aura"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Bell_palsy"
    },
    "Maybe_Mimicker_Bell_palsy": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Bell_palsy",
          "distribution": 0.02
        },
        {
          "transition": "Maybe_Mimicker_Hypoglycemia",
          "distribution": 0.98
        }
      ]
    },
    "Diagnose_Mimicker_Bell_palsy": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "193093009",
          "display": "Bell's palsy"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Hypoglycemia"
    },
    "Maybe_Mimicker_Hypoglycemia": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Hypoglycemia",
          "distribution": 0.05
        },
        {
          "transition": "Maybe_Mimicker_Seizure_disorder",
          "distribution": 0.95
        }
      ]
    },
    "Diagnose_Mimicker_Hypoglycemia": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "302866003",
          "display": "Hypoglycemia"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Seizure_disorder"
    },
    "Maybe_Mimicker_Seizure_disorder": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Seizure_disorder",
          "distribution": 0.05
        },
        {
          "transition": "End_Wellness_Encounter",
          "distribution": 0.95
        }
      ]
    },
    "Diagnose_Mimicker_Seizure_disorder": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "84757009",
          "display": "Epilepsy"
        }
      ],
      "direct_transition": "End_Wellness_Encounter"
    }
  },
  "gmf_version": 2
}
