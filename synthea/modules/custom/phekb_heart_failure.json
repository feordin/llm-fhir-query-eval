{
  "name": "PheKB Heart Failure",
  "remarks": [
    "Custom Synthea module for PheKB phenotype: heart failure",
    "Based on Mayo Clinic eMERGE HF algorithm (V03042014)",
    "",
    "PheKB algorithm: case requires ICD-9 428.X + positive HF mention in problem list,",
    "  with classification by ejection fraction: HFrEF if EF<50%, HFpEF if EF>=50%.",
    "",
    "Generates FOUR patient paths:",
    "  Path A (35%): Diagnosis + GDMT meds + reduced EF on echo — full HFrEF presentation",
    "  Path B (15%): Diagnosis + meds, no echo recorded",
    "  Path C (30%): GDMT meds ONLY, NO diagnosis (tricky — diuretics for HTN, beta blockers for arrhythmia, undiagnosed HF)",
    "  Path D (20%): Reduced EF on echo ONLY, NO diagnosis, NO meds (tricky — incidental echo finding, asymptomatic LV dysfunction)",
    "",
    "Diagnosis SNOMED code variation (only Paths A + B get a Condition):",
    "  25% Heart failure (84114007) — generic parent",
    "  20% Congestive heart failure (42343007) — most common general",
    "  15% Chronic congestive heart failure (88805009)",
    "  25% Heart failure with reduced ejection fraction (703272007) — HFrEF specific",
    "  15% Heart failure with normal ejection fraction (446221000) — HFpEF specific",
    "",
    "Medication ingredient variation (Paths A, B, C — anyone on meds):",
    "  30% Furosemide (4603) — loop diuretic, congestion management",
    "  20% Carvedilol (20352) — beta blocker GDMT",
    "  15% Spironolactone (9997) — MRA",
    "  20% Sacubitril/valsartan (1656339) — ARNi",
    "  15% Empagliflozin (1545653) — SGLT2 inhibitor",
    "",
    "Lab values (Path A and Path D get low EF):",
    "  EF case range: 15 - 45 % (HFrEF, below threshold of 50)",
    "",
    "Codes verified via NIH UMLS MCP and VSAC OID 2.16.840.1.113762.1.4.1219.23 (CMS DRLS Steward)."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },

    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 50,
        "unit": "years"
      },
      "direct_transition": "Set_HF_Flag"
    },

    "Set_HF_Flag": {
      "type": "SetAttribute",
      "attribute": "hf_positive",
      "value": true,
      "direct_transition": "Choose_Patient_Path"
    },

    "Choose_Patient_Path": {
      "type": "Simple",
      "remarks": [
        "Four-way split:",
        "  Path A (35%): Dx + meds + low EF (full HFrEF presentation)",
        "  Path B (15%): Dx + meds, no echo",
        "  Path C (30%): Meds only, NO dx (tricky)",
        "  Path D (20%): Low EF only, NO dx, NO meds (tricky — asymptomatic LV dysfunction)"
      ],
      "distributed_transition": [
        { "transition": "Set_Path_A", "distribution": 0.35 },
        { "transition": "Set_Path_B", "distribution": 0.15 },
        { "transition": "Set_Path_C", "distribution": 0.30 },
        { "transition": "Set_Path_D", "distribution": 0.20 }
      ]
    },

    "Set_Path_A": {
      "type": "SetAttribute",
      "attribute": "hf_has_dx",
      "value": true,
      "direct_transition": "Set_Path_A_Labs"
    },
    "Set_Path_A_Labs": {
      "type": "SetAttribute",
      "attribute": "hf_has_labs",
      "value": true,
      "direct_transition": "Set_Path_A_Meds"
    },
    "Set_Path_A_Meds": {
      "type": "SetAttribute",
      "attribute": "hf_has_meds",
      "value": true,
      "direct_transition": "Choose_Subtype"
    },

    "Set_Path_B": {
      "type": "SetAttribute",
      "attribute": "hf_has_dx",
      "value": true,
      "direct_transition": "Set_Path_B_Labs"
    },
    "Set_Path_B_Labs": {
      "type": "SetAttribute",
      "attribute": "hf_has_labs",
      "value": false,
      "direct_transition": "Set_Path_B_Meds"
    },
    "Set_Path_B_Meds": {
      "type": "SetAttribute",
      "attribute": "hf_has_meds",
      "value": true,
      "direct_transition": "Choose_Subtype"
    },

    "Set_Path_C": {
      "type": "SetAttribute",
      "remarks": ["TRICKY: HF meds only, no diagnosis code"],
      "attribute": "hf_has_dx",
      "value": false,
      "direct_transition": "Set_Path_C_Labs"
    },
    "Set_Path_C_Labs": {
      "type": "SetAttribute",
      "attribute": "hf_has_labs",
      "value": false,
      "direct_transition": "Set_Path_C_Meds"
    },
    "Set_Path_C_Meds": {
      "type": "SetAttribute",
      "attribute": "hf_has_meds",
      "value": true,
      "direct_transition": "Choose_Subtype"
    },

    "Set_Path_D": {
      "type": "SetAttribute",
      "remarks": ["TRICKY: Low EF only, no diagnosis, no treatment"],
      "attribute": "hf_has_dx",
      "value": false,
      "direct_transition": "Set_Path_D_Labs"
    },
    "Set_Path_D_Labs": {
      "type": "SetAttribute",
      "attribute": "hf_has_labs",
      "value": true,
      "direct_transition": "Set_Path_D_Meds"
    },
    "Set_Path_D_Meds": {
      "type": "SetAttribute",
      "attribute": "hf_has_meds",
      "value": false,
      "direct_transition": "Choose_Subtype"
    },

    "Choose_Subtype": {
      "type": "Simple",
      "remarks": [
        "Distribute across HF SNOMED subtypes (only matters for Paths A + B with dx):",
        "  25% Heart failure (parent)",
        "  20% Congestive heart failure",
        "  15% Chronic congestive heart failure",
        "  25% Heart failure with reduced ejection fraction (HFrEF)",
        "  15% Heart failure with normal ejection fraction (HFpEF)"
      ],
      "distributed_transition": [
        { "transition": "Set_Subtype_HF", "distribution": 0.25 },
        { "transition": "Set_Subtype_CHF", "distribution": 0.20 },
        { "transition": "Set_Subtype_ChronicCHF", "distribution": 0.15 },
        { "transition": "Set_Subtype_HFrEF", "distribution": 0.25 },
        { "transition": "Set_Subtype_HFpEF", "distribution": 0.15 }
      ]
    },

    "Set_Subtype_HF": { "type": "SetAttribute", "attribute": "hf_subtype", "value": "hf", "direct_transition": "Choose_Med" },
    "Set_Subtype_CHF": { "type": "SetAttribute", "attribute": "hf_subtype", "value": "chf", "direct_transition": "Choose_Med" },
    "Set_Subtype_ChronicCHF": { "type": "SetAttribute", "attribute": "hf_subtype", "value": "chronic_chf", "direct_transition": "Choose_Med" },
    "Set_Subtype_HFrEF": { "type": "SetAttribute", "attribute": "hf_subtype", "value": "hfref", "direct_transition": "Choose_Med" },
    "Set_Subtype_HFpEF": { "type": "SetAttribute", "attribute": "hf_subtype", "value": "hfpef", "direct_transition": "Choose_Med" },

    "Choose_Med": {
      "type": "Simple",
      "remarks": [
        "Distribute across HF medication ingredient codes:",
        "  30% Furosemide",
        "  20% Carvedilol",
        "  15% Spironolactone",
        "  20% Sacubitril/valsartan",
        "  15% Empagliflozin"
      ],
      "distributed_transition": [
        { "transition": "Set_Med_Furosemide", "distribution": 0.30 },
        { "transition": "Set_Med_Carvedilol", "distribution": 0.20 },
        { "transition": "Set_Med_Spironolactone", "distribution": 0.15 },
        { "transition": "Set_Med_SacVal", "distribution": 0.20 },
        { "transition": "Set_Med_Empagliflozin", "distribution": 0.15 }
      ]
    },

    "Set_Med_Furosemide": { "type": "SetAttribute", "attribute": "hf_med", "value": "furosemide", "direct_transition": "Set_Needs_First_Visit" },
    "Set_Med_Carvedilol": { "type": "SetAttribute", "attribute": "hf_med", "value": "carvedilol", "direct_transition": "Set_Needs_First_Visit" },
    "Set_Med_Spironolactone": { "type": "SetAttribute", "attribute": "hf_med", "value": "spironolactone", "direct_transition": "Set_Needs_First_Visit" },
    "Set_Med_SacVal": { "type": "SetAttribute", "attribute": "hf_med", "value": "sacval", "direct_transition": "Set_Needs_First_Visit" },
    "Set_Med_Empagliflozin": { "type": "SetAttribute", "attribute": "hf_med", "value": "empagliflozin", "direct_transition": "Set_Needs_First_Visit" },

    "Set_Needs_First_Visit": {
      "type": "SetAttribute",
      "attribute": "hf_needs_first_visit",
      "value": true,
      "direct_transition": "Wellness_Encounter"
    },

    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Check_First_Visit"
    },

    "Check_First_Visit": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "hf_needs_first_visit", "operator": "==", "value": true }, "transition": "Check_Has_Diagnosis" },
        { "transition": "End_Wellness_Encounter" }
      ]
    },

    "Check_Has_Diagnosis": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "hf_has_dx", "operator": "==", "value": true }, "transition": "Route_By_Subtype" },
        { "transition": "Check_Labs_NoDx" }
      ]
    },

    "Route_By_Subtype": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "hf_subtype", "operator": "==", "value": "hf" }, "transition": "Diagnose_HF" },
        { "condition": { "condition_type": "Attribute", "attribute": "hf_subtype", "operator": "==", "value": "chf" }, "transition": "Diagnose_CHF" },
        { "condition": { "condition_type": "Attribute", "attribute": "hf_subtype", "operator": "==", "value": "chronic_chf" }, "transition": "Diagnose_ChronicCHF" },
        { "condition": { "condition_type": "Attribute", "attribute": "hf_subtype", "operator": "==", "value": "hfref" }, "transition": "Diagnose_HFrEF" },
        { "transition": "Diagnose_HFpEF" }
      ]
    },

    "Diagnose_HF": {
      "type": "ConditionOnset",
      "assign_to_attribute": "hf_condition",
      "codes": [{ "system": "SNOMED-CT", "code": "84114007", "display": "Heart failure" }],
      "direct_transition": "Check_Labs_WithDx"
    },
    "Diagnose_CHF": {
      "type": "ConditionOnset",
      "assign_to_attribute": "hf_condition",
      "codes": [{ "system": "SNOMED-CT", "code": "42343007", "display": "Congestive heart failure" }],
      "direct_transition": "Check_Labs_WithDx"
    },
    "Diagnose_ChronicCHF": {
      "type": "ConditionOnset",
      "assign_to_attribute": "hf_condition",
      "codes": [{ "system": "SNOMED-CT", "code": "88805009", "display": "Chronic congestive heart failure" }],
      "direct_transition": "Check_Labs_WithDx"
    },
    "Diagnose_HFrEF": {
      "type": "ConditionOnset",
      "assign_to_attribute": "hf_condition",
      "codes": [{ "system": "SNOMED-CT", "code": "703272007", "display": "Heart failure with reduced ejection fraction" }],
      "direct_transition": "Check_Labs_WithDx"
    },
    "Diagnose_HFpEF": {
      "type": "ConditionOnset",
      "assign_to_attribute": "hf_condition",
      "codes": [{ "system": "SNOMED-CT", "code": "446221000", "display": "Heart failure with normal ejection fraction" }],
      "direct_transition": "Check_Labs_WithDx"
    },

    "Check_Labs_WithDx": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "hf_has_labs", "operator": "==", "value": true }, "transition": "Record_Low_EF_WithDx" },
        { "transition": "Check_Meds_WithDx" }
      ]
    },

    "Record_Low_EF_WithDx": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "%",
      "codes": [{ "system": "LOINC", "code": "8806-2", "display": "Left ventricular Ejection fraction by 2D echo" }],
      "range": { "low": 15, "high": 45 },
      "direct_transition": "Check_Meds_WithDx"
    },

    "Check_Meds_WithDx": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "hf_has_meds", "operator": "==", "value": true }, "transition": "Route_Med_WithDx" },
        { "transition": "Clear_First_Visit_Flag" }
      ]
    },

    "Route_Med_WithDx": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "hf_med", "operator": "==", "value": "furosemide" }, "transition": "Prescribe_Furosemide_WithDx" },
        { "condition": { "condition_type": "Attribute", "attribute": "hf_med", "operator": "==", "value": "carvedilol" }, "transition": "Prescribe_Carvedilol_WithDx" },
        { "condition": { "condition_type": "Attribute", "attribute": "hf_med", "operator": "==", "value": "spironolactone" }, "transition": "Prescribe_Spironolactone_WithDx" },
        { "condition": { "condition_type": "Attribute", "attribute": "hf_med", "operator": "==", "value": "sacval" }, "transition": "Prescribe_SacVal_WithDx" },
        { "transition": "Prescribe_Empagliflozin_WithDx" }
      ]
    },

    "Prescribe_Furosemide_WithDx": {
      "type": "MedicationOrder",
      "codes": [{ "system": "RxNorm", "code": "4603", "display": "furosemide" }],
      "reason": "hf_condition",
      "direct_transition": "Clear_First_Visit_Flag"
    },
    "Prescribe_Carvedilol_WithDx": {
      "type": "MedicationOrder",
      "codes": [{ "system": "RxNorm", "code": "20352", "display": "carvedilol" }],
      "reason": "hf_condition",
      "direct_transition": "Clear_First_Visit_Flag"
    },
    "Prescribe_Spironolactone_WithDx": {
      "type": "MedicationOrder",
      "codes": [{ "system": "RxNorm", "code": "9997", "display": "spironolactone" }],
      "reason": "hf_condition",
      "direct_transition": "Clear_First_Visit_Flag"
    },
    "Prescribe_SacVal_WithDx": {
      "type": "MedicationOrder",
      "codes": [{ "system": "RxNorm", "code": "1656339", "display": "sacubitril / valsartan" }],
      "reason": "hf_condition",
      "direct_transition": "Clear_First_Visit_Flag"
    },
    "Prescribe_Empagliflozin_WithDx": {
      "type": "MedicationOrder",
      "codes": [{ "system": "RxNorm", "code": "1545653", "display": "empagliflozin" }],
      "reason": "hf_condition",
      "direct_transition": "Clear_First_Visit_Flag"
    },

    "Check_Labs_NoDx": {
      "type": "Simple",
      "remarks": ["For Path C and Path D — no diagnosis branch"],
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "hf_has_labs", "operator": "==", "value": true }, "transition": "Record_Low_EF_NoDx" },
        { "transition": "Check_Meds_NoDx" }
      ]
    },

    "Record_Low_EF_NoDx": {
      "type": "Observation",
      "remarks": ["Path D: low EF but no Condition resource for HF"],
      "category": "laboratory",
      "unit": "%",
      "codes": [{ "system": "LOINC", "code": "8806-2", "display": "Left ventricular Ejection fraction by 2D echo" }],
      "range": { "low": 25, "high": 48 },
      "direct_transition": "Check_Meds_NoDx"
    },

    "Check_Meds_NoDx": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "hf_has_meds", "operator": "==", "value": true }, "transition": "Route_Med_NoDx" },
        { "transition": "Clear_First_Visit_Flag" }
      ]
    },

    "Route_Med_NoDx": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "hf_med", "operator": "==", "value": "furosemide" }, "transition": "Prescribe_Furosemide_NoDx" },
        { "condition": { "condition_type": "Attribute", "attribute": "hf_med", "operator": "==", "value": "carvedilol" }, "transition": "Prescribe_Carvedilol_NoDx" },
        { "condition": { "condition_type": "Attribute", "attribute": "hf_med", "operator": "==", "value": "spironolactone" }, "transition": "Prescribe_Spironolactone_NoDx" },
        { "condition": { "condition_type": "Attribute", "attribute": "hf_med", "operator": "==", "value": "sacval" }, "transition": "Prescribe_SacVal_NoDx" },
        { "transition": "Prescribe_Empagliflozin_NoDx" }
      ]
    },

    "Prescribe_Furosemide_NoDx": {
      "type": "MedicationOrder",
      "codes": [{ "system": "RxNorm", "code": "4603", "display": "furosemide" }],
      "direct_transition": "Clear_First_Visit_Flag"
    },
    "Prescribe_Carvedilol_NoDx": {
      "type": "MedicationOrder",
      "codes": [{ "system": "RxNorm", "code": "20352", "display": "carvedilol" }],
      "direct_transition": "Clear_First_Visit_Flag"
    },
    "Prescribe_Spironolactone_NoDx": {
      "type": "MedicationOrder",
      "codes": [{ "system": "RxNorm", "code": "9997", "display": "spironolactone" }],
      "direct_transition": "Clear_First_Visit_Flag"
    },
    "Prescribe_SacVal_NoDx": {
      "type": "MedicationOrder",
      "codes": [{ "system": "RxNorm", "code": "1656339", "display": "sacubitril / valsartan" }],
      "direct_transition": "Clear_First_Visit_Flag"
    },
    "Prescribe_Empagliflozin_NoDx": {
      "type": "MedicationOrder",
      "codes": [{ "system": "RxNorm", "code": "1545653", "display": "empagliflozin" }],
      "direct_transition": "Clear_First_Visit_Flag"
    },

    "Clear_First_Visit_Flag": {
      "type": "SetAttribute",
      "attribute": "hf_needs_first_visit",
      "value": false,
      "direct_transition": "End_Wellness_Encounter"
    },

    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },

    "Followup_Delay": {
      "type": "Delay",
      "range": { "low": 3, "high": 6, "unit": "months" },
      "direct_transition": "Wellness_Encounter"
    }
  },
  "gmf_version": 2
}
