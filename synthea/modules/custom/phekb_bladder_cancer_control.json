{
  "name": "PheKB Bladder Cancer Control",
  "remarks": [
    "Control module for bladder cancer. Generates patients age 50+ without bladder cancer dx."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 50,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "bladder_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Recurrent_urinary_tract_infection"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Recurrent_urinary_tract_infection": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Recurrent_urinary_tract_infection",
          "distribution": 0.2
        },
        {
          "transition": "Maybe_Mimicker_Benign_neoplasm_of_urinary_bladder",
          "distribution": 0.8
        }
      ]
    },
    "Diagnose_Mimicker_Recurrent_urinary_tract_infection": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "197927001",
          "display": "Recurrent urinary tract infection"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Benign_neoplasm_of_urinary_bladder"
    },
    "Maybe_Mimicker_Benign_neoplasm_of_urinary_bladder": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Benign_neoplasm_of_urinary_bladder",
          "distribution": 0.05
        },
        {
          "transition": "Maybe_Mimicker_Malignant_neoplasm_of_prostate",
          "distribution": 0.95
        }
      ]
    },
    "Diagnose_Mimicker_Benign_neoplasm_of_urinary_bladder": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "91992005",
          "display": "Benign neoplasm of urinary bladder"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Malignant_neoplasm_of_prostate"
    },
    "Maybe_Mimicker_Malignant_neoplasm_of_prostate": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Malignant_neoplasm_of_prostate",
          "distribution": 0.08
        },
        {
          "transition": "Maybe_Mimicker_Renal_cell_carcinoma",
          "distribution": 0.92
        }
      ]
    },
    "Diagnose_Mimicker_Malignant_neoplasm_of_prostate": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "399068003",
          "display": "Malignant neoplasm of prostate"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Renal_cell_carcinoma"
    },
    "Maybe_Mimicker_Renal_cell_carcinoma": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Renal_cell_carcinoma",
          "distribution": 0.03
        },
        {
          "transition": "Maybe_Mimicker_Ulcerative_cystitis",
          "distribution": 0.97
        }
      ]
    },
    "Diagnose_Mimicker_Renal_cell_carcinoma": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "702391001",
          "display": "Renal cell carcinoma"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Ulcerative_cystitis"
    },
    "Maybe_Mimicker_Ulcerative_cystitis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Ulcerative_cystitis",
          "distribution": 0.04
        },
        {
          "transition": "End_Wellness_Encounter",
          "distribution": 0.96
        }
      ]
    },
    "Diagnose_Mimicker_Ulcerative_cystitis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "111409009",
          "display": "Ulcerative cystitis"
        }
      ],
      "direct_transition": "End_Wellness_Encounter"
    }
  },
  "gmf_version": 2
}
