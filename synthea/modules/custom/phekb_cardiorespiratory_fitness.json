{
  "name": "PheKB Cardiorespiratory Fitness (PheKB-aligned eMERGE Mayo)",
  "remarks": [
    "Custom Synthea module for cardiorespiratory fitness phenotype.",
    "Aligned to PheKB eMERGE Mayo Network algorithm: cardiac exercise stress test (NOT pharmacologic).",
    "",
    "Generates SINGLE-PATH module: cardiac stress test procedure (CPT 93015 → SNOMED 76746007).",
    "PheKB algorithm excludes pharmacologic stress (adenosine, dipyridamole, dobutamine) — we model only exercise stress.",
    "",
    "Age guard: >=18."
  ],
  "states": {
    "Initial": { "type": "Initial", "direct_transition": "Age_Guard" },
    "Age_Guard": { "type": "Guard", "allow": { "condition_type": "Age", "operator": ">=", "quantity": 18, "unit": "years" }, "direct_transition": "Set_Crf_Flag" },
    "Set_Crf_Flag": { "type": "SetAttribute", "attribute": "crf_positive", "value": true, "direct_transition": "Set_Needs_First_Visit" },
    "Set_Needs_First_Visit": { "type": "SetAttribute", "attribute": "crf_needs_first_visit", "value": true, "direct_transition": "Wellness_Encounter" },
    "Wellness_Encounter": { "type": "Encounter", "wellness": true, "direct_transition": "Check_First_Visit" },
    "Check_First_Visit": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "crf_needs_first_visit", "operator": "==", "value": true }, "transition": "Stress_Test_Procedure" },
        { "transition": "End_Wellness_Encounter" }
      ]
    },
    "Stress_Test_Procedure": { "type": "Procedure", "codes": [{ "system": "SNOMED-CT", "code": "76746007", "display": "Cardiovascular stress testing" }], "duration": { "low": 30, "high": 60, "unit": "minutes" }, "direct_transition": "Clear_First_Visit_Flag" },
    "Clear_First_Visit_Flag": { "type": "SetAttribute", "attribute": "crf_needs_first_visit", "value": false, "direct_transition": "End_Wellness_Encounter" },
    "End_Wellness_Encounter": { "type": "EncounterEnd", "direct_transition": "Followup_Delay" },
    "Followup_Delay": { "type": "Delay", "range": { "low": 12, "high": 36, "unit": "months" }, "direct_transition": "Wellness_Encounter" }
  },
  "gmf_version": 2
}
