{
  "name": "PheKB Cystic Fibrosis Control",
  "remarks": [
    "Control module for cystic fibrosis. Generates patients age 1+ without CF dx."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 1,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "cf_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Asthma"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Asthma": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Asthma",
          "distribution": 0.2
        },
        {
          "transition": "Maybe_Mimicker_Bronchiectasis",
          "distribution": 0.8
        }
      ]
    },
    "Diagnose_Mimicker_Asthma": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "195967001",
          "display": "Asthma"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Bronchiectasis"
    },
    "Maybe_Mimicker_Bronchiectasis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Bronchiectasis",
          "distribution": 0.08
        },
        {
          "transition": "Maybe_Mimicker_Recurrent_pneumonia",
          "distribution": 0.92
        }
      ]
    },
    "Diagnose_Mimicker_Bronchiectasis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "12295008",
          "display": "Bronchiectasis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Recurrent_pneumonia"
    },
    "Maybe_Mimicker_Recurrent_pneumonia": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Recurrent_pneumonia",
          "distribution": 0.1
        },
        {
          "transition": "Maybe_Mimicker_Immotile_cilia_syndrome",
          "distribution": 0.9
        }
      ]
    },
    "Diagnose_Mimicker_Recurrent_pneumonia": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "699014000",
          "display": "Recurrent pneumonia"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Immotile_cilia_syndrome"
    },
    "Maybe_Mimicker_Immotile_cilia_syndrome": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Immotile_cilia_syndrome",
          "distribution": 0.02
        },
        {
          "transition": "Maybe_Mimicker_Exocrine_pancreatic_insufficiency",
          "distribution": 0.98
        }
      ]
    },
    "Diagnose_Mimicker_Immotile_cilia_syndrome": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "86204009",
          "display": "Immotile cilia syndrome"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Exocrine_pancreatic_insufficiency"
    },
    "Maybe_Mimicker_Exocrine_pancreatic_insufficiency": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Exocrine_pancreatic_insufficiency",
          "distribution": 0.05
        },
        {
          "transition": "End_Wellness_Encounter",
          "distribution": 0.95
        }
      ]
    },
    "Diagnose_Mimicker_Exocrine_pancreatic_insufficiency": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "47367009",
          "display": "Exocrine pancreatic insufficiency"
        }
      ],
      "direct_transition": "End_Wellness_Encounter"
    }
  },
  "gmf_version": 2
}
