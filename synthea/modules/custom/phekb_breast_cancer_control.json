{
  "name": "PheKB Breast Cancer Control",
  "remarks": [
    "Control module for PheKB breast cancer phenotype.",
    "Generates patients who do NOT have breast cancer.",
    "",
    "Controls per Mayo PheKB algorithm must:",
    "  - Be age >= 18",
    "  - Have no breast cancer diagnosis or history codes",
    "  - Have no endocrine therapy or HER2-directed therapy",
    "",
    "Controls get NO Condition resources for breast cancer and NO endocrine/HER2 therapy."
  ],
  "states": {
    "Initial": { "type": "Initial", "direct_transition": "Age_Guard" },

    "Age_Guard": {
      "type": "Guard",
      "allow": { "condition_type": "Age", "operator": ">=", "quantity": 40, "unit": "years" },
      "direct_transition": "Set_Control_Flag"
    },

    "Set_Control_Flag": { "type": "SetAttribute", "attribute": "bc_positive", "value": false, "direct_transition": "Wellness_Encounter" },

    "Wellness_Encounter": { "type": "Encounter", "wellness": true, "direct_transition": "End_Wellness_Encounter" },

    "End_Wellness_Encounter": { "type": "EncounterEnd", "direct_transition": "Followup_Delay" },

    "Followup_Delay": {
      "type": "Delay",
      "range": { "low": 12, "high": 24, "unit": "months" },
      "direct_transition": "Wellness_Encounter"
    }
  },
  "gmf_version": 2
}
