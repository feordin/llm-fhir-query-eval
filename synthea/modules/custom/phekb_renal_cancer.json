{
  "name": "PheKB Renal Cell Carcinoma",
  "remarks": [
    "Custom Synthea module for renal cell carcinoma (RCC).",
    "12th cancer phenotype, third urological cancer (after PCa, Bladder).",
    "Single-path: 100% have RCC dx. Uses 'Clear cell carcinoma of kidney' (most common RCC subtype). Age guard: >=50."
  ],
  "states": {
    "Initial": { "type": "Initial", "direct_transition": "Age_Guard" },
    "Age_Guard": { "type": "Guard", "allow": { "condition_type": "Age", "operator": ">=", "quantity": 50, "unit": "years" }, "direct_transition": "Set_RCC_Flag" },
    "Set_RCC_Flag": { "type": "SetAttribute", "attribute": "rcc_positive", "value": true, "direct_transition": "Set_Needs_First_Visit" },
    "Set_Needs_First_Visit": { "type": "SetAttribute", "attribute": "rcc_needs_first_visit", "value": true, "direct_transition": "Wellness_Encounter" },
    "Wellness_Encounter": { "type": "Encounter", "wellness": true, "direct_transition": "Check_First_Visit" },
    "Check_First_Visit": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "rcc_needs_first_visit", "operator": "==", "value": true }, "transition": "Diagnose_RCC" },
        { "transition": "End_Wellness_Encounter" }
      ]
    },
    "Diagnose_RCC": { "type": "ConditionOnset", "assign_to_attribute": "rcc_condition", "codes": [{ "system": "SNOMED-CT", "code": "254915003", "display": "Clear cell carcinoma of kidney" }], "direct_transition": "Clear_First_Visit_Flag" },
    "Clear_First_Visit_Flag": { "type": "SetAttribute", "attribute": "rcc_needs_first_visit", "value": false, "direct_transition": "End_Wellness_Encounter" },
    "End_Wellness_Encounter": { "type": "EncounterEnd", "direct_transition": "Followup_Delay" },
    "Followup_Delay": { "type": "Delay", "range": { "low": 6, "high": 12, "unit": "months" }, "direct_transition": "Wellness_Encounter" }
  },
  "gmf_version": 2
}
