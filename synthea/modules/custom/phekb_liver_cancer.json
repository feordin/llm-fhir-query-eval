{
  "name": "PheKB Liver Cancer (HCC)",
  "remarks": [
    "Custom Synthea module for hepatocellular carcinoma (HCC).",
    "Fifth cancer phenotype (after breast, CRC, prostate, ovarian). Second GI cancer. First liver malignancy.",
    "",
    "Generates THREE patient paths:",
    "  Path A (60%): HCC dx + elevated AFP",
    "  Path B (25%): HCC dx, no AFP measured (early-stage or AFP-negative variant)",
    "  Path D (15%): Elevated AFP without formal HCC dx (rare — undiagnosed/incident finding)",
    "",
    "Diagnosis SNOMED variation (Paths A + B):",
    "  60% Primary carcinoma of liver (187769009)",
    "  25% Malignant neoplasm of liver (93870000) — broader",
    "  15% Metastatic malignant neoplasm to liver (94381002) — advanced/metastatic",
    "",
    "AFP elevation (Paths A + D): range 100-2000 ng/mL (HCC-suggestive when >200, diagnostic when >400)"
  ],
  "states": {
    "Initial": { "type": "Initial", "direct_transition": "Age_Guard" },
    "Age_Guard": { "type": "Guard", "allow": { "condition_type": "Age", "operator": ">=", "quantity": 40, "unit": "years" }, "direct_transition": "Set_HCC_Flag" },
    "Set_HCC_Flag": { "type": "SetAttribute", "attribute": "hcc_positive", "value": true, "direct_transition": "Choose_Patient_Path" },
    "Choose_Patient_Path": {
      "type": "Simple",
      "distributed_transition": [
        { "transition": "Set_Path_A", "distribution": 0.60 },
        { "transition": "Set_Path_B", "distribution": 0.25 },
        { "transition": "Set_Path_D", "distribution": 0.15 }
      ]
    },
    "Set_Path_A": { "type": "SetAttribute", "attribute": "hcc_has_dx", "value": true, "direct_transition": "Set_Path_A_Lab" },
    "Set_Path_A_Lab": { "type": "SetAttribute", "attribute": "hcc_has_afp", "value": true, "direct_transition": "Choose_Subtype" },
    "Set_Path_B": { "type": "SetAttribute", "attribute": "hcc_has_dx", "value": true, "direct_transition": "Set_Path_B_Lab" },
    "Set_Path_B_Lab": { "type": "SetAttribute", "attribute": "hcc_has_afp", "value": false, "direct_transition": "Choose_Subtype" },
    "Set_Path_D": { "type": "SetAttribute", "remarks": ["TRICKY: elevated AFP without HCC dx"], "attribute": "hcc_has_dx", "value": false, "direct_transition": "Set_Path_D_Lab" },
    "Set_Path_D_Lab": { "type": "SetAttribute", "attribute": "hcc_has_afp", "value": true, "direct_transition": "Choose_Subtype" },

    "Choose_Subtype": {
      "type": "Simple",
      "distributed_transition": [
        { "transition": "Set_Subtype_Primary", "distribution": 0.60 },
        { "transition": "Set_Subtype_Liver_Malig", "distribution": 0.25 },
        { "transition": "Set_Subtype_Metastatic", "distribution": 0.15 }
      ]
    },
    "Set_Subtype_Primary": { "type": "SetAttribute", "attribute": "hcc_subtype", "value": "primary", "direct_transition": "Set_Needs_First_Visit" },
    "Set_Subtype_Liver_Malig": { "type": "SetAttribute", "attribute": "hcc_subtype", "value": "liver_malig", "direct_transition": "Set_Needs_First_Visit" },
    "Set_Subtype_Metastatic": { "type": "SetAttribute", "attribute": "hcc_subtype", "value": "metastatic", "direct_transition": "Set_Needs_First_Visit" },

    "Set_Needs_First_Visit": { "type": "SetAttribute", "attribute": "hcc_needs_first_visit", "value": true, "direct_transition": "Wellness_Encounter" },
    "Wellness_Encounter": { "type": "Encounter", "wellness": true, "direct_transition": "Check_First_Visit" },
    "Check_First_Visit": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "hcc_needs_first_visit", "operator": "==", "value": true }, "transition": "Check_Has_Diagnosis" },
        { "transition": "End_Wellness_Encounter" }
      ]
    },
    "Check_Has_Diagnosis": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "hcc_has_dx", "operator": "==", "value": true }, "transition": "Route_By_Subtype" },
        { "transition": "Check_AFP_NoDx" }
      ]
    },
    "Route_By_Subtype": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "hcc_subtype", "operator": "==", "value": "primary" }, "transition": "Diagnose_Primary" },
        { "condition": { "condition_type": "Attribute", "attribute": "hcc_subtype", "operator": "==", "value": "liver_malig" }, "transition": "Diagnose_Liver_Malig" },
        { "transition": "Diagnose_Metastatic" }
      ]
    },
    "Diagnose_Primary": { "type": "ConditionOnset", "assign_to_attribute": "hcc_condition", "codes": [{ "system": "SNOMED-CT", "code": "187769009", "display": "Primary carcinoma of liver" }], "direct_transition": "Check_AFP_WithDx" },
    "Diagnose_Liver_Malig": { "type": "ConditionOnset", "assign_to_attribute": "hcc_condition", "codes": [{ "system": "SNOMED-CT", "code": "93870000", "display": "Malignant neoplasm of liver" }], "direct_transition": "Check_AFP_WithDx" },
    "Diagnose_Metastatic": { "type": "ConditionOnset", "assign_to_attribute": "hcc_condition", "codes": [{ "system": "SNOMED-CT", "code": "94381002", "display": "Metastatic malignant neoplasm to liver" }], "direct_transition": "Check_AFP_WithDx" },

    "Check_AFP_WithDx": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "hcc_has_afp", "operator": "==", "value": true }, "transition": "Record_AFP_WithDx" },
        { "transition": "Clear_First_Visit_Flag" }
      ]
    },
    "Record_AFP_WithDx": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "ng/mL",
      "codes": [{ "system": "LOINC", "code": "1834-1", "display": "Alpha-1-Fetoprotein [Mass/volume] in Serum or Plasma" }],
      "range": { "low": 100, "high": 2000 },
      "direct_transition": "Clear_First_Visit_Flag"
    },

    "Check_AFP_NoDx": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "hcc_has_afp", "operator": "==", "value": true }, "transition": "Record_AFP_NoDx" },
        { "transition": "Clear_First_Visit_Flag" }
      ]
    },
    "Record_AFP_NoDx": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "ng/mL",
      "codes": [{ "system": "LOINC", "code": "1834-1", "display": "Alpha-1-Fetoprotein [Mass/volume] in Serum or Plasma" }],
      "range": { "low": 100, "high": 2000 },
      "direct_transition": "Clear_First_Visit_Flag"
    },

    "Clear_First_Visit_Flag": { "type": "SetAttribute", "attribute": "hcc_needs_first_visit", "value": false, "direct_transition": "End_Wellness_Encounter" },
    "End_Wellness_Encounter": { "type": "EncounterEnd", "direct_transition": "Followup_Delay" },
    "Followup_Delay": { "type": "Delay", "range": { "low": 6, "high": 12, "unit": "months" }, "direct_transition": "Wellness_Encounter" }
  },
  "gmf_version": 2
}
