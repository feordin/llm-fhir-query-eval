{
  "name": "PheKB Severe Childhood Obesity Control",
  "remarks": ["Control module for severe pediatric obesity. Generates pediatric patients (5-17) with normal BMI (15-22)."],
  "states": {
    "Initial": { "type": "Initial", "direct_transition": "Age_Guard_Min" },
    "Age_Guard_Min": { "type": "Guard", "allow": { "condition_type": "Age", "operator": ">=", "quantity": 5, "unit": "years" }, "direct_transition": "Age_Guard_Max" },
    "Age_Guard_Max": { "type": "Guard", "allow": { "condition_type": "Age", "operator": "<=", "quantity": 17, "unit": "years" }, "direct_transition": "Set_Control_Flag" },
    "Set_Control_Flag": { "type": "SetAttribute", "attribute": "seco_positive", "value": false, "direct_transition": "Wellness_Encounter" },
    "Wellness_Encounter": { "type": "Encounter", "wellness": true, "direct_transition": "Record_Normal_BMI" },
    "Record_Normal_BMI": {
      "type": "Observation",
      "category": "vital-signs",
      "unit": "kg/m2",
      "codes": [{ "system": "LOINC", "code": "39156-5", "display": "Body mass index (BMI) [Ratio]" }],
      "range": { "low": 15, "high": 22 },
      "direct_transition": "End_Wellness_Encounter"
    },
    "End_Wellness_Encounter": { "type": "EncounterEnd", "direct_transition": "Followup_Delay" },
    "Followup_Delay": { "type": "Delay", "range": { "low": 12, "high": 24, "unit": "months" }, "direct_transition": "Wellness_Encounter" }
  },
  "gmf_version": 2
}
