{
  "name": "PheKB Type 2 Diabetes Mellitus",
  "remarks": [
    "Custom Synthea module for PheKB phenotype: type-2-diabetes-mellitus",
    "Based on Northwestern University T2DM algorithm (5 identification paths)",
    "",
    "Generates TWO types of positive patients:",
    "  Type A (70%): Diagnosis + Meds + Labs (Algorithm Paths 1-3, 5)",
    "  Type B (30%): Meds + Labs, NO diagnosis code (Algorithm Path 4)",
    "",
    "Path 4 patients test whether LLMs can identify T2DM cases that have",
    "no Condition resource - only MedicationRequest + Observation evidence.",
    "",
    "Lab thresholds (from PheKB T2DM-algorithm.pdf Table 7):",
    "  Case: HbA1c >= 6.5%, Fasting glucose >= 125 mg/dL, Random glucose > 200 mg/dL",
    "  Control: HbA1c < 6.0%, Fasting glucose < 110 mg/dL, Random glucose < 110 mg/dL",
    "",
    "Codes verified via NIH UMLS MCP (2025AB):",
    "  SNOMED 44054006, LOINC 4548-4/1558-6/2339-0",
    "  RxNorm SCD: 860975 (Metformin), 310490 (Glipizide), 665033 (Sitagliptin),",
    "             310539 (Glyburide), 312440 (Pioglitazone), 199246 (Glimepiride)"
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 18,
        "unit": "years"
      },
      "direct_transition": "Set_Prediabetes"
    },
    "Set_Prediabetes": {
      "type": "SetAttribute",
      "attribute": "prediabetes",
      "value": true,
      "direct_transition": "Wait_For_T2DM_Progression"
    },
    "Wait_For_T2DM_Progression": {
      "type": "Delay",
      "range": {
        "low": 1,
        "high": 3,
        "unit": "years"
      },
      "direct_transition": "Set_Diabetes"
    },
    "Set_Diabetes": {
      "type": "SetAttribute",
      "attribute": "diabetes",
      "value": true,
      "direct_transition": "Choose_Patient_Path"
    },
    "Choose_Patient_Path": {
      "type": "Simple",
      "remarks": [
        "Split patients into two groups:",
        "  70% get a formal T2DM diagnosis (Paths 1-3, 5)",
        "  30% have NO diagnosis - only meds + abnormal labs (Path 4)",
        "This tests whether LLMs search beyond Condition resources."
      ],
      "distributed_transition": [
        {
          "transition": "Set_Path_With_Diagnosis",
          "distribution": 0.7
        },
        {
          "transition": "Set_Path_No_Diagnosis",
          "distribution": 0.3
        }
      ]
    },
    "Set_Path_With_Diagnosis": {
      "type": "SetAttribute",
      "attribute": "t2dm_has_diagnosis",
      "value": true,
      "direct_transition": "Set_Needs_First_Visit"
    },
    "Set_Path_No_Diagnosis": {
      "type": "SetAttribute",
      "remarks": [
        "Path 4: No diagnosis code, only meds + labs"
      ],
      "attribute": "t2dm_has_diagnosis",
      "value": false,
      "direct_transition": "Set_Needs_First_Visit"
    },
    "Set_Needs_First_Visit": {
      "type": "SetAttribute",
      "attribute": "t2dm_needs_first_visit",
      "value": true,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Check_First_Visit"
    },
    "Check_First_Visit": {
      "type": "Simple",
      "conditional_transition": [
        {
          "condition": {
            "condition_type": "Attribute",
            "attribute": "t2dm_needs_first_visit",
            "operator": "==",
            "value": true
          },
          "transition": "Route_First_Visit"
        },
        {
          "transition": "Record_Followup_HbA1c"
        }
      ]
    },
    "Route_First_Visit": {
      "type": "Simple",
      "remarks": [
        "Route to diagnosis or no-diagnosis path based on patient type"
      ],
      "conditional_transition": [
        {
          "condition": {
            "condition_type": "Attribute",
            "attribute": "t2dm_has_diagnosis",
            "operator": "==",
            "value": true
          },
          "transition": "Diagnose_T2DM"
        },
        {
          "transition": "Record_Path4_HbA1c"
        }
      ]
    },
    "Diagnose_T2DM": {
      "type": "Simple",
      "remarks": [
        "Paths 1-3,5: Record T2DM diagnosis inside wellness encounter",
        "Distributes patients across SNOMED variants for code-variation testing."
      ],
      "distributed_transition": [
        {
          "transition": "Diagnose_T2DM__variant_0",
          "distribution": 0.6
        },
        {
          "transition": "Diagnose_T2DM__variant_1",
          "distribution": 0.25
        },
        {
          "transition": "Diagnose_T2DM__variant_2",
          "distribution": 0.15
        }
      ]
    },
    "Record_Diagnosis_HbA1c": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "%",
      "codes": [
        {
          "system": "LOINC",
          "code": "4548-4",
          "display": "Hemoglobin A1c/Hemoglobin.total in Blood"
        }
      ],
      "range": {
        "low": 6.5,
        "high": 10.0
      },
      "direct_transition": "Record_Diagnosis_Fasting_Glucose"
    },
    "Record_Diagnosis_Fasting_Glucose": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "mg/dL",
      "codes": [
        {
          "system": "LOINC",
          "code": "1558-6",
          "display": "Fasting glucose [Mass/volume] in Serum or Plasma"
        }
      ],
      "range": {
        "low": 126,
        "high": 250
      },
      "direct_transition": "Record_Diagnosis_Random_Glucose"
    },
    "Record_Diagnosis_Random_Glucose": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "mg/dL",
      "codes": [
        {
          "system": "LOINC",
          "code": "2339-0",
          "display": "Glucose [Mass/volume] in Blood"
        }
      ],
      "range": {
        "low": 201,
        "high": 350
      },
      "direct_transition": "Prescribe_Metformin_Diagnosed"
    },
    "Prescribe_Metformin_Diagnosed": {
      "type": "MedicationOrder",
      "codes": [
        {
          "system": "RxNorm",
          "code": "860975",
          "display": "24 HR metformin hydrochloride 500 MG Extended Release Oral Tablet"
        }
      ],
      "reason": "t2dm_condition",
      "direct_transition": "Choose_Second_Med_Diagnosed"
    },
    "Choose_Second_Med_Diagnosed": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Prescribe_Glipizide_Dx",
          "distribution": 0.25
        },
        {
          "transition": "Prescribe_Sitagliptin_Dx",
          "distribution": 0.25
        },
        {
          "transition": "Prescribe_Glyburide_Dx",
          "distribution": 0.2
        },
        {
          "transition": "Clear_First_Visit_Flag",
          "distribution": 0.3
        }
      ]
    },
    "Prescribe_Glipizide_Dx": {
      "type": "MedicationOrder",
      "codes": [
        {
          "system": "RxNorm",
          "code": "310490",
          "display": "glipizide 5 MG Oral Tablet"
        }
      ],
      "reason": "t2dm_condition",
      "direct_transition": "Clear_First_Visit_Flag"
    },
    "Prescribe_Sitagliptin_Dx": {
      "type": "MedicationOrder",
      "codes": [
        {
          "system": "RxNorm",
          "code": "665033",
          "display": "sitagliptin 100 MG Oral Tablet"
        }
      ],
      "reason": "t2dm_condition",
      "direct_transition": "Clear_First_Visit_Flag"
    },
    "Prescribe_Glyburide_Dx": {
      "type": "MedicationOrder",
      "codes": [
        {
          "system": "RxNorm",
          "code": "310537",
          "display": "glyburide 5 MG Oral Tablet"
        }
      ],
      "reason": "t2dm_condition",
      "direct_transition": "Clear_First_Visit_Flag"
    },
    "Record_Path4_HbA1c": {
      "type": "Observation",
      "remarks": [
        "Path 4: Abnormal HbA1c but NO ConditionOnset - no diagnosis code"
      ],
      "category": "laboratory",
      "unit": "%",
      "codes": [
        {
          "system": "LOINC",
          "code": "4548-4",
          "display": "Hemoglobin A1c/Hemoglobin.total in Blood"
        }
      ],
      "range": {
        "low": 6.5,
        "high": 9.5
      },
      "direct_transition": "Record_Path4_Fasting_Glucose"
    },
    "Record_Path4_Fasting_Glucose": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "mg/dL",
      "codes": [
        {
          "system": "LOINC",
          "code": "1558-6",
          "display": "Fasting glucose [Mass/volume] in Serum or Plasma"
        }
      ],
      "range": {
        "low": 126,
        "high": 220
      },
      "direct_transition": "Record_Path4_Random_Glucose"
    },
    "Record_Path4_Random_Glucose": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "mg/dL",
      "codes": [
        {
          "system": "LOINC",
          "code": "2339-0",
          "display": "Glucose [Mass/volume] in Blood"
        }
      ],
      "range": {
        "low": 201,
        "high": 320
      },
      "direct_transition": "Choose_Path4_Med"
    },
    "Choose_Path4_Med": {
      "type": "Simple",
      "remarks": [
        "Path 4 patients get T2DM meds (key evidence without diagnosis)"
      ],
      "distributed_transition": [
        {
          "transition": "Prescribe_Metformin_Path4",
          "distribution": 0.4
        },
        {
          "transition": "Prescribe_Pioglitazone_Path4",
          "distribution": 0.2
        },
        {
          "transition": "Prescribe_Glimepiride_Path4",
          "distribution": 0.2
        },
        {
          "transition": "Prescribe_Glyburide_Path4",
          "distribution": 0.2
        }
      ]
    },
    "Prescribe_Metformin_Path4": {
      "type": "MedicationOrder",
      "codes": [
        {
          "system": "RxNorm",
          "code": "860975",
          "display": "24 HR metformin hydrochloride 500 MG Extended Release Oral Tablet"
        }
      ],
      "direct_transition": "Clear_First_Visit_Flag"
    },
    "Prescribe_Pioglitazone_Path4": {
      "type": "MedicationOrder",
      "codes": [
        {
          "system": "RxNorm",
          "code": "312440",
          "display": "pioglitazone 30 MG Oral Tablet"
        }
      ],
      "direct_transition": "Clear_First_Visit_Flag"
    },
    "Prescribe_Glimepiride_Path4": {
      "type": "MedicationOrder",
      "codes": [
        {
          "system": "RxNorm",
          "code": "199246",
          "display": "glimepiride 2 MG Oral Tablet"
        }
      ],
      "direct_transition": "Clear_First_Visit_Flag"
    },
    "Prescribe_Glyburide_Path4": {
      "type": "MedicationOrder",
      "codes": [
        {
          "system": "RxNorm",
          "code": "310537",
          "display": "glyburide 5 MG Oral Tablet"
        }
      ],
      "direct_transition": "Clear_First_Visit_Flag"
    },
    "Clear_First_Visit_Flag": {
      "type": "SetAttribute",
      "attribute": "t2dm_needs_first_visit",
      "value": false,
      "direct_transition": "End_Wellness_Encounter"
    },
    "Record_Followup_HbA1c": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "%",
      "codes": [
        {
          "system": "LOINC",
          "code": "4548-4",
          "display": "Hemoglobin A1c/Hemoglobin.total in Blood"
        }
      ],
      "range": {
        "low": 6.0,
        "high": 9.5
      },
      "direct_transition": "Record_Followup_Glucose"
    },
    "Record_Followup_Glucose": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "mg/dL",
      "codes": [
        {
          "system": "LOINC",
          "code": "2339-0",
          "display": "Glucose [Mass/volume] in Blood"
        }
      ],
      "range": {
        "low": 100,
        "high": 280
      },
      "direct_transition": "End_Wellness_Encounter"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 3,
        "high": 6,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Diagnose_T2DM__variant_0": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "44054006",
          "display": "Type 2 diabetes mellitus"
        }
      ],
      "direct_transition": "Record_Diagnosis_HbA1c",
      "assign_to_attribute": "t2dm_condition"
    },
    "Diagnose_T2DM__variant_1": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "73211009",
          "display": "Diabetes mellitus"
        }
      ],
      "direct_transition": "Record_Diagnosis_HbA1c",
      "assign_to_attribute": "t2dm_condition"
    },
    "Diagnose_T2DM__variant_2": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "9414007",
          "display": "Impaired glucose tolerance"
        }
      ],
      "direct_transition": "Record_Diagnosis_HbA1c",
      "assign_to_attribute": "t2dm_condition"
    }
  },
  "gmf_version": 2
}
