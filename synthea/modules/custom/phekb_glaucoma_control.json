{
  "name": "PheKB Glaucoma Control",
  "remarks": [
    "Control module for glaucoma. Generates patients age 40+ without glaucoma dx or timolol Rx."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 40,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "glauc_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Raised_intraocular_pressure"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Raised_intraocular_pressure": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Raised_intraocular_pressure",
          "distribution": 0.25
        },
        {
          "transition": "Maybe_Mimicker_Cataract",
          "distribution": 0.75
        }
      ]
    },
    "Diagnose_Mimicker_Raised_intraocular_pressure": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "112222000",
          "display": "Raised intraocular pressure"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Cataract"
    },
    "Maybe_Mimicker_Cataract": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Cataract",
          "distribution": 0.3
        },
        {
          "transition": "Maybe_Mimicker_Age_related_macular_degeneration",
          "distribution": 0.7
        }
      ]
    },
    "Diagnose_Mimicker_Cataract": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "193570009",
          "display": "Cataract"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Age_related_macular_degeneration"
    },
    "Maybe_Mimicker_Age_related_macular_degeneration": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Age_related_macular_degeneration",
          "distribution": 0.12
        },
        {
          "transition": "Maybe_Mimicker_Retinopathy_due_to_diabetes_mellitus",
          "distribution": 0.88
        }
      ]
    },
    "Diagnose_Mimicker_Age_related_macular_degeneration": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "267718000",
          "display": "Age related macular degeneration"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Retinopathy_due_to_diabetes_mellitus"
    },
    "Maybe_Mimicker_Retinopathy_due_to_diabetes_mellitus": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Retinopathy_due_to_diabetes_mellitus",
          "distribution": 0.1
        },
        {
          "transition": "Maybe_Mimicker_Optic_neuritis",
          "distribution": 0.9
        }
      ]
    },
    "Diagnose_Mimicker_Retinopathy_due_to_diabetes_mellitus": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "4855003",
          "display": "Retinopathy due to diabetes mellitus"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Optic_neuritis"
    },
    "Maybe_Mimicker_Optic_neuritis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Optic_neuritis",
          "distribution": 0.02
        },
        {
          "transition": "End_Wellness_Encounter",
          "distribution": 0.98
        }
      ]
    },
    "Diagnose_Mimicker_Optic_neuritis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "66760008",
          "display": "Optic neuritis"
        }
      ],
      "direct_transition": "End_Wellness_Encounter"
    }
  },
  "gmf_version": 2
}
