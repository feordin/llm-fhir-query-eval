{
  "name": "PheKB Parkinson's Disease Control",
  "remarks": [
    "Control module. Generates patients age 50+ without PD dx or levodopa."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 50,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "pd_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Essential_tremor"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Essential_tremor": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Essential_tremor",
          "distribution": 0.2
        },
        {
          "transition": "Maybe_Mimicker_Drug_induced_parkinsonism",
          "distribution": 0.8
        }
      ]
    },
    "Diagnose_Mimicker_Essential_tremor": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "609558009",
          "display": "Essential tremor"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Drug_induced_parkinsonism"
    },
    "Maybe_Mimicker_Drug_induced_parkinsonism": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Drug_induced_parkinsonism",
          "distribution": 0.08
        },
        {
          "transition": "Maybe_Mimicker_Dementia_with_Lewy_bodies",
          "distribution": 0.92
        }
      ]
    },
    "Diagnose_Mimicker_Drug_induced_parkinsonism": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "4223005",
          "display": "Parkinsonism caused by drug"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Dementia_with_Lewy_bodies"
    },
    "Maybe_Mimicker_Dementia_with_Lewy_bodies": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Dementia_with_Lewy_bodies",
          "distribution": 0.05
        },
        {
          "transition": "Maybe_Mimicker_Progressive_supranuclear_palsy",
          "distribution": 0.95
        }
      ]
    },
    "Diagnose_Mimicker_Dementia_with_Lewy_bodies": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "80098002",
          "display": "Lewy body disease"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Progressive_supranuclear_palsy"
    },
    "Maybe_Mimicker_Progressive_supranuclear_palsy": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Progressive_supranuclear_palsy",
          "distribution": 0.02
        },
        {
          "transition": "End_Wellness_Encounter",
          "distribution": 0.98
        }
      ]
    },
    "Diagnose_Mimicker_Progressive_supranuclear_palsy": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "192976002",
          "display": "Progressive supranuclear palsy"
        }
      ],
      "direct_transition": "End_Wellness_Encounter"
    }
  },
  "gmf_version": 2
}
