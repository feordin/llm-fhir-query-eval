{
  "name": "PheKB Coronary Heart Disease Control",
  "remarks": [
    "Control module for CHD phenotype.",
    "Generates patients without CHD (no dx, no procedures, no secondary prevention meds)."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 50,
        "unit": "years"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Gastroesophageal_reflux_disease"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Gastroesophageal_reflux_disease": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Gastroesophageal_reflux_disease",
          "distribution": 0.25
        },
        {
          "transition": "Maybe_Mimicker_Costochondritis",
          "distribution": 0.75
        }
      ]
    },
    "Diagnose_Mimicker_Gastroesophageal_reflux_disease": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "235595009",
          "display": "Gastroesophageal reflux disease"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Costochondritis"
    },
    "Maybe_Mimicker_Costochondritis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Costochondritis",
          "distribution": 0.05
        },
        {
          "transition": "Maybe_Mimicker_Pericarditis",
          "distribution": 0.95
        }
      ]
    },
    "Diagnose_Mimicker_Costochondritis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "64109004",
          "display": "Costal chondritis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Pericarditis"
    },
    "Maybe_Mimicker_Pericarditis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Pericarditis",
          "distribution": 0.02
        },
        {
          "transition": "Maybe_Mimicker_Dissection_of_aorta",
          "distribution": 0.98
        }
      ]
    },
    "Diagnose_Mimicker_Pericarditis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "3238004",
          "display": "Pericarditis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Dissection_of_aorta"
    },
    "Maybe_Mimicker_Dissection_of_aorta": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Dissection_of_aorta",
          "distribution": 0.005
        },
        {
          "transition": "End_Wellness_Encounter",
          "distribution": 0.995
        }
      ]
    },
    "Diagnose_Mimicker_Dissection_of_aorta": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "308546005",
          "display": "Dissection of aorta"
        }
      ],
      "direct_transition": "End_Wellness_Encounter"
    }
  },
  "gmf_version": 2
}
