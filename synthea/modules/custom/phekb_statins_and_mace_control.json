{
  "name": "PheKB Statins and MACE Control",
  "remarks": [
    "Control module. Generates patients age 40+ without statin Rx or AMI dx."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 40,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "mace_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Mixed_hyperlipidemia"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Mixed_hyperlipidemia": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Mixed_hyperlipidemia",
          "distribution": 0.4
        },
        {
          "transition": "Maybe_Mimicker_Coronary_arteriosclerosis",
          "distribution": 0.6
        }
      ]
    },
    "Diagnose_Mimicker_Mixed_hyperlipidemia": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "267434003",
          "display": "Mixed hyperlipidemia"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Coronary_arteriosclerosis"
    },
    "Maybe_Mimicker_Coronary_arteriosclerosis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Coronary_arteriosclerosis",
          "distribution": 0.2
        },
        {
          "transition": "Maybe_Mimicker_Type_2_diabetes_mellitus",
          "distribution": 0.8
        }
      ]
    },
    "Diagnose_Mimicker_Coronary_arteriosclerosis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "53741008",
          "display": "Coronary arteriosclerosis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Type_2_diabetes_mellitus"
    },
    "Maybe_Mimicker_Type_2_diabetes_mellitus": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Type_2_diabetes_mellitus",
          "distribution": 0.25
        },
        {
          "transition": "Maybe_Mimicker_Essential_hypertension",
          "distribution": 0.75
        }
      ]
    },
    "Diagnose_Mimicker_Type_2_diabetes_mellitus": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "44054006",
          "display": "Type 2 diabetes mellitus"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Essential_hypertension"
    },
    "Maybe_Mimicker_Essential_hypertension": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Essential_hypertension",
          "distribution": 0.3
        },
        {
          "transition": "Maybe_Mimicker_Stable_angina",
          "distribution": 0.7
        }
      ]
    },
    "Diagnose_Mimicker_Essential_hypertension": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "59621000",
          "display": "Essential hypertension"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Stable_angina"
    },
    "Maybe_Mimicker_Stable_angina": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Stable_angina",
          "distribution": 0.1
        },
        {
          "transition": "End_Wellness_Encounter",
          "distribution": 0.9
        }
      ]
    },
    "Diagnose_Mimicker_Stable_angina": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "233819005",
          "display": "Stable angina"
        }
      ],
      "direct_transition": "End_Wellness_Encounter"
    }
  },
  "gmf_version": 2
}
