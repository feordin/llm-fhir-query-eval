{
  "name": "PheKB Crohn's Disease Control",
  "remarks": [
    "Control module for PheKB Crohn's Disease phenotype.",
    "Generates patients who do NOT have Crohn's.",
    "",
    "Controls have:",
    "  - No Crohn's diagnosis",
    "  - Calprotectin below 50 mcg/g (well below 250 cutoff)",
    "  - No IBD therapy"
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 18,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "crohn_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Ulcerative_colitis"
    },
    "Record_Normal_Calprotectin": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "ug/g",
      "codes": [
        {
          "system": "LOINC",
          "code": "38445-3",
          "display": "Calprotectin [Mass/mass] in Stool"
        }
      ],
      "range": {
        "low": 10,
        "high": 50
      },
      "direct_transition": "End_Wellness_Encounter"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Ulcerative_colitis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Ulcerative_colitis",
          "distribution": 0.1
        },
        {
          "transition": "Maybe_Mimicker_Irritable_bowel_syndrome",
          "distribution": 0.9
        }
      ]
    },
    "Diagnose_Mimicker_Ulcerative_colitis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "64766004",
          "display": "Ulcerative colitis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Irritable_bowel_syndrome"
    },
    "Maybe_Mimicker_Irritable_bowel_syndrome": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Irritable_bowel_syndrome",
          "distribution": 0.2
        },
        {
          "transition": "Maybe_Mimicker_Celiac_disease",
          "distribution": 0.8
        }
      ]
    },
    "Diagnose_Mimicker_Irritable_bowel_syndrome": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "10743008",
          "display": "Irritable bowel syndrome"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Celiac_disease"
    },
    "Maybe_Mimicker_Celiac_disease": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Celiac_disease",
          "distribution": 0.05
        },
        {
          "transition": "Maybe_Mimicker_Microscopic_colitis",
          "distribution": 0.95
        }
      ]
    },
    "Diagnose_Mimicker_Celiac_disease": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "396331005",
          "display": "Celiac disease"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Microscopic_colitis"
    },
    "Maybe_Mimicker_Microscopic_colitis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Microscopic_colitis",
          "distribution": 0.02
        },
        {
          "transition": "Record_Normal_Calprotectin",
          "distribution": 0.98
        }
      ]
    },
    "Diagnose_Mimicker_Microscopic_colitis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "235753003",
          "display": "Microscopic colitis"
        }
      ],
      "direct_transition": "Record_Normal_Calprotectin"
    }
  },
  "gmf_version": 2
}
