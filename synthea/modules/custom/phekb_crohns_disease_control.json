{
  "name": "PheKB Crohn's Disease Control",
  "remarks": [
    "Control module for PheKB Crohn's Disease phenotype.",
    "Generates patients who do NOT have Crohn's.",
    "",
    "Controls have:",
    "  - No Crohn's diagnosis",
    "  - Calprotectin below 50 mcg/g (well below 250 cutoff)",
    "  - No IBD therapy"
  ],
  "states": {
    "Initial": { "type": "Initial", "direct_transition": "Age_Guard" },
    "Age_Guard": { "type": "Guard", "allow": { "condition_type": "Age", "operator": ">=", "quantity": 18, "unit": "years" }, "direct_transition": "Set_Control_Flag" },
    "Set_Control_Flag": { "type": "SetAttribute", "attribute": "crohn_positive", "value": false, "direct_transition": "Wellness_Encounter" },
    "Wellness_Encounter": { "type": "Encounter", "wellness": true, "direct_transition": "Record_Normal_Calprotectin" },
    "Record_Normal_Calprotectin": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "ug/g",
      "codes": [{ "system": "LOINC", "code": "38445-3", "display": "Calprotectin [Mass/mass] in Stool" }],
      "range": { "low": 10, "high": 50 },
      "direct_transition": "End_Wellness_Encounter"
    },
    "End_Wellness_Encounter": { "type": "EncounterEnd", "direct_transition": "Followup_Delay" },
    "Followup_Delay": { "type": "Delay", "range": { "low": 12, "high": 24, "unit": "months" }, "direct_transition": "Wellness_Encounter" }
  },
  "gmf_version": 2
}
