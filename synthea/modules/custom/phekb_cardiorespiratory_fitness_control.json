{
  "name": "PheKB Cardiorespiratory Fitness Control",
  "remarks": [
    "Control: age 18+ without stress test."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 18,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "crf_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Iron_deficiency_anemia"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Obesity": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Obesity",
          "distribution": 0.35
        },
        {
          "transition": "Maybe_Mimicker_Coronary_arteriosclerosis",
          "distribution": 0.65
        }
      ]
    },
    "Diagnose_Mimicker_Obesity": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "414916001",
          "display": "Obesity"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Coronary_arteriosclerosis"
    },
    "Maybe_Mimicker_Coronary_arteriosclerosis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Coronary_arteriosclerosis",
          "distribution": 0.15
        },
        {
          "transition": "Maybe_Mimicker_Congestive_heart_failure",
          "distribution": 0.85
        }
      ]
    },
    "Diagnose_Mimicker_Coronary_arteriosclerosis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "53741008",
          "display": "Coronary arteriosclerosis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Congestive_heart_failure"
    },
    "Maybe_Mimicker_Congestive_heart_failure": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Congestive_heart_failure",
          "distribution": 0.08
        },
        {
          "transition": "Maybe_Mimicker_Chronic_obstructive_pulmonary_disease",
          "distribution": 0.92
        }
      ]
    },
    "Diagnose_Mimicker_Congestive_heart_failure": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "42343007",
          "display": "Congestive heart failure"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Chronic_obstructive_pulmonary_disease"
    },
    "Maybe_Mimicker_Chronic_obstructive_pulmonary_disease": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Chronic_obstructive_pulmonary_disease",
          "distribution": 0.1
        },
        {
          "transition": "End_Wellness_Encounter",
          "distribution": 0.9
        }
      ]
    },
    "Diagnose_Mimicker_Chronic_obstructive_pulmonary_disease": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "13645005",
          "display": "Chronic obstructive pulmonary disease"
        }
      ],
      "direct_transition": "End_Wellness_Encounter"
    },
    "Maybe_Mimicker_Iron_deficiency_anemia": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Iron_deficiency_anemia",
          "distribution": 0.07
        },
        {
          "transition": "Maybe_Mimicker_Obesity",
          "distribution": 0.9299999999999999
        }
      ]
    },
    "Diagnose_Mimicker_Iron_deficiency_anemia": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "87522002",
          "display": "Iron deficiency anemia"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Obesity"
    }
  },
  "gmf_version": 2
}
