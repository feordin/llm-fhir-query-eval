{
  "name": "PheKB Renal Cell Carcinoma Control",
  "remarks": [
    "Control module for renal cell carcinoma. Generates patients age 50+ without RCC dx."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 50,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "rcc_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Cyst_of_kidney"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Cyst_of_kidney": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Cyst_of_kidney",
          "distribution": 0.35
        },
        {
          "transition": "Maybe_Mimicker_Angiomyolipoma",
          "distribution": 0.65
        }
      ]
    },
    "Diagnose_Mimicker_Cyst_of_kidney": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "722223000",
          "display": "Cyst of kidney"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Angiomyolipoma"
    },
    "Maybe_Mimicker_Angiomyolipoma": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Angiomyolipoma",
          "distribution": 0.05
        },
        {
          "transition": "Maybe_Mimicker_Pyelonephritis",
          "distribution": 0.95
        }
      ]
    },
    "Diagnose_Mimicker_Angiomyolipoma": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "19929002",
          "display": "Angiomyolipoma"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Pyelonephritis"
    },
    "Maybe_Mimicker_Pyelonephritis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Pyelonephritis",
          "distribution": 0.1
        },
        {
          "transition": "Maybe_Mimicker_Malignant_neoplasm_of_urinary_bladder",
          "distribution": 0.9
        }
      ]
    },
    "Diagnose_Mimicker_Pyelonephritis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "45816000",
          "display": "Pyelonephritis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Malignant_neoplasm_of_urinary_bladder"
    },
    "Maybe_Mimicker_Malignant_neoplasm_of_urinary_bladder": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Malignant_neoplasm_of_urinary_bladder",
          "distribution": 0.08
        },
        {
          "transition": "Maybe_Mimicker_Hydronephrosis",
          "distribution": 0.92
        }
      ]
    },
    "Diagnose_Mimicker_Malignant_neoplasm_of_urinary_bladder": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "399326009",
          "display": "Malignant neoplasm of urinary bladder"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Hydronephrosis"
    },
    "Maybe_Mimicker_Hydronephrosis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Hydronephrosis",
          "distribution": 0.1
        },
        {
          "transition": "End_Wellness_Encounter",
          "distribution": 0.9
        }
      ]
    },
    "Diagnose_Mimicker_Hydronephrosis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "43064006",
          "display": "Hydronephrosis"
        }
      ],
      "direct_transition": "End_Wellness_Encounter"
    }
  },
  "gmf_version": 2
}
