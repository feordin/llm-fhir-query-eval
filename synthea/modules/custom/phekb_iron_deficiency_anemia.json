{
  "name": "PheKB Iron Deficiency Anemia",
  "remarks": [
    "Custom Synthea module for iron deficiency anemia (IDA).",
    "First hematology phenotype. First ferritin/hemoglobin lab phenotype.",
    "Tests recognition that ferritin <30 ng/mL + low Hgb defines IDA — distinct from anemia of chronic disease (high ferritin) or B12/folate deficiency.",
    "",
    "Generates FOUR patient paths:",
    "  Path A (45%): IDA dx + ferrous sulfate + low Hgb + low ferritin",
    "  Path B (20%): IDA dx + iron Rx, no labs measured",
    "  Path C (20%): Iron Rx without IDA dx (TRICKY — empirical for chronic blood loss, vegetarianism)",
    "  Path D (15%): Low Hgb + low ferritin without IDA dx (TRICKY — undiagnosed/asymptomatic)",
    "",
    "Diagnosis SNOMED variation:",
    "  60% Iron deficiency anemia (87522002) — most specific",
    "  40% Anemia (271737000) — broader",
    "",
    "Hgb range: 7-11 g/dL (normal F 12-16, M 14-18). Ferritin range: 5-25 ng/mL (low <30 = iron deficiency).",
    "",
    "Age guard: >=18."
  ],
  "states": {
    "Initial": { "type": "Initial", "direct_transition": "Age_Guard" },
    "Age_Guard": { "type": "Guard", "allow": { "condition_type": "Age", "operator": ">=", "quantity": 18, "unit": "years" }, "direct_transition": "Set_IDA_Flag" },
    "Set_IDA_Flag": { "type": "SetAttribute", "attribute": "ida_positive", "value": true, "direct_transition": "Choose_Patient_Path" },
    "Choose_Patient_Path": {
      "type": "Simple",
      "distributed_transition": [
        { "transition": "Set_Path_A", "distribution": 0.45 },
        { "transition": "Set_Path_B", "distribution": 0.20 },
        { "transition": "Set_Path_C", "distribution": 0.20 },
        { "transition": "Set_Path_D", "distribution": 0.15 }
      ]
    },
    "Set_Path_A": { "type": "SetAttribute", "attribute": "ida_has_dx", "value": true, "direct_transition": "Set_Path_A_Med" },
    "Set_Path_A_Med": { "type": "SetAttribute", "attribute": "ida_has_med", "value": true, "direct_transition": "Set_Path_A_Lab" },
    "Set_Path_A_Lab": { "type": "SetAttribute", "attribute": "ida_has_lab", "value": true, "direct_transition": "Choose_Subtype" },
    "Set_Path_B": { "type": "SetAttribute", "attribute": "ida_has_dx", "value": true, "direct_transition": "Set_Path_B_Med" },
    "Set_Path_B_Med": { "type": "SetAttribute", "attribute": "ida_has_med", "value": true, "direct_transition": "Set_Path_B_Lab" },
    "Set_Path_B_Lab": { "type": "SetAttribute", "attribute": "ida_has_lab", "value": false, "direct_transition": "Choose_Subtype" },
    "Set_Path_C": { "type": "SetAttribute", "remarks": ["TRICKY: iron Rx without IDA dx"], "attribute": "ida_has_dx", "value": false, "direct_transition": "Set_Path_C_Med" },
    "Set_Path_C_Med": { "type": "SetAttribute", "attribute": "ida_has_med", "value": true, "direct_transition": "Set_Path_C_Lab" },
    "Set_Path_C_Lab": { "type": "SetAttribute", "attribute": "ida_has_lab", "value": false, "direct_transition": "Choose_Subtype" },
    "Set_Path_D": { "type": "SetAttribute", "remarks": ["TRICKY: low Hgb + low ferritin, no IDA dx"], "attribute": "ida_has_dx", "value": false, "direct_transition": "Set_Path_D_Med" },
    "Set_Path_D_Med": { "type": "SetAttribute", "attribute": "ida_has_med", "value": false, "direct_transition": "Set_Path_D_Lab" },
    "Set_Path_D_Lab": { "type": "SetAttribute", "attribute": "ida_has_lab", "value": true, "direct_transition": "Choose_Subtype" },

    "Choose_Subtype": {
      "type": "Simple",
      "distributed_transition": [
        { "transition": "Set_Subtype_IDA", "distribution": 0.60 },
        { "transition": "Set_Subtype_Anemia", "distribution": 0.40 }
      ]
    },
    "Set_Subtype_IDA": { "type": "SetAttribute", "attribute": "ida_subtype", "value": "ida", "direct_transition": "Set_Needs_First_Visit" },
    "Set_Subtype_Anemia": { "type": "SetAttribute", "attribute": "ida_subtype", "value": "anemia", "direct_transition": "Set_Needs_First_Visit" },

    "Set_Needs_First_Visit": { "type": "SetAttribute", "attribute": "ida_needs_first_visit", "value": true, "direct_transition": "Wellness_Encounter" },
    "Wellness_Encounter": { "type": "Encounter", "wellness": true, "direct_transition": "Check_First_Visit" },
    "Check_First_Visit": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "ida_needs_first_visit", "operator": "==", "value": true }, "transition": "Check_Has_Diagnosis" },
        { "transition": "End_Wellness_Encounter" }
      ]
    },
    "Check_Has_Diagnosis": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "ida_has_dx", "operator": "==", "value": true }, "transition": "Route_By_Subtype" },
        { "transition": "Check_Med_NoDx" }
      ]
    },
    "Route_By_Subtype": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "ida_subtype", "operator": "==", "value": "ida" }, "transition": "Diagnose_IDA" },
        { "transition": "Diagnose_Anemia" }
      ]
    },
    "Diagnose_IDA": { "type": "ConditionOnset", "assign_to_attribute": "ida_condition", "codes": [{ "system": "SNOMED-CT", "code": "87522002", "display": "Iron deficiency anemia" }], "direct_transition": "Check_Med_WithDx" },
    "Diagnose_Anemia": { "type": "ConditionOnset", "assign_to_attribute": "ida_condition", "codes": [{ "system": "SNOMED-CT", "code": "271737000", "display": "Anemia" }], "direct_transition": "Check_Med_WithDx" },

    "Check_Med_WithDx": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "ida_has_med", "operator": "==", "value": true }, "transition": "Prescribe_Iron_WithDx" },
        { "transition": "Check_Lab_WithDx" }
      ]
    },
    "Prescribe_Iron_WithDx": { "type": "MedicationOrder", "codes": [{ "system": "RxNorm", "code": "310325", "display": "ferrous sulfate 325 MG Oral Tablet" }], "reason": "ida_condition", "direct_transition": "Check_Lab_WithDx" },
    "Check_Lab_WithDx": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "ida_has_lab", "operator": "==", "value": true }, "transition": "Record_Hgb_WithDx" },
        { "transition": "Clear_First_Visit_Flag" }
      ]
    },
    "Record_Hgb_WithDx": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "g/dL",
      "codes": [{ "system": "LOINC", "code": "718-7", "display": "Hemoglobin [Mass/volume] in Blood" }],
      "range": { "low": 7, "high": 11 },
      "direct_transition": "Record_Ferritin_WithDx"
    },
    "Record_Ferritin_WithDx": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "ng/mL",
      "codes": [{ "system": "LOINC", "code": "2276-4", "display": "Ferritin [Mass/volume] in Serum or Plasma" }],
      "range": { "low": 5, "high": 25 },
      "direct_transition": "Clear_First_Visit_Flag"
    },

    "Check_Med_NoDx": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "ida_has_med", "operator": "==", "value": true }, "transition": "Prescribe_Iron_NoDx" },
        { "transition": "Check_Lab_NoDx" }
      ]
    },
    "Prescribe_Iron_NoDx": { "type": "MedicationOrder", "codes": [{ "system": "RxNorm", "code": "310325", "display": "ferrous sulfate 325 MG Oral Tablet" }], "direct_transition": "Check_Lab_NoDx" },
    "Check_Lab_NoDx": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "ida_has_lab", "operator": "==", "value": true }, "transition": "Record_Hgb_NoDx" },
        { "transition": "Clear_First_Visit_Flag" }
      ]
    },
    "Record_Hgb_NoDx": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "g/dL",
      "codes": [{ "system": "LOINC", "code": "718-7", "display": "Hemoglobin [Mass/volume] in Blood" }],
      "range": { "low": 7, "high": 11 },
      "direct_transition": "Record_Ferritin_NoDx"
    },
    "Record_Ferritin_NoDx": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "ng/mL",
      "codes": [{ "system": "LOINC", "code": "2276-4", "display": "Ferritin [Mass/volume] in Serum or Plasma" }],
      "range": { "low": 5, "high": 25 },
      "direct_transition": "Clear_First_Visit_Flag"
    },

    "Clear_First_Visit_Flag": { "type": "SetAttribute", "attribute": "ida_needs_first_visit", "value": false, "direct_transition": "End_Wellness_Encounter" },
    "End_Wellness_Encounter": { "type": "EncounterEnd", "direct_transition": "Followup_Delay" },
    "Followup_Delay": { "type": "Delay", "range": { "low": 6, "high": 12, "unit": "months" }, "direct_transition": "Wellness_Encounter" }
  },
  "gmf_version": 2
}
