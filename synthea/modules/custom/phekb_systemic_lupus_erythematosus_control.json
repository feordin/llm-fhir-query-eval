{
  "name": "PheKB Systemic Lupus Erythematosus Control",
  "remarks": [
    "Control module for PheKB SLE phenotype.",
    "Generates patients without SLE — negative ANA titers (10-80, below the 1:160 cutoff)."
  ],
  "states": {
    "Initial": { "type": "Initial", "direct_transition": "Age_Guard" },
    "Age_Guard": { "type": "Guard", "allow": { "condition_type": "Age", "operator": ">=", "quantity": 18, "unit": "years" }, "direct_transition": "Set_Control_Flag" },
    "Set_Control_Flag": { "type": "SetAttribute", "attribute": "sle_positive", "value": false, "direct_transition": "Wellness_Encounter" },
    "Wellness_Encounter": { "type": "Encounter", "wellness": true, "direct_transition": "Record_Normal_ANA" },
    "Record_Normal_ANA": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "{titer}",
      "codes": [{ "system": "LOINC", "code": "5048-4", "display": "Nuclear Ab [Titer] in Serum by Immunofluorescence" }],
      "range": { "low": 10, "high": 80 },
      "direct_transition": "End_Wellness_Encounter"
    },
    "End_Wellness_Encounter": { "type": "EncounterEnd", "direct_transition": "Followup_Delay" },
    "Followup_Delay": { "type": "Delay", "range": { "low": 12, "high": 24, "unit": "months" }, "direct_transition": "Wellness_Encounter" }
  },
  "gmf_version": 2
}
