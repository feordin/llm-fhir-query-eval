{
  "name": "PheKB Systemic Lupus Erythematosus Control",
  "remarks": [
    "Control module for PheKB SLE phenotype.",
    "Generates patients without SLE \u2014 negative ANA titers (10-80, below the 1:160 cutoff)."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 18,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "sle_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Rheumatoid_arthritis"
    },
    "Record_Normal_ANA": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "{titer}",
      "codes": [
        {
          "system": "LOINC",
          "code": "5048-4",
          "display": "Nuclear Ab [Titer] in Serum by Immunofluorescence"
        }
      ],
      "range": {
        "low": 10,
        "high": 80
      },
      "direct_transition": "End_Wellness_Encounter"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Rheumatoid_arthritis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Rheumatoid_arthritis",
          "distribution": 0.15
        },
        {
          "transition": "Maybe_Mimicker_Sjogren_s_syndrome",
          "distribution": 0.85
        }
      ]
    },
    "Diagnose_Mimicker_Rheumatoid_arthritis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "69896004",
          "display": "Rheumatoid arthritis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Sjogren_s_syndrome"
    },
    "Maybe_Mimicker_Sjogren_s_syndrome": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Sjogren_s_syndrome",
          "distribution": 0.08
        },
        {
          "transition": "Maybe_Mimicker_Mixed_connective_tissue_disease",
          "distribution": 0.92
        }
      ]
    },
    "Diagnose_Mimicker_Sjogren_s_syndrome": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "83901003",
          "display": "Sj\u00f6gren's syndrome"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Mixed_connective_tissue_disease"
    },
    "Maybe_Mimicker_Mixed_connective_tissue_disease": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Mixed_connective_tissue_disease",
          "distribution": 0.03
        },
        {
          "transition": "Maybe_Mimicker_Fibromyalgia",
          "distribution": 0.97
        }
      ]
    },
    "Diagnose_Mimicker_Mixed_connective_tissue_disease": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "398049005",
          "display": "Mixed collagen vascular disease"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Fibromyalgia"
    },
    "Maybe_Mimicker_Fibromyalgia": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Fibromyalgia",
          "distribution": 0.1
        },
        {
          "transition": "Record_Normal_ANA",
          "distribution": 0.9
        }
      ]
    },
    "Diagnose_Mimicker_Fibromyalgia": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "203082005",
          "display": "Fibromyalgia"
        }
      ],
      "direct_transition": "Record_Normal_ANA"
    }
  },
  "gmf_version": 2
}
