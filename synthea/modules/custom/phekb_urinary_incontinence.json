{
  "name": "PheKB Urinary Incontinence",
  "remarks": [
    "Custom Synthea module for urinary incontinence (overactive bladder).",
    "First non-cancer genitourinary phenotype.",
    "",
    "Generates THREE patient paths:",
    "  Path A (60%): UI dx + anticholinergic (oxybutynin / tolterodine / solifenacin)",
    "  Path B (30%): UI dx only (lifestyle / pelvic floor therapy, not modeled)",
    "  Path C (10%): anticholinergic without UI dx (TRICKY — overactive bladder undiagnosed)",
    "",
    "Med distribution within Path A/C:",
    "  50% oxybutynin (older, non-selective)",
    "  30% tolterodine (M3-selective)",
    "  20% solifenacin (M3-selective, longer half-life)",
    "",
    "Age guard: >=50 (UI prevalence rises sharply with age)."
  ],
  "states": {
    "Initial": { "type": "Initial", "direct_transition": "Age_Guard" },
    "Age_Guard": { "type": "Guard", "allow": { "condition_type": "Age", "operator": ">=", "quantity": 50, "unit": "years" }, "direct_transition": "Set_Ui_Flag" },
    "Set_Ui_Flag": { "type": "SetAttribute", "attribute": "ui_positive", "value": true, "direct_transition": "Choose_Patient_Path" },
    "Choose_Patient_Path": {
      "type": "Simple",
      "distributed_transition": [
        { "transition": "Set_Path_A", "distribution": 0.60 },
        { "transition": "Set_Path_B", "distribution": 0.30 },
        { "transition": "Set_Path_C", "distribution": 0.10 }
      ]
    },
    "Set_Path_A": { "type": "SetAttribute", "attribute": "ui_has_dx", "value": true, "direct_transition": "Set_Path_A_Med" },
    "Set_Path_A_Med": { "type": "SetAttribute", "attribute": "ui_has_med", "value": true, "direct_transition": "Choose_Med" },
    "Set_Path_B": { "type": "SetAttribute", "attribute": "ui_has_dx", "value": true, "direct_transition": "Set_Path_B_Med" },
    "Set_Path_B_Med": { "type": "SetAttribute", "attribute": "ui_has_med", "value": false, "direct_transition": "Choose_Med" },
    "Set_Path_C": { "type": "SetAttribute", "remarks": ["TRICKY: anticholinergic without UI dx"], "attribute": "ui_has_dx", "value": false, "direct_transition": "Set_Path_C_Med" },
    "Set_Path_C_Med": { "type": "SetAttribute", "attribute": "ui_has_med", "value": true, "direct_transition": "Choose_Med" },

    "Choose_Med": {
      "type": "Simple",
      "distributed_transition": [
        { "transition": "Set_Med_Oxybutynin", "distribution": 0.50 },
        { "transition": "Set_Med_Tolterodine", "distribution": 0.30 },
        { "transition": "Set_Med_Solifenacin", "distribution": 0.20 }
      ]
    },
    "Set_Med_Oxybutynin": { "type": "SetAttribute", "attribute": "ui_med_choice", "value": "oxybutynin", "direct_transition": "Set_Needs_First_Visit" },
    "Set_Med_Tolterodine": { "type": "SetAttribute", "attribute": "ui_med_choice", "value": "tolterodine", "direct_transition": "Set_Needs_First_Visit" },
    "Set_Med_Solifenacin": { "type": "SetAttribute", "attribute": "ui_med_choice", "value": "solifenacin", "direct_transition": "Set_Needs_First_Visit" },

    "Set_Needs_First_Visit": { "type": "SetAttribute", "attribute": "ui_needs_first_visit", "value": true, "direct_transition": "Wellness_Encounter" },
    "Wellness_Encounter": { "type": "Encounter", "wellness": true, "direct_transition": "Check_First_Visit" },
    "Check_First_Visit": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "ui_needs_first_visit", "operator": "==", "value": true }, "transition": "Check_Has_Diagnosis" },
        { "transition": "End_Wellness_Encounter" }
      ]
    },
    "Check_Has_Diagnosis": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "ui_has_dx", "operator": "==", "value": true }, "transition": "Diagnose_Ui" },
        { "transition": "Check_Med_NoDx" }
      ]
    },
    "Diagnose_Ui": { "type": "ConditionOnset", "assign_to_attribute": "ui_condition", "codes": [{ "system": "SNOMED-CT", "code": "165232002", "display": "Urinary incontinence" }], "direct_transition": "Check_Med_WithDx" },

    "Check_Med_WithDx": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "ui_has_med", "operator": "==", "value": true }, "transition": "Route_Med_WithDx" },
        { "transition": "Clear_First_Visit_Flag" }
      ]
    },
    "Route_Med_WithDx": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "ui_med_choice", "operator": "==", "value": "oxybutynin" }, "transition": "Prescribe_Oxy_WithDx" },
        { "condition": { "condition_type": "Attribute", "attribute": "ui_med_choice", "operator": "==", "value": "tolterodine" }, "transition": "Prescribe_Tol_WithDx" },
        { "transition": "Prescribe_Sol_WithDx" }
      ]
    },
    "Prescribe_Oxy_WithDx": { "type": "MedicationOrder", "codes": [{ "system": "RxNorm", "code": "32675", "display": "oxybutynin" }], "reason": "ui_condition", "direct_transition": "Clear_First_Visit_Flag" },
    "Prescribe_Tol_WithDx": { "type": "MedicationOrder", "codes": [{ "system": "RxNorm", "code": "119565", "display": "tolterodine" }], "reason": "ui_condition", "direct_transition": "Clear_First_Visit_Flag" },
    "Prescribe_Sol_WithDx": { "type": "MedicationOrder", "codes": [{ "system": "RxNorm", "code": "322167", "display": "solifenacin" }], "reason": "ui_condition", "direct_transition": "Clear_First_Visit_Flag" },

    "Check_Med_NoDx": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "ui_has_med", "operator": "==", "value": true }, "transition": "Route_Med_NoDx" },
        { "transition": "Clear_First_Visit_Flag" }
      ]
    },
    "Route_Med_NoDx": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "ui_med_choice", "operator": "==", "value": "oxybutynin" }, "transition": "Prescribe_Oxy_NoDx" },
        { "condition": { "condition_type": "Attribute", "attribute": "ui_med_choice", "operator": "==", "value": "tolterodine" }, "transition": "Prescribe_Tol_NoDx" },
        { "transition": "Prescribe_Sol_NoDx" }
      ]
    },
    "Prescribe_Oxy_NoDx": { "type": "MedicationOrder", "codes": [{ "system": "RxNorm", "code": "32675", "display": "oxybutynin" }], "direct_transition": "Clear_First_Visit_Flag" },
    "Prescribe_Tol_NoDx": { "type": "MedicationOrder", "codes": [{ "system": "RxNorm", "code": "119565", "display": "tolterodine" }], "direct_transition": "Clear_First_Visit_Flag" },
    "Prescribe_Sol_NoDx": { "type": "MedicationOrder", "codes": [{ "system": "RxNorm", "code": "322167", "display": "solifenacin" }], "direct_transition": "Clear_First_Visit_Flag" },

    "Clear_First_Visit_Flag": { "type": "SetAttribute", "attribute": "ui_needs_first_visit", "value": false, "direct_transition": "End_Wellness_Encounter" },
    "End_Wellness_Encounter": { "type": "EncounterEnd", "direct_transition": "Followup_Delay" },
    "Followup_Delay": { "type": "Delay", "range": { "low": 6, "high": 12, "unit": "months" }, "direct_transition": "Wellness_Encounter" }
  },
  "gmf_version": 2
}
