{
  "name": "PheKB Autoimmune Disease Control",
  "remarks": [
    "Control: age 18+ without autoimmune dx."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 18,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "aid_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Fibromyalgia"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Fibromyalgia": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Fibromyalgia",
          "distribution": 0.15
        },
        {
          "transition": "Maybe_Mimicker_Hypothyroidism",
          "distribution": 0.85
        }
      ]
    },
    "Diagnose_Mimicker_Fibromyalgia": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "203082005",
          "display": "Fibromyalgia"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Hypothyroidism"
    },
    "Maybe_Mimicker_Hypothyroidism": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Hypothyroidism",
          "distribution": 0.2
        },
        {
          "transition": "Maybe_Mimicker_Degenerative_polyarthritis",
          "distribution": 0.8
        }
      ]
    },
    "Diagnose_Mimicker_Hypothyroidism": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "40930008",
          "display": "Hypothyroidism"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Degenerative_polyarthritis"
    },
    "Maybe_Mimicker_Degenerative_polyarthritis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Degenerative_polyarthritis",
          "distribution": 0.25
        },
        {
          "transition": "Maybe_Mimicker_Chronic_fatigue_syndrome",
          "distribution": 0.75
        }
      ]
    },
    "Diagnose_Mimicker_Degenerative_polyarthritis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "225655006",
          "display": "Degenerative polyarthritis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Chronic_fatigue_syndrome"
    },
    "Maybe_Mimicker_Chronic_fatigue_syndrome": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Chronic_fatigue_syndrome",
          "distribution": 0.05
        },
        {
          "transition": "Maybe_Mimicker_Polymyalgia_rheumatica",
          "distribution": 0.95
        }
      ]
