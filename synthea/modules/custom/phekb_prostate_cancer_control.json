{
  "name": "PheKB Prostate Cancer Control",
  "remarks": [
    "Control module for PheKB prostate cancer phenotype.",
    "Generates male patients without PCa. Normal PSA values (0.5-3 ng/mL)."
  ],
  "states": {
    "Initial": { "type": "Initial", "direct_transition": "Sex_Guard" },
    "Sex_Guard": { "type": "Guard", "allow": { "condition_type": "Gender", "gender": "M" }, "direct_transition": "Age_Guard" },
    "Age_Guard": { "type": "Guard", "allow": { "condition_type": "Age", "operator": ">=", "quantity": 50, "unit": "years" }, "direct_transition": "Set_Control_Flag" },
    "Set_Control_Flag": { "type": "SetAttribute", "attribute": "pca_positive", "value": false, "direct_transition": "Wellness_Encounter" },
    "Wellness_Encounter": { "type": "Encounter", "wellness": true, "direct_transition": "Record_Normal_PSA" },
    "Record_Normal_PSA": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "ng/mL",
      "codes": [{ "system": "LOINC", "code": "2857-1", "display": "Prostate specific Ag [Mass/volume] in Serum or Plasma" }],
      "range": { "low": 0.5, "high": 3.0 },
      "direct_transition": "End_Wellness_Encounter"
    },
    "End_Wellness_Encounter": { "type": "EncounterEnd", "direct_transition": "Followup_Delay" },
    "Followup_Delay": { "type": "Delay", "range": { "low": 12, "high": 24, "unit": "months" }, "direct_transition": "Wellness_Encounter" }
  },
  "gmf_version": 2
}
