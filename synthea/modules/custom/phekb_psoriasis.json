{
  "name": "PheKB Psoriasis",
  "remarks": [
    "Custom Synthea module for psoriasis.",
    "First immune-mediated skin disease phenotype.",
    "",
    "Generates THREE patient paths:",
    "  Path A (60%): Psoriasis dx + methotrexate (systemic therapy)",
    "  Path B (30%): Psoriasis dx only (mild — topical only, not modeled)",
    "  Path C (10%): methotrexate without psoriasis dx (TRICKY — also indicated for RA, ectopic pregnancy, malignancy)",
    "",
    "Age guard: >=18."
  ],
  "states": {
    "Initial": { "type": "Initial", "direct_transition": "Age_Guard" },
    "Age_Guard": { "type": "Guard", "allow": { "condition_type": "Age", "operator": ">=", "quantity": 18, "unit": "years" }, "direct_transition": "Set_Pso_Flag" },
    "Set_Pso_Flag": { "type": "SetAttribute", "attribute": "pso_positive", "value": true, "direct_transition": "Choose_Patient_Path" },
    "Choose_Patient_Path": {
      "type": "Simple",
      "distributed_transition": [
        { "transition": "Set_Path_A", "distribution": 0.60 },
        { "transition": "Set_Path_B", "distribution": 0.30 },
        { "transition": "Set_Path_C", "distribution": 0.10 }
      ]
    },
    "Set_Path_A": { "type": "SetAttribute", "attribute": "pso_has_dx", "value": true, "direct_transition": "Set_Path_A_Med" },
    "Set_Path_A_Med": { "type": "SetAttribute", "attribute": "pso_has_med", "value": true, "direct_transition": "Set_Needs_First_Visit" },
    "Set_Path_B": { "type": "SetAttribute", "attribute": "pso_has_dx", "value": true, "direct_transition": "Set_Path_B_Med" },
    "Set_Path_B_Med": { "type": "SetAttribute", "attribute": "pso_has_med", "value": false, "direct_transition": "Set_Needs_First_Visit" },
    "Set_Path_C": { "type": "SetAttribute", "remarks": ["TRICKY: methotrexate without psoriasis dx (cross-indicates RA)"], "attribute": "pso_has_dx", "value": false, "direct_transition": "Set_Path_C_Med" },
    "Set_Path_C_Med": { "type": "SetAttribute", "attribute": "pso_has_med", "value": true, "direct_transition": "Set_Needs_First_Visit" },

    "Set_Needs_First_Visit": { "type": "SetAttribute", "attribute": "pso_needs_first_visit", "value": true, "direct_transition": "Wellness_Encounter" },
    "Wellness_Encounter": { "type": "Encounter", "wellness": true, "direct_transition": "Check_First_Visit" },
    "Check_First_Visit": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "pso_needs_first_visit", "operator": "==", "value": true }, "transition": "Check_Has_Diagnosis" },
        { "transition": "End_Wellness_Encounter" }
      ]
    },
    "Check_Has_Diagnosis": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "pso_has_dx", "operator": "==", "value": true }, "transition": "Diagnose_Pso" },
        { "transition": "Check_Med_NoDx" }
      ]
    },
    "Diagnose_Pso": { "type": "ConditionOnset", "assign_to_attribute": "pso_condition", "codes": [{ "system": "SNOMED-CT", "code": "9014002", "display": "Psoriasis" }], "direct_transition": "Check_Med_WithDx" },

    "Check_Med_WithDx": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "pso_has_med", "operator": "==", "value": true }, "transition": "Prescribe_Mtx_WithDx" },
        { "transition": "Clear_First_Visit_Flag" }
      ]
    },
    "Prescribe_Mtx_WithDx": { "type": "MedicationOrder", "codes": [{ "system": "RxNorm", "code": "105585", "display": "methotrexate 2.5 MG Oral Tablet" }], "reason": "pso_condition", "direct_transition": "Clear_First_Visit_Flag" },

    "Check_Med_NoDx": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "pso_has_med", "operator": "==", "value": true }, "transition": "Prescribe_Mtx_NoDx" },
        { "transition": "Clear_First_Visit_Flag" }
      ]
    },
    "Prescribe_Mtx_NoDx": { "type": "MedicationOrder", "codes": [{ "system": "RxNorm", "code": "105585", "display": "methotrexate 2.5 MG Oral Tablet" }], "direct_transition": "Clear_First_Visit_Flag" },

    "Clear_First_Visit_Flag": { "type": "SetAttribute", "attribute": "pso_needs_first_visit", "value": false, "direct_transition": "End_Wellness_Encounter" },
    "End_Wellness_Encounter": { "type": "EncounterEnd", "direct_transition": "Followup_Delay" },
    "Followup_Delay": { "type": "Delay", "range": { "low": 6, "high": 12, "unit": "months" }, "direct_transition": "Wellness_Encounter" }
  },
  "gmf_version": 2
}
