{
  "name": "PheKB Asthma Response Inhaled Steroids Control",
  "remarks": [
    "Control: age 4-35 without asthma dx or ICS."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Lower_Guard"
    },
    "Age_Lower_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 4,
        "unit": "years"
      },
      "direct_transition": "Age_Upper_Guard"
    },
    "Age_Upper_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": "<=",
        "quantity": 35,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "aics_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Chronic_obstructive_lung_disease"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 6,
        "high": 12,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Chronic_obstructive_lung_disease": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Chronic_obstructive_lung_disease",
          "distribution": 0.15
        },
        {
          "transition": "Maybe_Mimicker_Allergic_rhinitis",
          "distribution": 0.85
        }
      ]
    },
    "Diagnose_Mimicker_Chronic_obstructive_lung_disease": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "13645005",
          "display": "Chronic obstructive pulmonary disease"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Allergic_rhinitis"
    },
    "Maybe_Mimicker_Allergic_rhinitis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Allergic_rhinitis",
          "distribution": 0.25
        },
        {
          "transition": "Maybe_Mimicker_Cough_variant_asthma",
          "distribution": 0.75
        }
      ]
    },
    "Diagnose_Mimicker_Allergic_rhinitis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "61582004",
          "display": "Allergic rhinitis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Cough_variant_asthma"
    },
    "Maybe_Mimicker_Cough_variant_asthma": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Cough_variant_asthma",
          "distribution": 0.08
        },
        {
          "transition": "Maybe_Mimicker_Vocal_cord_dysfunction",
          "distribution": 0.92
        }
      ]
    },
    "Diagnose_Mimicker_Cough_variant_asthma": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "409663006",
          "display": "Cough variant asthma"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Vocal_cord_dysfunction"
    },
    "Maybe_Mimicker_Vocal_cord_dysfunction": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Vocal_cord_dysfunction",
          "distribution": 0.03
        },
        {
          "transition": "Maybe_Mimicker_Eosinophilic_bronchitis",
          "distribution": 0.97
        }
      ]
    },
    "Diagnose_Mimicker_Vocal_cord_dysfunction": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "134290008",
          "display": "Vocal cord dysfunction"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Eosinophilic_bronchitis"
    },
    "Maybe_Mimicker_Eosinophilic_bronchitis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Eosinophilic_bronchitis",
          "distribution": 0.02
        },
        {
          "transition": "End_Wellness_Encounter",
          "distribution": 0.98
        }
      ]
    },
    "Diagnose_Mimicker_Eosinophilic_bronchitis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "451981000124108",
          "display": "Eosinophilic bronchitis"
        }
      ],
      "direct_transition": "End_Wellness_Encounter"
    }
  },
  "gmf_version": 2
}
