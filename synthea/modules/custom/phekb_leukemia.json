{
  "name": "PheKB Leukemia",
  "remarks": [
    "Custom Synthea module for leukemia.",
    "16th cancer phenotype, first hematologic malignancy. Uses broad 'Leukemia' SNOMED concept covering AML/CML/ALL/CLL.",
    "Single-path: 100% have leukemia dx. Age guard: >=18 (can occur at any age but adult cohort here)."
  ],
  "states": {
    "Initial": { "type": "Initial", "direct_transition": "Age_Guard" },
    "Age_Guard": { "type": "Guard", "allow": { "condition_type": "Age", "operator": ">=", "quantity": 18, "unit": "years" }, "direct_transition": "Set_Leuk_Flag" },
    "Set_Leuk_Flag": { "type": "SetAttribute", "attribute": "leuk_positive", "value": true, "direct_transition": "Set_Needs_First_Visit" },
    "Set_Needs_First_Visit": { "type": "SetAttribute", "attribute": "leuk_needs_first_visit", "value": true, "direct_transition": "Wellness_Encounter" },
    "Wellness_Encounter": { "type": "Encounter", "wellness": true, "direct_transition": "Check_First_Visit" },
    "Check_First_Visit": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "leuk_needs_first_visit", "operator": "==", "value": true }, "transition": "Diagnose_Leuk" },
        { "transition": "End_Wellness_Encounter" }
      ]
    },
    "Diagnose_Leuk": { "type": "ConditionOnset", "assign_to_attribute": "leuk_condition", "codes": [{ "system": "SNOMED-CT", "code": "93143009", "display": "Leukemia, disease" }], "direct_transition": "Clear_First_Visit_Flag" },
    "Clear_First_Visit_Flag": { "type": "SetAttribute", "attribute": "leuk_needs_first_visit", "value": false, "direct_transition": "End_Wellness_Encounter" },
    "End_Wellness_Encounter": { "type": "EncounterEnd", "direct_transition": "Followup_Delay" },
    "Followup_Delay": { "type": "Delay", "range": { "low": 6, "high": 12, "unit": "months" }, "direct_transition": "Wellness_Encounter" }
  },
  "gmf_version": 2
}
