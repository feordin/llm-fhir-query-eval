{
  "name": "PheKB Depression Control",
  "remarks": [
    "Control module for PheKB depression phenotype.",
    "Generates patients who do NOT have depression.",
    "",
    "Controls per PheKB algorithm must:",
    "  - Have no depression diagnosis codes",
    "  - Have no antidepressant medication fills",
    "  - Be adults (age-matched to cases)",
    "",
    "Some controls receive other (non-depression) diagnoses common in primary care",
    "to mimic real adult patients but no depression-spectrum codes."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 18,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "dep_positive",
      "value": false,
      "direct_transition": "Set_Needs_First_Visit"
    },
    "Set_Needs_First_Visit": {
      "type": "SetAttribute",
      "attribute": "dep_needs_first_visit",
      "value": true,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Bipolar_disorder"
    },
    "Check_First_Visit": {
      "type": "Simple",
      "conditional_transition": [
        {
          "condition": {
            "condition_type": "Attribute",
            "attribute": "dep_needs_first_visit",
            "operator": "==",
            "value": true
          },
          "transition": "Maybe_Other_Condition"
        },
        {
          "transition": "End_Wellness_Encounter"
        }
      ]
    },
    "Maybe_Other_Condition": {
      "type": "Simple",
      "remarks": [
        "Some controls get a non-depression condition for realism"
      ],
      "distributed_transition": [
        {
          "transition": "Diagnose_Hypertension",
          "distribution": 0.3
        },
        {
          "transition": "Diagnose_Hyperlipidemia",
          "distribution": 0.25
        },
        {
          "transition": "Clear_First_Visit_Flag",
          "distribution": 0.45
        }
      ]
    },
    "Diagnose_Hypertension": {
      "type": "ConditionOnset",
      "assign_to_attribute": "control_condition",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "59621000",
          "display": "Essential hypertension (disorder)"
        }
      ],
      "direct_transition": "Clear_First_Visit_Flag"
    },
    "Diagnose_Hyperlipidemia": {
      "type": "ConditionOnset",
      "assign_to_attribute": "control_condition",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "55822004",
          "display": "Hyperlipidemia (disorder)"
        }
      ],
      "direct_transition": "Clear_First_Visit_Flag"
    },
    "Clear_First_Visit_Flag": {
      "type": "SetAttribute",
      "attribute": "dep_needs_first_visit",
      "value": false,
      "direct_transition": "End_Wellness_Encounter"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 6,
        "high": 18,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Bipolar_disorder": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Bipolar_disorder",
          "distribution": 0.1
        },
        {
          "transition": "Maybe_Mimicker_Adjustment_disorder",
          "distribution": 0.9
        }
      ]
    },
    "Diagnose_Mimicker_Bipolar_disorder": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "13746004",
          "display": "Bipolar disorder"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Adjustment_disorder"
    },
    "Maybe_Mimicker_Adjustment_disorder": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Adjustment_disorder",
          "distribution": 0.2
        },
        {
          "transition": "Maybe_Mimicker_Hypothyroidism",
          "distribution": 0.8
        }
      ]
    },
    "Diagnose_Mimicker_Adjustment_disorder": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "17226007",
          "display": "Adjustment disorder"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Hypothyroidism"
    },
    "Maybe_Mimicker_Hypothyroidism": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Hypothyroidism",
          "distribution": 0.05
        },
        {
          "transition": "Maybe_Mimicker_Iron_deficiency_anemia",
          "distribution": 0.95
        }
      ]
    },
    "Diagnose_Mimicker_Hypothyroidism": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "40930008",
          "display": "Hypothyroidism"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Iron_deficiency_anemia"
    },
    "Maybe_Mimicker_Iron_deficiency_anemia": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Iron_deficiency_anemia",
          "distribution": 0.1
        },
        {
          "transition": "Check_First_Visit",
          "distribution": 0.9
        }
      ]
    },
    "Diagnose_Mimicker_Iron_deficiency_anemia": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "87522002",
          "display": "Iron deficiency anemia"
        }
      ],
      "direct_transition": "Check_First_Visit"
    }
  },
  "gmf_version": 2
}
