{
  "name": "PheKB Iron Deficiency Anemia Control",
  "remarks": ["Control module for IDA. Generates adult patients with normal Hgb (12-16 g/dL) and normal ferritin (50-200 ng/mL)."],
  "states": {
    "Initial": { "type": "Initial", "direct_transition": "Age_Guard" },
    "Age_Guard": { "type": "Guard", "allow": { "condition_type": "Age", "operator": ">=", "quantity": 18, "unit": "years" }, "direct_transition": "Set_Control_Flag" },
    "Set_Control_Flag": { "type": "SetAttribute", "attribute": "ida_positive", "value": false, "direct_transition": "Wellness_Encounter" },
    "Wellness_Encounter": { "type": "Encounter", "wellness": true, "direct_transition": "Record_Normal_Hgb" },
    "Record_Normal_Hgb": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "g/dL",
      "codes": [{ "system": "LOINC", "code": "718-7", "display": "Hemoglobin [Mass/volume] in Blood" }],
      "range": { "low": 12.5, "high": 16 },
      "direct_transition": "Record_Normal_Ferritin"
    },
    "Record_Normal_Ferritin": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "ng/mL",
      "codes": [{ "system": "LOINC", "code": "2276-4", "display": "Ferritin [Mass/volume] in Serum or Plasma" }],
      "range": { "low": 50, "high": 200 },
      "direct_transition": "End_Wellness_Encounter"
    },
    "End_Wellness_Encounter": { "type": "EncounterEnd", "direct_transition": "Followup_Delay" },
    "Followup_Delay": { "type": "Delay", "range": { "low": 12, "high": 24, "unit": "months" }, "direct_transition": "Wellness_Encounter" }
  },
  "gmf_version": 2
}
