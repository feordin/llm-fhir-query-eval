{
  "name": "PheKB Iron Deficiency Anemia Control",
  "remarks": [
    "Control module for IDA. Generates adult patients with normal Hgb (12-16 g/dL) and normal ferritin (50-200 ng/mL)."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 18,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "ida_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Anemia_of_chronic_disease"
    },
    "Record_Normal_Hgb": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "g/dL",
      "codes": [
        {
          "system": "LOINC",
          "code": "718-7",
          "display": "Hemoglobin [Mass/volume] in Blood"
        }
      ],
      "range": {
        "low": 12.5,
        "high": 16
      },
      "direct_transition": "Record_Normal_Ferritin"
    },
    "Record_Normal_Ferritin": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "ng/mL",
      "codes": [
        {
          "system": "LOINC",
          "code": "2276-4",
          "display": "Ferritin [Mass/volume] in Serum or Plasma"
        }
      ],
      "range": {
        "low": 50,
        "high": 200
      },
      "direct_transition": "End_Wellness_Encounter"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Anemia_of_chronic_disease": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Anemia_of_chronic_disease",
          "distribution": 0.2
        },
        {
          "transition": "Maybe_Mimicker_Thalassemia",
          "distribution": 0.8
        }
      ]
    },
    "Diagnose_Mimicker_Anemia_of_chronic_disease": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "234347009",
          "display": "Anemia of chronic disease"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Thalassemia"
    },
    "Maybe_Mimicker_Thalassemia": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Thalassemia",
          "distribution": 0.05
        },
        {
          "transition": "Maybe_Mimicker_Vitamin_B12_deficiency",
          "distribution": 0.95
        }
      ]
    },
    "Diagnose_Mimicker_Thalassemia": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "40108008",
          "display": "Thalassemia"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Vitamin_B12_deficiency"
    },
    "Maybe_Mimicker_Vitamin_B12_deficiency": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Vitamin_B12_deficiency",
          "distribution": 0.1
        },
        {
          "transition": "Maybe_Mimicker_Folate_deficiency_anemia",
          "distribution": 0.9
        }
      ]
    },
    "Diagnose_Mimicker_Vitamin_B12_deficiency": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "190634004",
          "display": "Cobalamin deficiency"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Folate_deficiency_anemia"
    },
    "Maybe_Mimicker_Folate_deficiency_anemia": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Folate_deficiency_anemia",
          "distribution": 0.05
        },
        {
          "transition": "Record_Normal_Hgb",
          "distribution": 0.95
        }
      ]
    },
    "Diagnose_Mimicker_Folate_deficiency_anemia": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "85649008",
          "display": "Megaloblastic anemia due to folate deficiency"
        }
      ],
      "direct_transition": "Record_Normal_Hgb"
    }
  },
  "gmf_version": 2
}
