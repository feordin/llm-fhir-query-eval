{
  "name": "PheKB Multiple Myeloma",
  "remarks": [
    "Custom Synthea module for multiple myeloma.",
    "18th cancer phenotype, third hematologic malignancy. Plasma cell malignancy.",
    "Single-path: 100% have multiple myeloma dx. Age guard: >=45 (peak incidence 60-70)."
  ],
  "states": {
    "Initial": { "type": "Initial", "direct_transition": "Age_Guard" },
    "Age_Guard": { "type": "Guard", "allow": { "condition_type": "Age", "operator": ">=", "quantity": 45, "unit": "years" }, "direct_transition": "Set_MM_Flag" },
    "Set_MM_Flag": { "type": "SetAttribute", "attribute": "mm_positive", "value": true, "direct_transition": "Set_Needs_First_Visit" },
    "Set_Needs_First_Visit": { "type": "SetAttribute", "attribute": "mm_needs_first_visit", "value": true, "direct_transition": "Wellness_Encounter" },
    "Wellness_Encounter": { "type": "Encounter", "wellness": true, "direct_transition": "Check_First_Visit" },
    "Check_First_Visit": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "mm_needs_first_visit", "operator": "==", "value": true }, "transition": "Diagnose_MM" },
        { "transition": "End_Wellness_Encounter" }
      ]
    },
    "Diagnose_MM": { "type": "ConditionOnset", "assign_to_attribute": "mm_condition", "codes": [{ "system": "SNOMED-CT", "code": "109989006", "display": "Multiple myeloma" }], "direct_transition": "Clear_First_Visit_Flag" },
    "Clear_First_Visit_Flag": { "type": "SetAttribute", "attribute": "mm_needs_first_visit", "value": false, "direct_transition": "End_Wellness_Encounter" },
    "End_Wellness_Encounter": { "type": "EncounterEnd", "direct_transition": "Followup_Delay" },
    "Followup_Delay": { "type": "Delay", "range": { "low": 6, "high": 12, "unit": "months" }, "direct_transition": "Wellness_Encounter" }
  },
  "gmf_version": 2
}
