{
  "name": "PheKB Type 1 Diabetes Control",
  "remarks": [
    "Control module for PheKB type 1 diabetes phenotype.",
    "Generates patients without diabetes (HbA1c < 5.7%, no insulin, no diabetes diagnosis)."
  ],
  "states": {
    "Initial": { "type": "Initial", "direct_transition": "Age_Guard" },
    "Age_Guard": { "type": "Guard", "allow": { "condition_type": "Age", "operator": ">=", "quantity": 12, "unit": "years" }, "direct_transition": "Wellness_Encounter" },
    "Wellness_Encounter": { "type": "Encounter", "wellness": true, "direct_transition": "Record_Normal_HbA1c" },
    "Record_Normal_HbA1c": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "%",
      "codes": [{ "system": "LOINC", "code": "4548-4", "display": "Hemoglobin A1c/Hemoglobin.total in Blood" }],
      "range": { "low": 4.5, "high": 5.5 },
      "direct_transition": "End_Wellness_Encounter"
    },
    "End_Wellness_Encounter": { "type": "EncounterEnd", "direct_transition": "Followup_Delay" },
    "Followup_Delay": { "type": "Delay", "range": { "low": 12, "high": 24, "unit": "months" }, "direct_transition": "Wellness_Encounter" }
  },
  "gmf_version": 2
}
