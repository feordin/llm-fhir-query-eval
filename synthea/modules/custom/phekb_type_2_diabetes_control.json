{
  "name": "PheKB Type 2 Diabetes Control (Non-Diabetic)",
  "remarks": [
    "Control module for T2DM phenotype testing",
    "Generates patients who should NOT match T2DM criteria",
    "",
    "Control Criteria (exclusion from T2DM):",
    "- No diabetes diagnosis codes",
    "- No diabetes medications",
    "- Normal glucose levels (fasting < 100 mg/dL)",
    "- Normal HbA1c (< 5.7%)",
    "",
    "Uses 'wellness: true' encounter pattern to produce FHIR resources.",
    "These patients should NOT be returned by T2DM queries."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },

    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 18,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },

    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "t2dm_control",
      "value": true,
      "direct_transition": "Wellness_Encounter"
    },

    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Record_Normal_HbA1c"
    },

    "Record_Normal_HbA1c": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "%",
      "codes": [
        {
          "system": "LOINC",
          "code": "4548-4",
          "display": "Hemoglobin A1c/Hemoglobin.total in Blood"
        }
      ],
      "range": {
        "low": 4.5,
        "high": 5.6
      },
      "remarks": ["Normal HbA1c < 5.7%"],
      "direct_transition": "Record_Normal_Fasting_Glucose"
    },

    "Record_Normal_Fasting_Glucose": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "mg/dL",
      "codes": [
        {
          "system": "LOINC",
          "code": "1558-6",
          "display": "Fasting glucose [Mass/volume] in Serum or Plasma"
        }
      ],
      "range": {
        "low": 70,
        "high": 99
      },
      "remarks": ["Normal fasting glucose < 100 mg/dL"],
      "direct_transition": "Record_Normal_Random_Glucose"
    },

    "Record_Normal_Random_Glucose": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "mg/dL",
      "codes": [
        {
          "system": "LOINC",
          "code": "2339-0",
          "display": "Glucose [Mass/volume] in Blood"
        }
      ],
      "range": {
        "low": 80,
        "high": 139
      },
      "remarks": ["Normal random glucose < 140 mg/dL"],
      "direct_transition": "Check_Other_Conditions"
    },

    "Check_Other_Conditions": {
      "type": "Simple",
      "remarks": ["Some control patients have non-diabetes conditions for variety"],
      "distributed_transition": [
        {
          "transition": "Diagnose_Hypertension",
          "distribution": 0.30
        },
        {
          "transition": "Diagnose_Hyperlipidemia",
          "distribution": 0.25
        },
        {
          "transition": "End_Wellness_Encounter",
          "distribution": 0.45
        }
      ]
    },

    "Diagnose_Hypertension": {
      "type": "ConditionOnset",
      "assign_to_attribute": "hypertension",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "38341003",
          "display": "Hypertensive disorder"
        }
      ],
      "remarks": ["Non-diabetes condition for control population variety"],
      "direct_transition": "Prescribe_Antihypertensive"
    },

    "Prescribe_Antihypertensive": {
      "type": "MedicationOrder",
      "codes": [
        {
          "system": "RxNorm",
          "code": "314076",
          "display": "lisinopril 10 MG Oral Tablet"
        }
      ],
      "reason": "hypertension",
      "direct_transition": "End_Wellness_Encounter"
    },

    "Diagnose_Hyperlipidemia": {
      "type": "ConditionOnset",
      "assign_to_attribute": "hyperlipidemia",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "55822004",
          "display": "Hyperlipidemia"
        }
      ],
      "remarks": ["Non-diabetes condition for control population variety"],
      "direct_transition": "Prescribe_Statin"
    },

    "Prescribe_Statin": {
      "type": "MedicationOrder",
      "codes": [
        {
          "system": "RxNorm",
          "code": "259255",
          "display": "atorvastatin 20 MG Oral Tablet"
        }
      ],
      "reason": "hyperlipidemia",
      "direct_transition": "End_Wellness_Encounter"
    },

    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Terminal_Control"
    },

    "Terminal_Control": {
      "type": "Terminal",
      "remarks": ["Control patient - should NOT be found by T2DM phenotype query"]
    }
  },
  "gmf_version": 2
}
