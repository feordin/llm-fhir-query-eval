{
  "name": "PheKB Melanoma",
  "remarks": [
    "Custom Synthea module for malignant melanoma.",
    "14th cancer phenotype, first skin cancer. Distinct from squamous/basal cell carcinoma (non-melanoma skin cancer).",
    "Single-path: 100% have melanoma dx. Age guard: >=30."
  ],
  "states": {
    "Initial": { "type": "Initial", "direct_transition": "Age_Guard" },
    "Age_Guard": { "type": "Guard", "allow": { "condition_type": "Age", "operator": ">=", "quantity": 30, "unit": "years" }, "direct_transition": "Set_Mel_Flag" },
    "Set_Mel_Flag": { "type": "SetAttribute", "attribute": "mel_positive", "value": true, "direct_transition": "Set_Needs_First_Visit" },
    "Set_Needs_First_Visit": { "type": "SetAttribute", "attribute": "mel_needs_first_visit", "value": true, "direct_transition": "Wellness_Encounter" },
    "Wellness_Encounter": { "type": "Encounter", "wellness": true, "direct_transition": "Check_First_Visit" },
    "Check_First_Visit": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "mel_needs_first_visit", "operator": "==", "value": true }, "transition": "Diagnose_Mel" },
        { "transition": "End_Wellness_Encounter" }
      ]
    },
    "Diagnose_Mel": { "type": "ConditionOnset", "assign_to_attribute": "mel_condition", "codes": [{ "system": "SNOMED-CT", "code": "372244006", "display": "Malignant melanoma" }], "direct_transition": "Clear_First_Visit_Flag" },
    "Clear_First_Visit_Flag": { "type": "SetAttribute", "attribute": "mel_needs_first_visit", "value": false, "direct_transition": "End_Wellness_Encounter" },
    "End_Wellness_Encounter": { "type": "EncounterEnd", "direct_transition": "Followup_Delay" },
    "Followup_Delay": { "type": "Delay", "range": { "low": 6, "high": 12, "unit": "months" }, "direct_transition": "Wellness_Encounter" }
  },
  "gmf_version": 2
}
