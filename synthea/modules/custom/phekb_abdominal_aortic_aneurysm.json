    "Prescribe_Antihypertensive_AAA": {
      "type": "MedicationOrder",
      "remarks": ["Beta-blockers commonly prescribed for AAA management"],
      "codes": [
        {
          "system": "RxNorm",
          "code": "6918",
          "display": "Metoprolol"
        }
      ],
      "reason": "aaa_condition",
      "direct_transition": "Prescribe_Statin_AAA"
    },

    "Prescribe_Statin_AAA": {
      "type": "MedicationOrder",
      "remarks": ["Statins for cardiovascular risk reduction in AAA patients"],
      "codes": [
        {
          "system": "RxNorm",
          "code": "36567",
          "display": "Atorvastatin"
        }
      ],
      "reason": "aaa_condition",
      "direct_transition": "End_Type3_Second_Encounter"
