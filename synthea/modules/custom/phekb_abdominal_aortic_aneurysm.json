{
  "name": "PheKB Abdominal Aortic Aneurysm (AAA)",
  "remarks": [
    "Synthea module from PheKB phenotype: abdominal-aortic-aneurysm-aaa",
    "Based on Geisinger/eMERGE AAA algorithm",
    "Generates patients matching AAA phenotype criteria for FHIR query evaluation",
    "",
    "Case Types:",
    "- Case Type 1: AAA repair procedure (EVAR or open surgical repair)",
    "- Case Type 2: >= 1 vascular clinic visit with ruptured AAA (ICD-10 I71.3 / SNOMED 14336007)",
    "- Case Type 3: >= 2 vascular clinic visits with unruptured AAA (ICD-10 I71.4 / SNOMED 233985008)",
    "",
    "Age requirement: 40-89 years",
    "Exclusions: Marfan syndrome, Ehlers-Danlos, thoracic aneurysms, Moyamoya, fibromuscular dysplasia",
    "",
    "SNOMED codes verified via UMLS 2025AB:",
    "- 233985008 = Abdominal aortic aneurysm (general/unruptured)",
    "- 14336007 = Ruptured abdominal aortic aneurysm (crosswalks to ICD-10 I71.3)",
    "- 441788006 = Endovascular repair of abdominal aortic aneurysm",
    "- 24165007 = Open repair of abdominal aortic aneurysm with graft"
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "remarks": ["All patients start here"],
      "direct_transition": "Age_Guard"
    },

    "Age_Guard": {
      "type": "Guard",
      "remarks": ["AAA phenotype requires age 40-89"],
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 40,
        "unit": "years"
      },
      "direct_transition": "Case_Type_Selection"
    },

    "Case_Type_Selection": {
      "type": "Simple",
      "remarks": [
        "Distribute patients across the three AAA case types",
        "Case Type 1 (repair) is the strongest evidence",
        "All positive patients get AAA diagnosis + one case type pathway"
      ],
      "distributed_transition": [
        {
          "transition": "Wellness_Encounter_Type1",
          "distribution": 0.40,
          "remarks": ["40% Case Type 1: AAA repair procedure (with unruptured diagnosis)"]
        },
        {
          "transition": "Wellness_Encounter_Type2",
          "distribution": 0.25,
          "remarks": ["25% Case Type 2: ruptured AAA diagnosis"]
        },
        {
          "transition": "Wellness_Encounter_Type3_First",
          "distribution": 0.35,
          "remarks": ["35% Case Type 3: multiple unruptured AAA encounters"]
        }
      ]
    },

    "Wellness_Encounter_Type1": {
      "type": "Encounter",
      "wellness": true,
      "remarks": ["Wellness encounter for Case Type 1 - diagnosis then repair"],
      "direct_transition": "AAA_Diagnosis_Unruptured"
    },

    "AAA_Diagnosis_Unruptured": {
      "type": "ConditionOnset",
      "remarks": ["Unruptured AAA diagnosis for Case Type 1 patients"],
      "assign_to_attribute": "aaa_condition",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "233985008",
          "display": "Abdominal aortic aneurysm"
        }
      ],
      "direct_transition": "End_Encounter_Type1"
    },

    "End_Encounter_Type1": {
      "type": "EncounterEnd",
      "direct_transition": "Delay_Before_Repair"
    },

    "Delay_Before_Repair": {
      "type": "Delay",
      "range": {
        "low": 1,
        "high": 6,
        "unit": "months"
      },
      "direct_transition": "Repair_Encounter"
    },

    "Repair_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "reason": "aaa_condition",
      "remarks": ["Surgical encounter for AAA repair - wellness:true for FHIR export"],
      "direct_transition": "AAA_Repair_Type_Selection"
    },

    "AAA_Repair_Type_Selection": {
      "type": "Simple",
      "remarks": ["Select between endovascular (EVAR) and open surgical repair"],
      "distributed_transition": [
        {
          "transition": "Endovascular_Repair_EVAR",
          "distribution": 0.70,
          "remarks": ["70% get endovascular repair (EVAR) - more common modern approach"]
        },
        {
          "transition": "Open_Surgical_Repair",
          "distribution": 0.30,
          "remarks": ["30% get open surgical repair"]
        }
      ]
    },

    "Endovascular_Repair_EVAR": {
      "type": "Procedure",
      "reason": "aaa_condition",
      "remarks": ["Endovascular AAA repair (EVAR)"],
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "441788006",
          "display": "Endovascular repair of abdominal aortic aneurysm"
        }
      ],
      "duration": {
        "low": 90,
        "high": 180,
        "unit": "minutes"
      },
      "direct_transition": "End_Repair_Encounter"
    },

    "Open_Surgical_Repair": {
      "type": "Procedure",
      "reason": "aaa_condition",
      "remarks": ["Open AAA repair with graft"],
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "24165007",
          "display": "Open repair of abdominal aortic aneurysm with graft"
        }
      ],
      "duration": {
        "low": 120,
        "high": 240,
        "unit": "minutes"
      },
      "direct_transition": "End_Repair_Encounter"
    },

    "End_Repair_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Post_Repair_Followup_Delay"
    },

    "Post_Repair_Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 1,
        "high": 6,
        "unit": "months"
      },
      "direct_transition": "Post_Repair_Followup"
    },

    "Post_Repair_Followup": {
      "type": "Encounter",
      "encounter_class": "ambulatory",
      "reason": "aaa_condition",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "185347001",
          "display": "Encounter for problem"
        }
      ],
      "direct_transition": "End_Followup_Encounter"
    },

    "End_Followup_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Terminal_AAA_Case"
    },

    "Wellness_Encounter_Type2": {
      "type": "Encounter",
      "wellness": true,
      "remarks": ["Encounter for ruptured AAA - Case Type 2. Uses wellness:true for FHIR export."],
      "direct_transition": "AAA_Diagnosis_Ruptured"
    },

    "AAA_Diagnosis_Ruptured": {
      "type": "ConditionOnset",
      "remarks": ["Ruptured AAA diagnosis for Case Type 2 patients. SNOMED 14336007 verified via UMLS crosswalk from ICD-10 I71.3"],
      "assign_to_attribute": "aaa_condition",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "14336007",
          "display": "Ruptured abdominal aortic aneurysm"
        }
      ],
      "direct_transition": "Emergency_Repair"
    },

    "Emergency_Repair": {
      "type": "Procedure",
      "reason": "aaa_condition",
      "remarks": ["Emergency AAA repair for rupture"],
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "441788006",
          "display": "Endovascular repair of abdominal aortic aneurysm"
        }
      ],
      "duration": {
        "low": 90,
        "high": 180,
        "unit": "minutes"
      },
      "direct_transition": "End_Emergency_Encounter"
    },

    "End_Emergency_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Post_Emergency_Recovery"
    },

    "Post_Emergency_Recovery": {
      "type": "Delay",
      "range": {
        "low": 2,
        "high": 8,
        "unit": "weeks"
      },
      "direct_transition": "Post_Emergency_Followup"
    },

    "Post_Emergency_Followup": {
      "type": "Encounter",
      "encounter_class": "ambulatory",
      "reason": "aaa_condition",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "185347001",
          "display": "Encounter for problem"
        }
      ],
      "direct_transition": "End_Post_Emergency_Followup"
    },

    "End_Post_Emergency_Followup": {
      "type": "EncounterEnd",
      "direct_transition": "Terminal_AAA_Case"
    },

    "Wellness_Encounter_Type3_First": {
      "type": "Encounter",
      "wellness": true,
      "remarks": ["First vascular clinic visit for Case Type 3 - uses wellness encounter"],
      "direct_transition": "AAA_Diagnosis_Unruptured_Type3"
    },

    "AAA_Diagnosis_Unruptured_Type3": {
      "type": "ConditionOnset",
      "remarks": ["Unruptured AAA for Case Type 3 - multiple vascular clinic visits"],
      "assign_to_attribute": "aaa_condition",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "233985008",
          "display": "Abdominal aortic aneurysm"
        }
      ],
      "direct_transition": "End_Type3_First_Encounter"
    },

    "End_Type3_First_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Wait_Between_Type3_Visits"
    },

    "Wait_Between_Type3_Visits": {
      "type": "Delay",
      "remarks": ["Surveillance interval between vascular clinic visits"],
      "range": {
        "low": 3,
        "high": 12,
        "unit": "months"
      },
      "direct_transition": "Vascular_Encounter_Type3_Second"
    },

    "Vascular_Encounter_Type3_Second": {
      "type": "Encounter",
      "encounter_class": "ambulatory",
      "reason": "aaa_condition",
      "remarks": ["Second vascular clinic visit - satisfies Case Type 3 (>= 2 visits)"],
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "185347001",
          "display": "Encounter for problem"
        }
      ],
      "direct_transition": "Prescribe_Antihypertensive_AAA"
    },

    "Prescribe_Antihypertensive_AAA": {
      "type": "MedicationOrder",
      "remarks": ["Beta-blockers commonly prescribed for AAA management - SCD code"],
      "codes": [
        {
          "system": "RxNorm",
          "code": "866514",
          "display": "metoprolol tartrate 50 MG Oral Tablet"
        }
      ],
      "reason": "aaa_condition",
      "direct_transition": "Prescribe_Statin_AAA"
    },

    "Prescribe_Statin_AAA": {
      "type": "MedicationOrder",
      "remarks": ["Statins for cardiovascular risk reduction - SCD code"],
      "codes": [
        {
          "system": "RxNorm",
          "code": "259255",
          "display": "atorvastatin 20 MG Oral Tablet"
        }
      ],
      "reason": "aaa_condition",
      "direct_transition": "End_Type3_Second_Encounter"
    },

    "End_Type3_Second_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Terminal_AAA_Case"
    },

    "Terminal_AAA_Case": {
      "type": "Terminal",
      "remarks": ["AAA positive case - should be found by phenotype query"]
    }
  },
  "gmf_version": 2
}
