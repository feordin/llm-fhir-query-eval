{
  "name": "PheKB BPH Control",
  "remarks": [
    "Control module for BPH. Generates male patients age 40+ without BPH, BPH meds, or TURP."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Sex_Guard"
    },
    "Sex_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Gender",
        "gender": "M"
      },
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 40,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "bph_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Malignant_neoplasm_of_prostate"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Malignant_neoplasm_of_prostate": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Malignant_neoplasm_of_prostate",
          "distribution": 0.12
        },
        {
          "transition": "Maybe_Mimicker_Overactive_urinary_bladder",
          "distribution": 0.88
        }
      ]
    },
    "Diagnose_Mimicker_Malignant_neoplasm_of_prostate": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "399068003",
          "display": "Malignant neoplasm of prostate"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Overactive_urinary_bladder"
    },
    "Maybe_Mimicker_Overactive_urinary_bladder": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Overactive_urinary_bladder",
          "distribution": 0.15
        },
        {
          "transition": "Maybe_Mimicker_Recurrent_urinary_tract_infection",
          "distribution": 0.85
        }
      ]
    },
    "Diagnose_Mimicker_Overactive_urinary_bladder": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "786457000",
          "display": "Overactive urinary bladder"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Recurrent_urinary_tract_infection"
    },
    "Maybe_Mimicker_Recurrent_urinary_tract_infection": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Recurrent_urinary_tract_infection",
          "distribution": 0.1
        },
        {
          "transition": "Maybe_Mimicker_Prostatitis",
          "distribution": 0.9
        }
      ]
    },
    "Diagnose_Mimicker_Recurrent_urinary_tract_infection": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "197927001",
          "display": "Recurrent urinary tract infection"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Prostatitis"
    },
    "Maybe_Mimicker_Prostatitis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Prostatitis",
          "distribution": 0.07
        },
        {
          "transition": "Maybe_Mimicker_Urethral_stricture",
          "distribution": 0.9299999999999999
        }
      ]
    },
    "Diagnose_Mimicker_Prostatitis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "9713002",
          "display": "Prostatitis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Urethral_stricture"
    },
    "Maybe_Mimicker_Urethral_stricture": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Urethral_stricture",
          "distribution": 0.04
        },
        {
          "transition": "End_Wellness_Encounter",
          "distribution": 0.96
        }
      ]
    },
    "Diagnose_Mimicker_Urethral_stricture": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "76618002",
          "display": "Urethral stricture"
        }
      ],
      "direct_transition": "End_Wellness_Encounter"
    }
  },
  "gmf_version": 2
}
