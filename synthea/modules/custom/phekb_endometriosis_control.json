{
  "name": "PheKB Endometriosis Control",
  "remarks": [
    "Control module. Generates female patients age 18-50 without endometriosis dx or leuprolide."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Sex_Guard"
    },
    "Sex_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Gender",
        "gender": "F"
      },
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 18,
        "unit": "years"
      },
      "direct_transition": "Age_Upper_Guard"
    },
    "Age_Upper_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": "<=",
        "quantity": 50,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "endo_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Cyst_of_ovary"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Cyst_of_ovary": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Cyst_of_ovary",
          "distribution": 0.2
        },
        {
          "transition": "Maybe_Mimicker_Leiomyoma",
          "distribution": 0.8
        }
      ]
    },
    "Diagnose_Mimicker_Cyst_of_ovary": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "79883001",
          "display": "Cyst of ovary"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Leiomyoma"
    },
    "Maybe_Mimicker_Leiomyoma": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Leiomyoma",
          "distribution": 0.15
        },
        {
          "transition": "Maybe_Mimicker_Irritable_bowel_syndrome",
          "distribution": 0.85
        }
      ]
    },
    "Diagnose_Mimicker_Leiomyoma": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "146801000119103",
          "display": "Leiomyoma"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Irritable_bowel_syndrome"
    },
    "Maybe_Mimicker_Irritable_bowel_syndrome": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Irritable_bowel_syndrome",
          "distribution": 0.2
        },
        {
          "transition": "Maybe_Mimicker_Uterine_adenomyosis",
          "distribution": 0.8
        }
      ]
    },
    "Diagnose_Mimicker_Irritable_bowel_syndrome": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "10743008",
          "display": "Irritable bowel syndrome"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Uterine_adenomyosis"
    },
    "Maybe_Mimicker_Uterine_adenomyosis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Uterine_adenomyosis",
          "distribution": 0.08
        },
        {
          "transition": "Maybe_Mimicker_Female_pelvic_inflammatory_disease",
          "distribution": 0.92
        }
      ]
    },
    "Diagnose_Mimicker_Uterine_adenomyosis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "784314006",
          "display": "Uterine adenomyosis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Female_pelvic_inflammatory_disease"
    },
    "Maybe_Mimicker_Female_pelvic_inflammatory_disease": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Female_pelvic_inflammatory_disease",
          "distribution": 0.05
        },
        {
          "transition": "End_Wellness_Encounter",
          "distribution": 0.95
        }
      ]
    },
    "Diagnose_Mimicker_Female_pelvic_inflammatory_disease": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "198130006",
          "display": "Female pelvic inflammatory disease"
        }
      ],
      "direct_transition": "End_Wellness_Encounter"
    }
  },
  "gmf_version": 2
}
