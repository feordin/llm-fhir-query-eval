{
  "name": "PheKB HIV Control",
  "remarks": [
    "Control module for PheKB HIV phenotype.",
    "Generates patients without HIV (no dx, no ART, normal CD4 600-1200)."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 25,
        "unit": "years"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Infectious_mononucleosis"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Infectious_mononucleosis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Infectious_mononucleosis",
          "distribution": 0.1
        },
        {
          "transition": "Maybe_Mimicker_Type_B_viral_hepatitis",
          "distribution": 0.9
        }
      ]
    },
    "Diagnose_Mimicker_Infectious_mononucleosis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "271558008",
          "display": "Infectious mononucleosis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Type_B_viral_hepatitis"
    },
    "Maybe_Mimicker_Type_B_viral_hepatitis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Type_B_viral_hepatitis",
          "distribution": 0.08
        },
        {
          "transition": "Maybe_Mimicker_Tuberculosis",
          "distribution": 0.92
        }
      ]
    },
    "Diagnose_Mimicker_Type_B_viral_hepatitis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "66071002",
          "display": "Type B viral hepatitis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Tuberculosis"
    },
    "Maybe_Mimicker_Tuberculosis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Tuberculosis",
          "distribution": 0.05
        },
        {
          "transition": "Maybe_Mimicker_Syphilis",
          "distribution": 0.95
        }
      ]
    },
    "Diagnose_Mimicker_Tuberculosis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "56717001",
          "display": "Tuberculosis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Syphilis"
    },
    "Maybe_Mimicker_Syphilis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Syphilis",
          "distribution": 0.06
        },
        {
          "transition": "Maybe_Mimicker_Influenza",
          "distribution": 0.94
        }
      ]
