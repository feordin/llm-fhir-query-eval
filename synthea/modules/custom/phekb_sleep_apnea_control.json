{
  "name": "PheKB Sleep Apnea Control",
  "remarks": [
    "Control module for PheKB Sleep Apnea phenotype.",
    "Generates patients who do NOT have sleep apnea.",
    "",
    "Controls have:",
    "  - No sleep apnea diagnosis",
    "  - No polysomnography procedure",
    "  - Normal Wellness encounters only"
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 30,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "osa_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Insomnia_disorder"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Insomnia_disorder": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Insomnia_disorder",
          "distribution": 0.3
        },
        {
          "transition": "Maybe_Mimicker_Sleep_disorder",
          "distribution": 0.7
        }
      ]
    },
    "Diagnose_Mimicker_Insomnia_disorder": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "193462001",
          "display": "Insomnia"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Sleep_disorder"
    },
    "Maybe_Mimicker_Sleep_disorder": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Sleep_disorder",
          "distribution": 0.2
        },
        {
          "transition": "Maybe_Mimicker_Restless_legs_syndrome",
          "distribution": 0.8
        }
      ]
    },
    "Diagnose_Mimicker_Sleep_disorder": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "39898005",
          "display": "Sleep disorder"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Restless_legs_syndrome"
    },
    "Maybe_Mimicker_Restless_legs_syndrome": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Restless_legs_syndrome",
          "distribution": 0.1
        },
        {
          "transition": "Maybe_Mimicker_Depressive_disorder",
          "distribution": 0.9
        }
      ]
    },
    "Diagnose_Mimicker_Restless_legs_syndrome": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "32914008",
          "display": "Restless legs syndrome"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Depressive_disorder"
    },
    "Maybe_Mimicker_Depressive_disorder": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Depressive_disorder",
          "distribution": 0.2
        },
        {
          "transition": "Maybe_Mimicker_Narcolepsy",
          "distribution": 0.8
        }
      ]
    },
    "Diagnose_Mimicker_Depressive_disorder": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "35489007",
          "display": "Depressive disorder"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Narcolepsy"
    },
    "Maybe_Mimicker_Narcolepsy": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Narcolepsy",
          "distribution": 0.02
        },
        {
          "transition": "End_Wellness_Encounter",
          "distribution": 0.98
        }
      ]
    },
    "Diagnose_Mimicker_Narcolepsy": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "60380001",
          "display": "Narcolepsy"
        }
      ],
      "direct_transition": "End_Wellness_Encounter"
    }
  },
  "gmf_version": 2
}
