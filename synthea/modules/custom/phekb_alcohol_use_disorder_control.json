{
  "name": "PheKB Alcohol Use Disorder Control",
  "remarks": [
    "Control module for AUD. Generates adult patients without AUD dx or naltrexone."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 18,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "aud_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Tobacco_use_disorder"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Tobacco_use_disorder": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Tobacco_use_disorder",
          "distribution": 0.3
        },
        {
          "transition": "Maybe_Mimicker_Major_depressive_disorder",
          "distribution": 0.7
        }
      ]
    },
    "Diagnose_Mimicker_Tobacco_use_disorder": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "1345156008",
          "display": "Harmful pattern of use of tobacco"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Major_depressive_disorder"
    },
    "Maybe_Mimicker_Major_depressive_disorder": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Major_depressive_disorder",
          "distribution": 0.2
        },
        {
          "transition": "Maybe_Mimicker_Generalized_anxiety_disorder",
          "distribution": 0.8
        }
      ]
    },
    "Diagnose_Mimicker_Major_depressive_disorder": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "370143000",
          "display": "Major depressive disorder"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Generalized_anxiety_disorder"
    },
    "Maybe_Mimicker_Generalized_anxiety_disorder": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Generalized_anxiety_disorder",
          "distribution": 0.15
        },
        {
          "transition": "Maybe_Mimicker_Cannabis_use_disorder",
          "distribution": 0.85
        }
      ]
    },
    "Diagnose_Mimicker_Generalized_anxiety_disorder": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "21897009",
          "display": "Generalized anxiety disorder"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Cannabis_use_disorder"
    },
    "Maybe_Mimicker_Cannabis_use_disorder": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Cannabis_use_disorder",
          "distribution": 0.05
        },
        {
          "transition": "Maybe_Mimicker_Sedative_dependence",
          "distribution": 0.95
        }
      ]
    },
    "Diagnose_Mimicker_Cannabis_use_disorder": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "1336200007",
          "display": "Cannabis use disorder"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Sedative_dependence"
    },
    "Maybe_Mimicker_Sedative_dependence": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Sedative_dependence",
          "distribution": 0.03
        },
        {
          "transition": "End_Wellness_Encounter",
          "distribution": 0.97
        }
      ]
    },
    "Diagnose_Mimicker_Sedative_dependence": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "427327003",
          "display": "Sedative dependence"
        }
      ],
      "direct_transition": "End_Wellness_Encounter"
    }
  },
  "gmf_version": 2
}
