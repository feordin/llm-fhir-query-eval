{
  "name": "PheKB Esophageal Cancer Control",
  "remarks": [
    "Control module for esophageal cancer. Generates patients age 50+ without esophageal cancer dx."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 50,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "esoph_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Gastroesophageal_reflux_disease"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Gastroesophageal_reflux_disease": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Gastroesophageal_reflux_disease",
          "distribution": 0.3
        },
        {
          "transition": "Maybe_Mimicker_Barrett_s_esophagus",
          "distribution": 0.7
        }
      ]
    },
    "Diagnose_Mimicker_Gastroesophageal_reflux_disease": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "235595009",
          "display": "Gastroesophageal reflux disease"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Barrett_s_esophagus"
    },
    "Maybe_Mimicker_Barrett_s_esophagus": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Barrett_s_esophagus",
          "distribution": 0.08
        },
        {
          "transition": "Maybe_Mimicker_Esophagitis",
          "distribution": 0.92
        }
      ]
    },
    "Diagnose_Mimicker_Barrett_s_esophagus": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "302914006",
          "display": "Barrett's esophagus"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Esophagitis"
    },
    "Maybe_Mimicker_Esophagitis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Esophagitis",
          "distribution": 0.15
        },
        {
          "transition": "Maybe_Mimicker_Stricture_of_esophagus",
          "distribution": 0.85
        }
      ]
    },
    "Diagnose_Mimicker_Esophagitis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "16761005",
          "display": "Esophagitis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Stricture_of_esophagus"
    },
    "Maybe_Mimicker_Stricture_of_esophagus": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Stricture_of_esophagus",
          "distribution": 0.05
        },
        {
          "transition": "Maybe_Mimicker_Achalasia_of_esophagus",
          "distribution": 0.95
        }
      ]
    },
    "Diagnose_Mimicker_Stricture_of_esophagus": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "63305008",
          "display": "Stricture of esophagus"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Achalasia_of_esophagus"
    },
    "Maybe_Mimicker_Achalasia_of_esophagus": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Achalasia_of_esophagus",
          "distribution": 0.02
        },
        {
          "transition": "End_Wellness_Encounter",
          "distribution": 0.98
        }
      ]
    },
    "Diagnose_Mimicker_Achalasia_of_esophagus": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "45564002",
          "display": "Achalasia of esophagus"
        }
      ],
      "direct_transition": "End_Wellness_Encounter"
    }
  },
  "gmf_version": 2
}
