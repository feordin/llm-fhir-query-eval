{
  "name": "PheKB Psoriasis Control",
  "remarks": [
    "Control module. Generates patients age 18+ without psoriasis dx or methotrexate."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 18,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "pso_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Atopic_dermatitis"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Atopic_dermatitis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Atopic_dermatitis",
          "distribution": 0.15
        },
        {
          "transition": "Maybe_Mimicker_Seborrheic_dermatitis",
          "distribution": 0.85
        }
      ]
    },
    "Diagnose_Mimicker_Atopic_dermatitis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "24079001",
          "display": "Atopic dermatitis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Seborrheic_dermatitis"
    },
    "Maybe_Mimicker_Seborrheic_dermatitis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Seborrheic_dermatitis",
          "distribution": 0.15
        },
        {
          "transition": "Maybe_Mimicker_Tinea_corporis",
          "distribution": 0.85
        }
      ]
    },
    "Diagnose_Mimicker_Seborrheic_dermatitis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "50563003",
          "display": "Seborrheic dermatitis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Tinea_corporis"
    },
    "Maybe_Mimicker_Tinea_corporis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Tinea_corporis",
          "distribution": 0.05
        },
        {
          "transition": "End_Wellness_Encounter",
          "distribution": 0.95
        }
      ]
    },
    "Diagnose_Mimicker_Tinea_corporis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "84849002",
          "display": "Tinea corporis"
        }
      ],
      "direct_transition": "End_Wellness_Encounter"
    }
  },
  "gmf_version": 2
}
