{
  "name": "PheKB Glaucoma",
  "remarks": [
    "Custom Synthea module for glaucoma.",
    "Second ophthalmology phenotype (after cataracts + DR). First eye-drop medication phenotype.",
    "",
    "Generates THREE patient paths:",
    "  Path A (60%): Glaucoma dx + timolol Rx (typical IOP-lowering therapy)",
    "  Path B (25%): Glaucoma dx, no medication recorded (mild/observational)",
    "  Path C (15%): Timolol only, no glaucoma dx (TRICKY — empirical IOP-lowering)",
    "",
    "Diagnosis SNOMED variation:",
    "  50% Open-angle glaucoma (84494001) — most common",
    "  30% Glaucoma (23986001) — broader concept",
    "  20% Primary angle-closure glaucoma (392288006) — acute/emergent",
    "",
    "Age guard: >=40 (glaucoma risk increases with age)."
  ],
  "states": {
    "Initial": { "type": "Initial", "direct_transition": "Age_Guard" },
    "Age_Guard": { "type": "Guard", "allow": { "condition_type": "Age", "operator": ">=", "quantity": 40, "unit": "years" }, "direct_transition": "Set_Glauc_Flag" },
    "Set_Glauc_Flag": { "type": "SetAttribute", "attribute": "glauc_positive", "value": true, "direct_transition": "Choose_Patient_Path" },
    "Choose_Patient_Path": {
      "type": "Simple",
      "distributed_transition": [
        { "transition": "Set_Path_A", "distribution": 0.60 },
        { "transition": "Set_Path_B", "distribution": 0.25 },
        { "transition": "Set_Path_C", "distribution": 0.15 }
      ]
    },
    "Set_Path_A": { "type": "SetAttribute", "attribute": "glauc_has_dx", "value": true, "direct_transition": "Set_Path_A_Med" },
    "Set_Path_A_Med": { "type": "SetAttribute", "attribute": "glauc_has_med", "value": true, "direct_transition": "Choose_Subtype" },
    "Set_Path_B": { "type": "SetAttribute", "attribute": "glauc_has_dx", "value": true, "direct_transition": "Set_Path_B_Med" },
    "Set_Path_B_Med": { "type": "SetAttribute", "attribute": "glauc_has_med", "value": false, "direct_transition": "Choose_Subtype" },
    "Set_Path_C": { "type": "SetAttribute", "remarks": ["TRICKY: timolol without glaucoma dx"], "attribute": "glauc_has_dx", "value": false, "direct_transition": "Set_Path_C_Med" },
    "Set_Path_C_Med": { "type": "SetAttribute", "attribute": "glauc_has_med", "value": true, "direct_transition": "Choose_Subtype" },

    "Choose_Subtype": {
      "type": "Simple",
      "distributed_transition": [
        { "transition": "Set_Subtype_OAG", "distribution": 0.50 },
        { "transition": "Set_Subtype_Glauc", "distribution": 0.30 },
        { "transition": "Set_Subtype_PACG", "distribution": 0.20 }
      ]
    },
    "Set_Subtype_OAG": { "type": "SetAttribute", "attribute": "glauc_subtype", "value": "oag", "direct_transition": "Set_Needs_First_Visit" },
    "Set_Subtype_Glauc": { "type": "SetAttribute", "attribute": "glauc_subtype", "value": "glauc", "direct_transition": "Set_Needs_First_Visit" },
    "Set_Subtype_PACG": { "type": "SetAttribute", "attribute": "glauc_subtype", "value": "pacg", "direct_transition": "Set_Needs_First_Visit" },

    "Set_Needs_First_Visit": { "type": "SetAttribute", "attribute": "glauc_needs_first_visit", "value": true, "direct_transition": "Wellness_Encounter" },
    "Wellness_Encounter": { "type": "Encounter", "wellness": true, "direct_transition": "Check_First_Visit" },
    "Check_First_Visit": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "glauc_needs_first_visit", "operator": "==", "value": true }, "transition": "Check_Has_Diagnosis" },
        { "transition": "End_Wellness_Encounter" }
      ]
    },
    "Check_Has_Diagnosis": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "glauc_has_dx", "operator": "==", "value": true }, "transition": "Route_By_Subtype" },
        { "transition": "Check_Med_NoDx" }
      ]
    },
    "Route_By_Subtype": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "glauc_subtype", "operator": "==", "value": "oag" }, "transition": "Diagnose_OAG" },
        { "condition": { "condition_type": "Attribute", "attribute": "glauc_subtype", "operator": "==", "value": "glauc" }, "transition": "Diagnose_Glauc" },
        { "transition": "Diagnose_PACG" }
      ]
    },
    "Diagnose_OAG": { "type": "ConditionOnset", "assign_to_attribute": "glauc_condition", "codes": [{ "system": "SNOMED-CT", "code": "84494001", "display": "Open-angle glaucoma" }], "direct_transition": "Check_Med_WithDx" },
    "Diagnose_Glauc": { "type": "ConditionOnset", "assign_to_attribute": "glauc_condition", "codes": [{ "system": "SNOMED-CT", "code": "23986001", "display": "Glaucoma" }], "direct_transition": "Check_Med_WithDx" },
    "Diagnose_PACG": { "type": "ConditionOnset", "assign_to_attribute": "glauc_condition", "codes": [{ "system": "SNOMED-CT", "code": "392288006", "display": "Primary angle-closure glaucoma" }], "direct_transition": "Check_Med_WithDx" },

    "Check_Med_WithDx": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "glauc_has_med", "operator": "==", "value": true }, "transition": "Prescribe_Timolol_WithDx" },
        { "transition": "Clear_First_Visit_Flag" }
      ]
    },
    "Prescribe_Timolol_WithDx": { "type": "MedicationOrder", "codes": [{ "system": "RxNorm", "code": "10600", "display": "timolol" }], "reason": "glauc_condition", "direct_transition": "Clear_First_Visit_Flag" },

    "Check_Med_NoDx": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "glauc_has_med", "operator": "==", "value": true }, "transition": "Prescribe_Timolol_NoDx" },
        { "transition": "Clear_First_Visit_Flag" }
      ]
    },
    "Prescribe_Timolol_NoDx": { "type": "MedicationOrder", "codes": [{ "system": "RxNorm", "code": "10600", "display": "timolol" }], "direct_transition": "Clear_First_Visit_Flag" },

    "Clear_First_Visit_Flag": { "type": "SetAttribute", "attribute": "glauc_needs_first_visit", "value": false, "direct_transition": "End_Wellness_Encounter" },
    "End_Wellness_Encounter": { "type": "EncounterEnd", "direct_transition": "Followup_Delay" },
    "Followup_Delay": { "type": "Delay", "range": { "low": 6, "high": 12, "unit": "months" }, "direct_transition": "Wellness_Encounter" }
  },
  "gmf_version": 2
}
