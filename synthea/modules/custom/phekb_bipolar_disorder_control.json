{
  "name": "PheKB Bipolar Disorder Control",
  "remarks": [
    "Control module for bipolar disorder. Generates adult patients without bipolar dx or mood-stabilizer Rx."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 18,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "bipolar_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Major_depressive_disorder"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Major_depressive_disorder": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Major_depressive_disorder",
          "distribution": 0.3
        },
        {
          "transition": "Maybe_Mimicker_Cyclothymic_disorder",
          "distribution": 0.7
        }
      ]
    },
    "Diagnose_Mimicker_Major_depressive_disorder": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "370143000",
          "display": "Major depressive disorder"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Cyclothymic_disorder"
    },
    "Maybe_Mimicker_Cyclothymic_disorder": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Cyclothymic_disorder",
          "distribution": 0.05
        },
        {
          "transition": "Maybe_Mimicker_Borderline_personality_disorder",
          "distribution": 0.95
        }
      ]
    },
    "Diagnose_Mimicker_Cyclothymic_disorder": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "76105009",
          "display": "Cyclothymia"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Borderline_personality_disorder"
    },
    "Maybe_Mimicker_Borderline_personality_disorder": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Borderline_personality_disorder",
          "distribution": 0.1
        },
        {
          "transition": "End_Wellness_Encounter",
          "distribution": 0.9
        }
      ]
    },
    "Diagnose_Mimicker_Borderline_personality_disorder": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "20010003",
          "display": "Borderline personality disorder"
        }
      ],
      "direct_transition": "End_Wellness_Encounter"
    }
  },
  "gmf_version": 2
}
