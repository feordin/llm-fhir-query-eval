{
  "name": "PheKB Diabetic Retinopathy Control",
  "remarks": [
    "Control module for PheKB diabetic retinopathy phenotype. Generates patients without DR."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 30,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "dr_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Cataract"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Cataract": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Cataract",
          "distribution": 0.3
        },
        {
          "transition": "Maybe_Mimicker_Age_related_macular_degeneration",
          "distribution": 0.7
        }
      ]
    },
    "Diagnose_Mimicker_Cataract": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "193570009",
          "display": "Cataract"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Age_related_macular_degeneration"
    },
    "Maybe_Mimicker_Age_related_macular_degeneration": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Age_related_macular_degeneration",
          "distribution": 0.1
        },
        {
          "transition": "Maybe_Mimicker_Hypertensive_retinopathy",
          "distribution": 0.9
        }
      ]
    },
    "Diagnose_Mimicker_Age_related_macular_degeneration": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "267718000",
          "display": "Age related macular degeneration"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Hypertensive_retinopathy"
    },
    "Maybe_Mimicker_Hypertensive_retinopathy": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Hypertensive_retinopathy",
          "distribution": 0.15
        },
        {
          "transition": "Maybe_Mimicker_Primary_open_angle_glaucoma",
          "distribution": 0.85
        }
      ]
    },
    "Diagnose_Mimicker_Hypertensive_retinopathy": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "6962006",
          "display": "Hypertensive retinopathy"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Primary_open_angle_glaucoma"
    },
    "Maybe_Mimicker_Primary_open_angle_glaucoma": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Primary_open_angle_glaucoma",
          "distribution": 0.08
        },
        {
          "transition": "Maybe_Mimicker_Retinal_vein_occlusion",
          "distribution": 0.92
        }
      ]
    },
    "Diagnose_Mimicker_Primary_open_angle_glaucoma": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "77075001",
          "display": "Primary open angle glaucoma"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Retinal_vein_occlusion"
    },
    "Maybe_Mimicker_Retinal_vein_occlusion": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Retinal_vein_occlusion",
          "distribution": 0.03
        },
        {
          "transition": "End_Wellness_Encounter",
          "distribution": 0.97
        }
      ]
    },
    "Diagnose_Mimicker_Retinal_vein_occlusion": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "1237532002",
          "display": "Retinal vein occlusion"
        }
      ],
      "direct_transition": "End_Wellness_Encounter"
    }
  },
  "gmf_version": 2
}
