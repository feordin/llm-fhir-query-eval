{
  "name": "PheKB Multimodal Analgesia Control",
  "remarks": [
    "Control: age 18+ without surgery or opioid."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 18,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "mma_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Chronic_pain_syndrome"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Chronic_pain_syndrome": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Chronic_pain_syndrome",
          "distribution": 0.2
        },
        {
          "transition": "Maybe_Mimicker_Low_back_pain",
          "distribution": 0.8
        }
      ]
    },
    "Diagnose_Mimicker_Chronic_pain_syndrome": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "373621006",
          "display": "Chronic pain syndrome"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Low_back_pain"
    },
    "Maybe_Mimicker_Low_back_pain": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Low_back_pain",
          "distribution": 0.25
        },
        {
          "transition": "Maybe_Mimicker_Degenerative_polyarthritis",
          "distribution": 0.75
        }
      ]
    },
    "Diagnose_Mimicker_Low_back_pain": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "279039007",
          "display": "Low back pain"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Degenerative_polyarthritis"
    },
    "Maybe_Mimicker_Degenerative_polyarthritis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Degenerative_polyarthritis",
          "distribution": 0.2
        },
        {
          "transition": "Maybe_Mimicker_Fibromyalgia",
          "distribution": 0.8
        }
      ]
    },
    "Diagnose_Mimicker_Degenerative_polyarthritis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "225655006",
          "display": "Degenerative polyarthritis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Fibromyalgia"
    },
    "Maybe_Mimicker_Fibromyalgia": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Fibromyalgia",
          "distribution": 0.08
        },
        {
          "transition": "Maybe_Mimicker_Migraine",
          "distribution": 0.92
        }
      ]
    },
    "Diagnose_Mimicker_Fibromyalgia": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "203082005",
          "display": "Fibromyalgia"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Migraine"
    },
    "Maybe_Mimicker_Migraine": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Migraine",
          "distribution": 0.1
        },
        {
          "transition": "End_Wellness_Encounter",
          "distribution": 0.9
        }
      ]
    },
    "Diagnose_Mimicker_Migraine": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "37796009",
          "display": "Migraine"
        }
      ],
      "direct_transition": "End_Wellness_Encounter"
    }
  },
  "gmf_version": 2
}
