{
  "name": "PheKB Digital Rectal Exam Control",
  "remarks": [
    "Control: male age 35+ without prostate cancer or DRE."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Sex_Guard"
    },
    "Sex_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Gender",
        "gender": "M"
      },
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 35,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "dre_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Hyperplasia_of_prostate"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Hyperplasia_of_prostate": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Hyperplasia_of_prostate",
          "distribution": 0.3
        },
        {
          "transition": "Maybe_Mimicker_Constipation",
          "distribution": 0.7
        }
      ]
    },
    "Diagnose_Mimicker_Hyperplasia_of_prostate": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "433234005",
          "display": "Hyperplasia of prostate"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Constipation"
    },
    "Maybe_Mimicker_Constipation": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Constipation",
          "distribution": 0.2
        },
        {
          "transition": "Maybe_Mimicker_Hemorrhoids",
          "distribution": 0.8
        }
      ]
    },
    "Diagnose_Mimicker_Constipation": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "14760008",
          "display": "Constipation"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Hemorrhoids"
    },
    "Maybe_Mimicker_Hemorrhoids": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Hemorrhoids",
          "distribution": 0.15
        },
        {
          "transition": "Maybe_Mimicker_Rectal_hemorrhage",
          "distribution": 0.85
        }
      ]
    },
    "Diagnose_Mimicker_Hemorrhoids": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "70153002",
          "display": "Hemorrhoids"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Rectal_hemorrhage"
    },
    "Maybe_Mimicker_Rectal_hemorrhage": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Rectal_hemorrhage",
          "distribution": 0.08
        },
        {
          "transition": "Maybe_Mimicker_Prostatitis",
          "distribution": 0.92
        }
      ]
    },
    "Diagnose_Mimicker_Rectal_hemorrhage": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "12063002",
          "display": "Rectal hemorrhage"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Prostatitis"
    },
    "Maybe_Mimicker_Prostatitis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Prostatitis",
          "distribution": 0.05
        },
        {
          "transition": "End_Wellness_Encounter",
          "distribution": 0.95
        }
      ]
    },
    "Diagnose_Mimicker_Prostatitis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "9713002",
          "display": "Prostatitis"
        }
      ],
      "direct_transition": "End_Wellness_Encounter"
    }
  },
  "gmf_version": 2
}
