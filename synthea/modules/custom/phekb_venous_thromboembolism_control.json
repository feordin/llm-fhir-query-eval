{
  "name": "PheKB Venous Thromboembolism Control",
  "remarks": [
    "Control module for PheKB VTE phenotype.",
    "Generates patients who do NOT have VTE.",
    "",
    "Controls must:",
    "  - Have no VTE diagnosis",
    "  - Have D-dimer below 0.5 mcg/mL FEU",
    "  - Have no anticoagulant therapy",
    "",
    "Lab values (intentionally below the case threshold of D-dimer > 0.5 mcg/mL):",
    "  Control D-dimer range: 0.10-0.40 mcg/mL"
  ],
  "states": {
    "Initial": { "type": "Initial", "direct_transition": "Age_Guard" },
    "Age_Guard": { "type": "Guard", "allow": { "condition_type": "Age", "operator": ">=", "quantity": 30, "unit": "years" }, "direct_transition": "Set_Control_Flag" },
    "Set_Control_Flag": { "type": "SetAttribute", "attribute": "vte_positive", "value": false, "direct_transition": "Wellness_Encounter" },
    "Wellness_Encounter": { "type": "Encounter", "wellness": true, "direct_transition": "Record_Normal_DDimer" },
    "Record_Normal_DDimer": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "ug/mL",
      "codes": [{ "system": "LOINC", "code": "48065-7", "display": "Fibrin D-dimer FEU [Mass/volume] in Platelet poor plasma" }],
      "range": { "low": 0.10, "high": 0.40 },
      "direct_transition": "End_Wellness_Encounter"
    },
    "End_Wellness_Encounter": { "type": "EncounterEnd", "direct_transition": "Followup_Delay" },
    "Followup_Delay": { "type": "Delay", "range": { "low": 12, "high": 24, "unit": "months" }, "direct_transition": "Wellness_Encounter" }
  },
  "gmf_version": 2
}
