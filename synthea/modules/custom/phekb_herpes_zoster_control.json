{
  "name": "PheKB Herpes Zoster Control",
  "remarks": [
    "Control module for herpes zoster. Generates patients age 50+ without zoster dx or acyclovir Rx."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 50,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "hz_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Herpes_simplex"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Herpes_simplex": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Herpes_simplex",
          "distribution": 0.15
        },
        {
          "transition": "Maybe_Mimicker_Contact_dermatitis",
          "distribution": 0.85
        }
      ]
    },
    "Diagnose_Mimicker_Herpes_simplex": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "88594005",
          "display": "Herpes simplex"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Contact_dermatitis"
    },
    "Maybe_Mimicker_Contact_dermatitis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Contact_dermatitis",
          "distribution": 0.2
        },
        {
          "transition": "Maybe_Mimicker_Cellulitis",
          "distribution": 0.8
        }
      ]
    },
    "Diagnose_Mimicker_Contact_dermatitis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "40275004",
          "display": "Contact dermatitis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Cellulitis"
    },
    "Maybe_Mimicker_Cellulitis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Cellulitis",
          "distribution": 0.1
        },
        {
          "transition": "Maybe_Mimicker_Impetigo_bullosa",
          "distribution": 0.9
        }
      ]
    },
    "Diagnose_Mimicker_Cellulitis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "128045006",
          "display": "Cellulitis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Impetigo_bullosa"
    },
    "Maybe_Mimicker_Impetigo_bullosa": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Impetigo_bullosa",
          "distribution": 0.05
        },
        {
          "transition": "Maybe_Mimicker_Erysipelas",
          "distribution": 0.95
        }
      ]
    },
    "Diagnose_Mimicker_Impetigo_bullosa": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "399183005",
          "display": "Impetigo bullosa"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Erysipelas"
    },
    "Maybe_Mimicker_Erysipelas": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Erysipelas",
          "distribution": 0.05
        },
        {
          "transition": "End_Wellness_Encounter",
          "distribution": 0.95
        }
      ]
    },
    "Diagnose_Mimicker_Erysipelas": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "44653001",
          "display": "Erysipelas"
        }
      ],
      "direct_transition": "End_Wellness_Encounter"
    }
  },
  "gmf_version": 2
}
