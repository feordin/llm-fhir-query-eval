{
  "name": "PheKB Multiple Sclerosis Control",
  "remarks": [
    "Control module for PheKB MS phenotype.",
    "Generates patients who do NOT have multiple sclerosis.",
    "",
    "Controls per PheKB MS algorithm must:",
    "  - Have no MS diagnosis",
    "  - Have no MS DMT prescriptions",
    "  - Have no other autoimmune disease codes (per MS algorithm exclusion list)",
    "",
    "Controls get NO Condition resources for MS and NO MS DMTs."
  ],
  "states": {
    "Initial": { "type": "Initial", "direct_transition": "Age_Guard" },

    "Age_Guard": {
      "type": "Guard",
      "allow": { "condition_type": "Age", "operator": ">=", "quantity": 20, "unit": "years" },
      "direct_transition": "Set_Control_Flag"
    },

    "Set_Control_Flag": { "type": "SetAttribute", "attribute": "ms_positive", "value": false, "direct_transition": "Wellness_Encounter" },

    "Wellness_Encounter": { "type": "Encounter", "wellness": true, "direct_transition": "End_Wellness_Encounter" },

    "End_Wellness_Encounter": { "type": "EncounterEnd", "direct_transition": "Followup_Delay" },

    "Followup_Delay": {
      "type": "Delay",
      "range": { "low": 12, "high": 24, "unit": "months" },
      "direct_transition": "Wellness_Encounter"
    }
  },
  "gmf_version": 2
}
