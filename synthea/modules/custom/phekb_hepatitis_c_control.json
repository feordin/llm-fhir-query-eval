{
  "name": "PheKB Hepatitis C Control",
  "remarks": [
    "Control module for PheKB hepatitis C phenotype.",
    "Generates patients who do NOT have HCV.",
    "",
    "Controls must:",
    "  - Have no HCV diagnosis",
    "  - Have no DAA medications",
    "  - Have negative or no HCV antibody test",
    "",
    "Controls get NO Condition resources for HCV, NO DAAs, and NO HCV labs."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 25,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "hcv_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Type_B_viral_hepatitis"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Type_B_viral_hepatitis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Type_B_viral_hepatitis",
          "distribution": 0.1
        },
        {
          "transition": "Maybe_Mimicker_Metabolic_dysfunction_associated_steatotic_liver_disease",
          "distribution": 0.9
        }
      ]
    },
    "Diagnose_Mimicker_Type_B_viral_hepatitis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "66071002",
          "display": "Type B viral hepatitis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Metabolic_dysfunction_associated_steatotic_liver_disease"
    },
    "Maybe_Mimicker_Metabolic_dysfunction_associated_steatotic_liver_disease": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Metabolic_dysfunction_associated_steatotic_liver_disease",
          "distribution": 0.25
        },
        {
          "transition": "Maybe_Mimicker_Alcoholic_liver_damage",
          "distribution": 0.75
        }
      ]
    },
    "Diagnose_Mimicker_Metabolic_dysfunction_associated_steatotic_liver_disease": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "1231824009",
          "display": "Metabolic dysfunction-associated steatotic liver disease"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Alcoholic_liver_damage"
    },
    "Maybe_Mimicker_Alcoholic_liver_damage": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Alcoholic_liver_damage",
          "distribution": 0.12
        },
        {
          "transition": "Maybe_Mimicker_Viral_hepatitis_type_A",
          "distribution": 0.88
        }
      ]
    },
    "Diagnose_Mimicker_Alcoholic_liver_damage": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "41309000",
          "display": "Alcoholic liver damage"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Viral_hepatitis_type_A"
    },
    "Maybe_Mimicker_Viral_hepatitis_type_A": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Viral_hepatitis_type_A",
          "distribution": 0.03
        },
        {
          "transition": "Maybe_Mimicker_Chronic_autoimmune_hepatitis",
          "distribution": 0.97
        }
      ]
    },
    "Diagnose_Mimicker_Viral_hepatitis_type_A": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "40468003",
          "display": "Viral hepatitis, type A"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Chronic_autoimmune_hepatitis"
    },
    "Maybe_Mimicker_Chronic_autoimmune_hepatitis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Chronic_autoimmune_hepatitis",
          "distribution": 0.02
        },
        {
          "transition": "End_Wellness_Encounter",
          "distribution": 0.98
        }
      ]
    },
    "Diagnose_Mimicker_Chronic_autoimmune_hepatitis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "16098491000119109",
          "display": "Chronic autoimmune hepatitis"
        }
      ],
      "direct_transition": "End_Wellness_Encounter"
    }
  },
  "gmf_version": 2
}
