{
  "name": "PheKB Hepatitis C Control",
  "remarks": [
    "Control module for PheKB hepatitis C phenotype.",
    "Generates patients who do NOT have HCV.",
    "",
    "Controls must:",
    "  - Have no HCV diagnosis",
    "  - Have no DAA medications",
    "  - Have negative or no HCV antibody test",
    "",
    "Controls get NO Condition resources for HCV, NO DAAs, and NO HCV labs."
  ],
  "states": {
    "Initial": { "type": "Initial", "direct_transition": "Age_Guard" },
    "Age_Guard": { "type": "Guard", "allow": { "condition_type": "Age", "operator": ">=", "quantity": 25, "unit": "years" }, "direct_transition": "Set_Control_Flag" },
    "Set_Control_Flag": { "type": "SetAttribute", "attribute": "hcv_positive", "value": false, "direct_transition": "Wellness_Encounter" },
    "Wellness_Encounter": { "type": "Encounter", "wellness": true, "direct_transition": "End_Wellness_Encounter" },
    "End_Wellness_Encounter": { "type": "EncounterEnd", "direct_transition": "Followup_Delay" },
    "Followup_Delay": { "type": "Delay", "range": { "low": 12, "high": 24, "unit": "months" }, "direct_transition": "Wellness_Encounter" }
  },
  "gmf_version": 2
}
