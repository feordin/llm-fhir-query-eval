{
  "name": "PheKB Cystic Fibrosis",
  "remarks": [
    "Custom Synthea module for cystic fibrosis (CF).",
    "First genetic pediatric phenotype (lifelong autosomal recessive CFTR mutation).",
    "Single-path module: 100% have CF dx (genetic disease — present from birth).",
    "",
    "No medication or lab path: CFTR modulator RxNorm codes had verification difficulties; sweat chloride LOINC unverifiable in this batch. Future expansion: ivacaftor/elexacaftor + sweat chloride.",
    "",
    "Age guard: >=1 (CF can be diagnosed by newborn screening, but data here represents identified patients age 1+)."
  ],
  "states": {
    "Initial": { "type": "Initial", "direct_transition": "Age_Guard" },
    "Age_Guard": { "type": "Guard", "allow": { "condition_type": "Age", "operator": ">=", "quantity": 1, "unit": "years" }, "direct_transition": "Set_CF_Flag" },
    "Set_CF_Flag": { "type": "SetAttribute", "attribute": "cf_positive", "value": true, "direct_transition": "Set_Needs_First_Visit" },

    "Set_Needs_First_Visit": { "type": "SetAttribute", "attribute": "cf_needs_first_visit", "value": true, "direct_transition": "Wellness_Encounter" },
    "Wellness_Encounter": { "type": "Encounter", "wellness": true, "direct_transition": "Check_First_Visit" },
    "Check_First_Visit": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "cf_needs_first_visit", "operator": "==", "value": true }, "transition": "Diagnose_CF" },
        { "transition": "End_Wellness_Encounter" }
      ]
    },
    "Diagnose_CF": { "type": "ConditionOnset", "assign_to_attribute": "cf_condition", "codes": [{ "system": "SNOMED-CT", "code": "190905008", "display": "Cystic fibrosis" }], "direct_transition": "Clear_First_Visit_Flag" },

    "Clear_First_Visit_Flag": { "type": "SetAttribute", "attribute": "cf_needs_first_visit", "value": false, "direct_transition": "End_Wellness_Encounter" },
    "End_Wellness_Encounter": { "type": "EncounterEnd", "direct_transition": "Followup_Delay" },
    "Followup_Delay": { "type": "Delay", "range": { "low": 3, "high": 6, "unit": "months" }, "direct_transition": "Wellness_Encounter" }
  },
  "gmf_version": 2
}
