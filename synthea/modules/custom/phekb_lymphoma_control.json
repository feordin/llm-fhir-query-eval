{
  "name": "PheKB Lymphoma Control",
  "remarks": [
    "Control module for lymphoma. Generates adult patients without lymphoma dx."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 18,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "lym_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Lymphadenopathy"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Lymphadenopathy": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Lymphadenopathy",
          "distribution": 0.3
        },
        {
          "transition": "Maybe_Mimicker_Infectious_mononucleosis",
          "distribution": 0.7
        }
      ]
    },
    "Diagnose_Mimicker_Lymphadenopathy": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "30746006",
          "display": "Lymphadenopathy"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Infectious_mononucleosis"
    },
    "Maybe_Mimicker_Infectious_mononucleosis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Infectious_mononucleosis",
          "distribution": 0.1
        },
        {
          "transition": "Maybe_Mimicker_Sarcoidosis",
          "distribution": 0.9
        }
      ]
    },
    "Diagnose_Mimicker_Infectious_mononucleosis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "271558008",
          "display": "Infectious mononucleosis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Sarcoidosis"
    },
    "Maybe_Mimicker_Sarcoidosis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Sarcoidosis",
          "distribution": 0.05
        },
        {
          "transition": "Maybe_Mimicker_Tuberculous_adenitis",
          "distribution": 0.95
        }
      ]
    },
    "Diagnose_Mimicker_Sarcoidosis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "31541009",
          "display": "Sarcoidosis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Tuberculous_adenitis"
    },
    "Maybe_Mimicker_Tuberculous_adenitis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Tuberculous_adenitis",
          "distribution": 0.04
        },
        {
          "transition": "Maybe_Mimicker_Acute_leukemia",
