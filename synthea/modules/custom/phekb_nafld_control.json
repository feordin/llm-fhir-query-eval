{
  "name": "PheKB NAFLD Control",
  "remarks": ["Control module for NAFLD. Generates patients without fatty liver disease. Normal ALT (10-35) and AST (10-30)."],
  "states": {
    "Initial": { "type": "Initial", "direct_transition": "Age_Guard" },
    "Age_Guard": { "type": "Guard", "allow": { "condition_type": "Age", "operator": ">=", "quantity": 30, "unit": "years" }, "direct_transition": "Set_Control_Flag" },
    "Set_Control_Flag": { "type": "SetAttribute", "attribute": "nafld_positive", "value": false, "direct_transition": "Wellness_Encounter" },
    "Wellness_Encounter": { "type": "Encounter", "wellness": true, "direct_transition": "Record_Normal_ALT" },
    "Record_Normal_ALT": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "U/L",
      "codes": [{ "system": "LOINC", "code": "1742-6", "display": "Alanine aminotransferase [Enzymatic activity/volume] in Serum or Plasma" }],
      "range": { "low": 10, "high": 35 },
      "direct_transition": "Record_Normal_AST"
    },
    "Record_Normal_AST": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "U/L",
      "codes": [{ "system": "LOINC", "code": "1920-8", "display": "Aspartate aminotransferase [Enzymatic activity/volume] in Serum or Plasma" }],
      "range": { "low": 10, "high": 30 },
      "direct_transition": "End_Wellness_Encounter"
    },
    "End_Wellness_Encounter": { "type": "EncounterEnd", "direct_transition": "Followup_Delay" },
    "Followup_Delay": { "type": "Delay", "range": { "low": 12, "high": 24, "unit": "months" }, "direct_transition": "Wellness_Encounter" }
  },
  "gmf_version": 2
}
