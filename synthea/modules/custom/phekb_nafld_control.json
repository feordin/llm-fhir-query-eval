{
  "name": "PheKB NAFLD Control",
  "remarks": [
    "Control module for NAFLD. Generates patients without fatty liver disease. Normal ALT (10-35) and AST (10-30)."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 30,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "nafld_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Alcoholic_liver_damage"
    },
    "Record_Normal_ALT": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "U/L",
      "codes": [
        {
          "system": "LOINC",
          "code": "1742-6",
          "display": "Alanine aminotransferase [Enzymatic activity/volume] in Serum or Plasma"
        }
      ],
      "range": {
        "low": 10,
        "high": 35
      },
      "direct_transition": "Record_Normal_AST"
    },
    "Record_Normal_AST": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "U/L",
      "codes": [
        {
          "system": "LOINC",
          "code": "1920-8",
          "display": "Aspartate aminotransferase [Enzymatic activity/volume] in Serum or Plasma"
        }
      ],
      "range": {
        "low": 10,
        "high": 30
      },
      "direct_transition": "End_Wellness_Encounter"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Alcoholic_liver_damage": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Alcoholic_liver_damage",
          "distribution": 0.25
        },
        {
          "transition": "Maybe_Mimicker_Viral_hepatitis_C",
          "distribution": 0.75
        }
      ]
    },
    "Diagnose_Mimicker_Alcoholic_liver_damage": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "41309000",
          "display": "Alcoholic liver damage"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Viral_hepatitis_C"
    },
    "Maybe_Mimicker_Viral_hepatitis_C": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Viral_hepatitis_C",
          "distribution": 0.1
        },
        {
          "transition": "Maybe_Mimicker_Type_B_viral_hepatitis",
          "distribution": 0.9
        }
      ]
    },
    "Diagnose_Mimicker_Viral_hepatitis_C": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "50711007",
          "display": "Viral hepatitis C"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Type_B_viral_hepatitis"
    },
    "Maybe_Mimicker_Type_B_viral_hepatitis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Type_B_viral_hepatitis",
          "distribution": 0.05
        },
        {
          "transition": "Maybe_Mimicker_Cirrhosis_of_liver",
          "distribution": 0.95
        }
      ]
    },
    "Diagnose_Mimicker_Type_B_viral_hepatitis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "66071002",
          "display": "Type B viral hepatitis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Cirrhosis_of_liver"
    },
    "Maybe_Mimicker_Cirrhosis_of_liver": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Cirrhosis_of_liver",
          "distribution": 0.15
        },
        {
          "transition": "Maybe_Mimicker_Hereditary_hemochromatosis",
          "distribution": 0.85
        }
      ]
    },
    "Diagnose_Mimicker_Cirrhosis_of_liver": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "19943007",
          "display": "Cirrhosis of liver"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Hereditary_hemochromatosis"
    },
    "Maybe_Mimicker_Hereditary_hemochromatosis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Hereditary_hemochromatosis",
          "distribution": 0.02
        },
        {
          "transition": "Record_Normal_ALT",
          "distribution": 0.98
        }
      ]
    },
    "Diagnose_Mimicker_Hereditary_hemochromatosis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "35400008",
          "display": "Hereditary hemochromatosis"
        }
      ],
      "direct_transition": "Record_Normal_ALT"
    }
  },
  "gmf_version": 2
}
