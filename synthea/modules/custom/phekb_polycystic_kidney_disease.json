{
  "name": "PheKB Polycystic Kidney Disease",
  "remarks": [
    "Custom Synthea module for polycystic kidney disease (PKD).",
    "First hereditary kidney disease phenotype.",
    "Single-path: 100% have PKD dx (genetic — present from birth, manifests later).",
    "",
    "Age guard: >=18 (PKD typically diagnosed in adulthood; the infantile-type SNOMED code we use here is the only verifiable variant — distinguishing autosomal dominant vs recessive PKD coding is left to future evaluation)."
  ],
  "states": {
    "Initial": { "type": "Initial", "direct_transition": "Age_Guard" },
    "Age_Guard": { "type": "Guard", "allow": { "condition_type": "Age", "operator": ">=", "quantity": 18, "unit": "years" }, "direct_transition": "Set_PKD_Flag" },
    "Set_PKD_Flag": { "type": "SetAttribute", "attribute": "pkd_positive", "value": true, "direct_transition": "Set_Needs_First_Visit" },
    "Set_Needs_First_Visit": { "type": "SetAttribute", "attribute": "pkd_needs_first_visit", "value": true, "direct_transition": "Wellness_Encounter" },
    "Wellness_Encounter": { "type": "Encounter", "wellness": true, "direct_transition": "Check_First_Visit" },
    "Check_First_Visit": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "pkd_needs_first_visit", "operator": "==", "value": true }, "transition": "Diagnose_PKD" },
        { "transition": "End_Wellness_Encounter" }
      ]
    },
    "Diagnose_PKD": { "type": "ConditionOnset", "assign_to_attribute": "pkd_condition", "codes": [{ "system": "SNOMED-CT", "code": "28770003", "display": "Polycystic kidney disease, infantile type" }], "direct_transition": "Clear_First_Visit_Flag" },
    "Clear_First_Visit_Flag": { "type": "SetAttribute", "attribute": "pkd_needs_first_visit", "value": false, "direct_transition": "End_Wellness_Encounter" },
    "End_Wellness_Encounter": { "type": "EncounterEnd", "direct_transition": "Followup_Delay" },
    "Followup_Delay": { "type": "Delay", "range": { "low": 6, "high": 12, "unit": "months" }, "direct_transition": "Wellness_Encounter" }
  },
  "gmf_version": 2
}
