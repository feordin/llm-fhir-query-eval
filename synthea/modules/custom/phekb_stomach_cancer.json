{
  "name": "PheKB Stomach Cancer",
  "remarks": [
    "Custom Synthea module for stomach (gastric) cancer.",
    "10th cancer phenotype, third GI cancer (after CRC, HCC, Pancreatic).",
    "Single-path: 100% have gastric cancer dx. Age guard: >=50."
  ],
  "states": {
    "Initial": { "type": "Initial", "direct_transition": "Age_Guard" },
    "Age_Guard": { "type": "Guard", "allow": { "condition_type": "Age", "operator": ">=", "quantity": 50, "unit": "years" }, "direct_transition": "Set_Stomach_Flag" },
    "Set_Stomach_Flag": { "type": "SetAttribute", "attribute": "stomach_positive", "value": true, "direct_transition": "Set_Needs_First_Visit" },
    "Set_Needs_First_Visit": { "type": "SetAttribute", "attribute": "stomach_needs_first_visit", "value": true, "direct_transition": "Wellness_Encounter" },
    "Wellness_Encounter": { "type": "Encounter", "wellness": true, "direct_transition": "Check_First_Visit" },
    "Check_First_Visit": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "stomach_needs_first_visit", "operator": "==", "value": true }, "transition": "Diagnose_Stomach" },
        { "transition": "End_Wellness_Encounter" }
      ]
    },
    "Diagnose_Stomach": { "type": "ConditionOnset", "assign_to_attribute": "stomach_condition", "codes": [{ "system": "SNOMED-CT", "code": "363349007", "display": "Malignant neoplasm of stomach" }], "direct_transition": "Clear_First_Visit_Flag" },
    "Clear_First_Visit_Flag": { "type": "SetAttribute", "attribute": "stomach_needs_first_visit", "value": false, "direct_transition": "End_Wellness_Encounter" },
    "End_Wellness_Encounter": { "type": "EncounterEnd", "direct_transition": "Followup_Delay" },
    "Followup_Delay": { "type": "Delay", "range": { "low": 6, "high": 12, "unit": "months" }, "direct_transition": "Wellness_Encounter" }
  },
  "gmf_version": 2
}
