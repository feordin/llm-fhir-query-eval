{
  "name": "PheKB Diverticulitis",
  "remarks": [
    "Custom Synthea module for diverticulitis (acute colonic).",
    "Second GI inflammatory phenotype (after Crohn's). Common condition in adults >50.",
    "First antibiotic-treated phenotype with ciprofloxacin + metronidazole (standard outpatient regimen).",
    "",
    "Generates THREE patient paths:",
    "  Path A (50%): Diverticulitis dx + ciprofloxacin + metronidazole (typical episode)",
    "  Path B (30%): Diverticulitis dx, no antibiotics (mild self-limited or Hinchey 0)",
    "  Path C (20%): Cipro + metronidazole only, no diverticulitis dx (TRICKY — empirical for intra-abdominal infection or unconfirmed UTI/IAI)",
    "",
    "Age guard: >=50 (diverticulitis prevalence increases with age)."
  ],
  "states": {
    "Initial": { "type": "Initial", "direct_transition": "Age_Guard" },
    "Age_Guard": { "type": "Guard", "allow": { "condition_type": "Age", "operator": ">=", "quantity": 50, "unit": "years" }, "direct_transition": "Set_Div_Flag" },
    "Set_Div_Flag": { "type": "SetAttribute", "attribute": "div_positive", "value": true, "direct_transition": "Choose_Patient_Path" },
    "Choose_Patient_Path": {
      "type": "Simple",
      "distributed_transition": [
        { "transition": "Set_Path_A", "distribution": 0.50 },
        { "transition": "Set_Path_B", "distribution": 0.30 },
        { "transition": "Set_Path_C", "distribution": 0.20 }
      ]
    },
    "Set_Path_A": { "type": "SetAttribute", "attribute": "div_has_dx", "value": true, "direct_transition": "Set_Path_A_Meds" },
    "Set_Path_A_Meds": { "type": "SetAttribute", "attribute": "div_has_meds", "value": true, "direct_transition": "Set_Needs_First_Visit" },
    "Set_Path_B": { "type": "SetAttribute", "attribute": "div_has_dx", "value": true, "direct_transition": "Set_Path_B_Meds" },
    "Set_Path_B_Meds": { "type": "SetAttribute", "attribute": "div_has_meds", "value": false, "direct_transition": "Set_Needs_First_Visit" },
    "Set_Path_C": { "type": "SetAttribute", "remarks": ["TRICKY: cipro+metro only, no diverticulitis dx"], "attribute": "div_has_dx", "value": false, "direct_transition": "Set_Path_C_Meds" },
    "Set_Path_C_Meds": { "type": "SetAttribute", "attribute": "div_has_meds", "value": true, "direct_transition": "Set_Needs_First_Visit" },

    "Set_Needs_First_Visit": { "type": "SetAttribute", "attribute": "div_needs_first_visit", "value": true, "direct_transition": "Wellness_Encounter" },
    "Wellness_Encounter": { "type": "Encounter", "wellness": true, "direct_transition": "Check_First_Visit" },
    "Check_First_Visit": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "div_needs_first_visit", "operator": "==", "value": true }, "transition": "Check_Has_Diagnosis" },
        { "transition": "End_Wellness_Encounter" }
      ]
    },
    "Check_Has_Diagnosis": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "div_has_dx", "operator": "==", "value": true }, "transition": "Diagnose_Diverticulitis" },
        { "transition": "Check_Meds_NoDx" }
      ]
    },
    "Diagnose_Diverticulitis": { "type": "ConditionOnset", "assign_to_attribute": "div_condition", "codes": [{ "system": "SNOMED-CT", "code": "307496006", "display": "Diverticulitis" }], "direct_transition": "Check_Meds_WithDx" },

    "Check_Meds_WithDx": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "div_has_meds", "operator": "==", "value": true }, "transition": "Prescribe_Cipro_WithDx" },
        { "transition": "Clear_First_Visit_Flag" }
      ]
    },
    "Prescribe_Cipro_WithDx": { "type": "MedicationOrder", "codes": [{ "system": "RxNorm", "code": "2551", "display": "ciprofloxacin" }], "reason": "div_condition", "direct_transition": "Prescribe_Metro_WithDx" },
    "Prescribe_Metro_WithDx": { "type": "MedicationOrder", "codes": [{ "system": "RxNorm", "code": "6922", "display": "metronidazole" }], "reason": "div_condition", "direct_transition": "Clear_First_Visit_Flag" },

    "Check_Meds_NoDx": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "div_has_meds", "operator": "==", "value": true }, "transition": "Prescribe_Cipro_NoDx" },
        { "transition": "Clear_First_Visit_Flag" }
      ]
    },
    "Prescribe_Cipro_NoDx": { "type": "MedicationOrder", "codes": [{ "system": "RxNorm", "code": "2551", "display": "ciprofloxacin" }], "direct_transition": "Prescribe_Metro_NoDx" },
    "Prescribe_Metro_NoDx": { "type": "MedicationOrder", "codes": [{ "system": "RxNorm", "code": "6922", "display": "metronidazole" }], "direct_transition": "Clear_First_Visit_Flag" },

    "Clear_First_Visit_Flag": { "type": "SetAttribute", "attribute": "div_needs_first_visit", "value": false, "direct_transition": "End_Wellness_Encounter" },
    "End_Wellness_Encounter": { "type": "EncounterEnd", "direct_transition": "Followup_Delay" },
    "Followup_Delay": { "type": "Delay", "range": { "low": 6, "high": 12, "unit": "months" }, "direct_transition": "Wellness_Encounter" }
  },
  "gmf_version": 2
}
