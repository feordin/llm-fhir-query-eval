{
  "name": "PheKB Asthma Control (Non-Asthmatic)",
  "remarks": [
    "Control module for asthma phenotype testing",
    "Generates patients who should NOT match asthma criteria",
    "",
    "Control Criteria (exclusion from asthma):",
    "- No asthma diagnosis codes",
    "- No asthma medications (no albuterol, fluticasone, budesonide, montelukast)",
    "- May have unrelated conditions for variety (hypertension, allergic rhinitis)",
    "",
    "Uses 'wellness: true' encounter pattern to produce FHIR resources.",
    "These patients should NOT be returned by asthma queries."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },

    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 4,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },

    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "asthma_control",
      "value": true,
      "direct_transition": "Wellness_Encounter"
    },

    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Check_Other_Conditions"
    },

    "Check_Other_Conditions": {
      "type": "Simple",
      "remarks": ["Some control patients have non-asthma conditions for variety"],
      "distributed_transition": [
        {
          "transition": "Diagnose_Hypertension",
          "distribution": 0.25
        },
        {
          "transition": "Diagnose_Allergic_Rhinitis",
          "distribution": 0.25
        },
        {
          "transition": "Diagnose_GERD",
          "distribution": 0.15
        },
        {
          "transition": "End_Wellness_Encounter",
          "distribution": 0.35
        }
      ]
    },

    "Diagnose_Hypertension": {
      "type": "ConditionOnset",
      "assign_to_attribute": "hypertension",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "38341003",
          "display": "Hypertensive disorder"
        }
      ],
      "remarks": ["Non-asthma condition for control population variety"],
      "direct_transition": "Prescribe_Antihypertensive"
    },

    "Prescribe_Antihypertensive": {
      "type": "MedicationOrder",
      "codes": [
        {
          "system": "RxNorm",
          "code": "314076",
          "display": "lisinopril 10 MG Oral Tablet"
        }
      ],
      "reason": "hypertension",
      "direct_transition": "End_Wellness_Encounter"
    },

    "Diagnose_Allergic_Rhinitis": {
      "type": "ConditionOnset",
      "assign_to_attribute": "allergic_rhinitis",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "61582004",
          "display": "Allergic rhinitis"
        }
      ],
      "remarks": ["Allergic rhinitis is NOT asthma -- a valid control condition"],
      "direct_transition": "Prescribe_Antihistamine"
    },

    "Prescribe_Antihistamine": {
      "type": "MedicationOrder",
      "codes": [
        {
          "system": "RxNorm",
          "code": "1014676",
          "display": "cetirizine hydrochloride 5 MG Oral Tablet"
        }
      ],
      "reason": "allergic_rhinitis",
      "direct_transition": "End_Wellness_Encounter"
    },

    "Diagnose_GERD": {
      "type": "ConditionOnset",
      "assign_to_attribute": "gerd",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "235595009",
          "display": "Gastroesophageal reflux disease"
        }
      ],
      "remarks": ["GERD is a common comorbidity but NOT asthma"],
      "direct_transition": "End_Wellness_Encounter"
    },

    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Terminal_Control"
    },

    "Terminal_Control": {
      "type": "Terminal",
      "remarks": ["Control patient - should NOT be found by asthma phenotype query"]
    }
  },
  "gmf_version": 2
}
