{
  "name": "PheKB Dementia Control",
  "remarks": [
    "Control module for PheKB dementia phenotype.",
    "Generates patients who do NOT have dementia.",
    "",
    "Controls per PheKB algorithm must:",
    "  - Have no dementia diagnosis codes",
    "  - Have no dementia drug fills",
    "  - Be elderly (age-matched to cases) to ensure realistic comparison",
    "",
    "Some controls receive other (non-dementia) age-related diagnoses such as",
    "age-related macular degeneration or osteoarthritis to mimic real elderly patients,",
    "but no cognitive impairment / dementia codes."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },

    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 50,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },

    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "dementia_positive",
      "value": false,
      "direct_transition": "Set_Needs_First_Visit"
    },

    "Set_Needs_First_Visit": {
      "type": "SetAttribute",
      "attribute": "dementia_needs_first_visit",
      "value": true,
      "direct_transition": "Wellness_Encounter"
    },

    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Check_First_Visit"
    },

    "Check_First_Visit": {
      "type": "Simple",
      "conditional_transition": [
        {
          "condition": {
            "condition_type": "Attribute",
            "attribute": "dementia_needs_first_visit",
            "operator": "==",
            "value": true
          },
          "transition": "Maybe_Other_Condition"
        },
        {
          "transition": "End_Wellness_Encounter"
        }
      ]
    },

    "Maybe_Other_Condition": {
      "type": "Simple",
      "remarks": ["Some elderly controls get a non-dementia condition for realism"],
      "distributed_transition": [
        { "transition": "Diagnose_Osteoarthritis", "distribution": 0.30 },
        { "transition": "Diagnose_Hyperlipidemia", "distribution": 0.30 },
        { "transition": "Clear_First_Visit_Flag", "distribution": 0.40 }
      ]
    },

    "Diagnose_Osteoarthritis": {
      "type": "ConditionOnset",
      "assign_to_attribute": "control_condition",
      "codes": [
        { "system": "SNOMED-CT", "code": "396275006", "display": "Osteoarthritis (disorder)" }
      ],
      "direct_transition": "Clear_First_Visit_Flag"
    },

    "Diagnose_Hyperlipidemia": {
      "type": "ConditionOnset",
      "assign_to_attribute": "control_condition",
      "codes": [
        { "system": "SNOMED-CT", "code": "55822004", "display": "Hyperlipidemia (disorder)" }
      ],
      "direct_transition": "Clear_First_Visit_Flag"
    },

    "Clear_First_Visit_Flag": {
      "type": "SetAttribute",
      "attribute": "dementia_needs_first_visit",
      "value": false,
      "direct_transition": "End_Wellness_Encounter"
    },

    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },

    "Followup_Delay": {
      "type": "Delay",
      "range": { "low": 6, "high": 18, "unit": "months" },
      "direct_transition": "Wellness_Encounter"
    }
  },
  "gmf_version": 2
}
