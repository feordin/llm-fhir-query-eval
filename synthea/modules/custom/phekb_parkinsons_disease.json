{
  "name": "PheKB Parkinson's Disease",
  "remarks": [
    "Custom Synthea module for Parkinson's disease.",
    "First movement disorder phenotype.",
    "",
    "Generates THREE patient paths:",
    "  Path A (60%): PD dx + levodopa",
    "  Path B (30%): PD dx only (early/mild, observation only)",
    "  Path C (10%): levodopa without PD dx (TRICKY — may be on levodopa for restless legs / drug-induced parkinsonism)",
    "",
    "Age guard: >=50 (typical onset)."
  ],
  "states": {
    "Initial": { "type": "Initial", "direct_transition": "Age_Guard" },
    "Age_Guard": { "type": "Guard", "allow": { "condition_type": "Age", "operator": ">=", "quantity": 50, "unit": "years" }, "direct_transition": "Set_Pd_Flag" },
    "Set_Pd_Flag": { "type": "SetAttribute", "attribute": "pd_positive", "value": true, "direct_transition": "Choose_Patient_Path" },
    "Choose_Patient_Path": {
      "type": "Simple",
      "distributed_transition": [
        { "transition": "Set_Path_A", "distribution": 0.60 },
        { "transition": "Set_Path_B", "distribution": 0.30 },
        { "transition": "Set_Path_C", "distribution": 0.10 }
      ]
    },
    "Set_Path_A": { "type": "SetAttribute", "attribute": "pd_has_dx", "value": true, "direct_transition": "Set_Path_A_Med" },
    "Set_Path_A_Med": { "type": "SetAttribute", "attribute": "pd_has_med", "value": true, "direct_transition": "Set_Needs_First_Visit" },
    "Set_Path_B": { "type": "SetAttribute", "attribute": "pd_has_dx", "value": true, "direct_transition": "Set_Path_B_Med" },
    "Set_Path_B_Med": { "type": "SetAttribute", "attribute": "pd_has_med", "value": false, "direct_transition": "Set_Needs_First_Visit" },
    "Set_Path_C": { "type": "SetAttribute", "remarks": ["TRICKY: levodopa without PD dx"], "attribute": "pd_has_dx", "value": false, "direct_transition": "Set_Path_C_Med" },
    "Set_Path_C_Med": { "type": "SetAttribute", "attribute": "pd_has_med", "value": true, "direct_transition": "Set_Needs_First_Visit" },

    "Set_Needs_First_Visit": { "type": "SetAttribute", "attribute": "pd_needs_first_visit", "value": true, "direct_transition": "Wellness_Encounter" },
    "Wellness_Encounter": { "type": "Encounter", "wellness": true, "direct_transition": "Check_First_Visit" },
    "Check_First_Visit": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "pd_needs_first_visit", "operator": "==", "value": true }, "transition": "Check_Has_Diagnosis" },
        { "transition": "End_Wellness_Encounter" }
      ]
    },
    "Check_Has_Diagnosis": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "pd_has_dx", "operator": "==", "value": true }, "transition": "Diagnose_Pd" },
        { "transition": "Check_Med_NoDx" }
      ]
    },
    "Diagnose_Pd": { "type": "ConditionOnset", "assign_to_attribute": "pd_condition", "codes": [{ "system": "SNOMED-CT", "code": "49049000", "display": "Parkinson's disease" }], "direct_transition": "Check_Med_WithDx" },

    "Check_Med_WithDx": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "pd_has_med", "operator": "==", "value": true }, "transition": "Prescribe_Levodopa_WithDx" },
        { "transition": "Clear_First_Visit_Flag" }
      ]
    },
    "Prescribe_Levodopa_WithDx": { "type": "MedicationOrder", "codes": [{ "system": "RxNorm", "code": "6375", "display": "levodopa" }], "reason": "pd_condition", "direct_transition": "Clear_First_Visit_Flag" },

    "Check_Med_NoDx": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "pd_has_med", "operator": "==", "value": true }, "transition": "Prescribe_Levodopa_NoDx" },
        { "transition": "Clear_First_Visit_Flag" }
      ]
    },
    "Prescribe_Levodopa_NoDx": { "type": "MedicationOrder", "codes": [{ "system": "RxNorm", "code": "6375", "display": "levodopa" }], "direct_transition": "Clear_First_Visit_Flag" },

    "Clear_First_Visit_Flag": { "type": "SetAttribute", "attribute": "pd_needs_first_visit", "value": false, "direct_transition": "End_Wellness_Encounter" },
    "End_Wellness_Encounter": { "type": "EncounterEnd", "direct_transition": "Followup_Delay" },
    "Followup_Delay": { "type": "Delay", "range": { "low": 6, "high": 12, "unit": "months" }, "direct_transition": "Wellness_Encounter" }
  },
  "gmf_version": 2
}
