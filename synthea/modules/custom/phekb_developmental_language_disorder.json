{
  "name": "PheKB Developmental Language Disorder (PheKB-aligned APT-DLD)",
  "remarks": [
    "Custom Synthea module for developmental language disorder (DLD).",
    "Aligned to APT-DLD (Walters et al. 2020, JSLHR) — Vanderbilt's automated phenotyping tool.",
    "",
    "PheKB algorithm: 6 inclusion ICD codes — pediatric (<18) at first occurrence — exclude hearing loss, ID, chromosomal anomalies.",
    "  Inclusion codes: ICD-10 F80.1, F80.2, F80.89 (modern); ICD-9 315.31, 315.32, 315.39 (legacy).",
    "",
    "Generates SINGLE-PATH module: dx-only (DLD is treated with speech therapy, no specific Rx).",
    "Multi-system code distribution: 60% F80.89 (other dev disorders, broadest), 25% F80.2 (mixed), 15% F80.1 (expressive).",
    "",
    "Age guard: 5-17 (pediatric onset)."
  ],
  "states": {
    "Initial": { "type": "Initial", "direct_transition": "Age_Lower_Guard" },
    "Age_Lower_Guard": { "type": "Guard", "allow": { "condition_type": "Age", "operator": ">=", "quantity": 5, "unit": "years" }, "direct_transition": "Age_Upper_Guard" },
    "Age_Upper_Guard": { "type": "Guard", "allow": { "condition_type": "Age", "operator": "<=", "quantity": 17, "unit": "years" }, "direct_transition": "Set_Dld_Flag" },
    "Set_Dld_Flag": { "type": "SetAttribute", "attribute": "dld_positive", "value": true, "direct_transition": "Choose_DxCode" },

    "Choose_DxCode": {
      "type": "Simple",
      "distributed_transition": [
        { "transition": "Set_DxCode_F8089", "distribution": 0.60 },
        { "transition": "Set_DxCode_F802", "distribution": 0.25 },
        { "transition": "Set_DxCode_F801", "distribution": 0.15 }
      ]
    },
    "Set_DxCode_F8089": { "type": "SetAttribute", "attribute": "dld_dx_code", "value": "icd10_F80_89", "direct_transition": "Set_Needs_First_Visit" },
    "Set_DxCode_F802": { "type": "SetAttribute", "attribute": "dld_dx_code", "value": "icd10_F80_2", "direct_transition": "Set_Needs_First_Visit" },
    "Set_DxCode_F801": { "type": "SetAttribute", "attribute": "dld_dx_code", "value": "icd10_F80_1", "direct_transition": "Set_Needs_First_Visit" },

    "Set_Needs_First_Visit": { "type": "SetAttribute", "attribute": "dld_needs_first_visit", "value": true, "direct_transition": "Wellness_Encounter" },
    "Wellness_Encounter": { "type": "Encounter", "wellness": true, "direct_transition": "Check_First_Visit" },
    "Check_First_Visit": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "dld_needs_first_visit", "operator": "==", "value": true }, "transition": "Route_Dx_By_Code" },
        { "transition": "End_Wellness_Encounter" }
      ]
    },
    "Route_Dx_By_Code": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "dld_dx_code", "operator": "==", "value": "icd10_F80_89" }, "transition": "Diagnose_F8089" },
        { "condition": { "condition_type": "Attribute", "attribute": "dld_dx_code", "operator": "==", "value": "icd10_F80_2" }, "transition": "Diagnose_F802" },
        { "transition": "Diagnose_F801" }
      ]
    },
    "Diagnose_F8089": { "type": "ConditionOnset", "assign_to_attribute": "dld_condition", "codes": [{ "system": "http://hl7.org/fhir/sid/icd-10-cm", "code": "F80.89", "display": "Other developmental disorders of speech and language" }], "direct_transition": "Clear_First_Visit_Flag" },
    "Diagnose_F802": { "type": "ConditionOnset", "assign_to_attribute": "dld_condition", "codes": [{ "system": "http://hl7.org/fhir/sid/icd-10-cm", "code": "F80.2", "display": "Mixed receptive-expressive language disorder" }], "direct_transition": "Clear_First_Visit_Flag" },
    "Diagnose_F801": { "type": "ConditionOnset", "assign_to_attribute": "dld_condition", "codes": [{ "system": "http://hl7.org/fhir/sid/icd-10-cm", "code": "F80.1", "display": "Expressive language disorder" }], "direct_transition": "Clear_First_Visit_Flag" },

    "Clear_First_Visit_Flag": { "type": "SetAttribute", "attribute": "dld_needs_first_visit", "value": false, "direct_transition": "End_Wellness_Encounter" },
    "End_Wellness_Encounter": { "type": "EncounterEnd", "direct_transition": "Followup_Delay" },
    "Followup_Delay": { "type": "Delay", "range": { "low": 6, "high": 12, "unit": "months" }, "direct_transition": "Wellness_Encounter" }
  },
  "gmf_version": 2
}
