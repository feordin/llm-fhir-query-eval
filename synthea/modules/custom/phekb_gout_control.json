{
  "name": "PheKB Gout Control",
  "remarks": ["Control module for gout. Generates patients age 30+ with normal urate (<6.5 mg/dL) and no gout dx or urate-lowering meds."],
  "states": {
    "Initial": { "type": "Initial", "direct_transition": "Age_Guard" },
    "Age_Guard": { "type": "Guard", "allow": { "condition_type": "Age", "operator": ">=", "quantity": 30, "unit": "years" }, "direct_transition": "Set_Control_Flag" },
    "Set_Control_Flag": { "type": "SetAttribute", "attribute": "gout_positive", "value": false, "direct_transition": "Wellness_Encounter" },
    "Wellness_Encounter": { "type": "Encounter", "wellness": true, "direct_transition": "Record_Normal_Urate" },
    "Record_Normal_Urate": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "mg/dL",
      "codes": [{ "system": "LOINC", "code": "3084-1", "display": "Urate [Mass/volume] in Serum or Plasma" }],
      "range": { "low": 3.5, "high": 6.5 },
      "direct_transition": "End_Wellness_Encounter"
    },
    "End_Wellness_Encounter": { "type": "EncounterEnd", "direct_transition": "Followup_Delay" },
    "Followup_Delay": { "type": "Delay", "range": { "low": 12, "high": 24, "unit": "months" }, "direct_transition": "Wellness_Encounter" }
  },
  "gmf_version": 2
}
