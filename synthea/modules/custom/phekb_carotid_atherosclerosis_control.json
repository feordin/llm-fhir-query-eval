{
  "name": "PheKB CAAD Control",
  "remarks": [
    "Control module for carotid atherosclerosis. Generates patients age 50+ without carotid stenosis dx, antiplatelet/statin meds, or carotid revascularization."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 50,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "caad_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Coronary_arteriosclerosis"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Coronary_arteriosclerosis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Coronary_arteriosclerosis",
          "distribution": 0.3
        },
        {
          "transition": "Maybe_Mimicker_Peripheral_arterial_occlusive_disease",
          "distribution": 0.7
        }
      ]
    },
    "Diagnose_Mimicker_Coronary_arteriosclerosis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "53741008",
          "display": "Coronary arteriosclerosis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Peripheral_arterial_occlusive_disease"
    },
    "Maybe_Mimicker_Peripheral_arterial_occlusive_disease": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Peripheral_arterial_occlusive_disease",
          "distribution": 0.2
        },
        {
          "transition": "Maybe_Mimicker_Vertebral_artery_stenosis",
          "distribution": 0.8
        }
      ]
    },
    "Diagnose_Mimicker_Peripheral_arterial_occlusive_disease": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "399957001",
          "display": "Peripheral arterial occlusive disease"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Vertebral_artery_stenosis"
    },
    "Maybe_Mimicker_Vertebral_artery_stenosis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Vertebral_artery_stenosis",
          "distribution": 0.05
        },
        {
          "transition": "Maybe_Mimicker_Subclavian_steal_syndrome",
          "distribution": 0.95
        }
      ]
    },
    "Diagnose_Mimicker_Vertebral_artery_stenosis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "90520006",
          "display": "Vertebral artery stenosis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Subclavian_steal_syndrome"
    },
    "Maybe_Mimicker_Subclavian_steal_syndrome": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Subclavian_steal_syndrome",
          "distribution": 0.03
        },
        {
          "transition": "Maybe_Mimicker_Dissection_of_carotid_artery",
          "distribution": 0.97
        }
      ]
    },
    "Diagnose_Mimicker_Subclavian_steal_syndrome": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "15258001",
          "display": "Subclavian steal syndrome"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Dissection_of_carotid_artery"
    },
    "Maybe_Mimicker_Dissection_of_carotid_artery": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Dissection_of_carotid_artery",
          "distribution": 0.02
        },
        {
          "transition": "End_Wellness_Encounter",
          "distribution": 0.98
        }
      ]
    },
    "Diagnose_Mimicker_Dissection_of_carotid_artery": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "720626009",
          "display": "Dissection of carotid artery"
        }
      ],
      "direct_transition": "End_Wellness_Encounter"
    }
  },
  "gmf_version": 2
}
