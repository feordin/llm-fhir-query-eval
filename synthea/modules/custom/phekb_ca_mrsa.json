{
  "name": "PheKB Community-Acquired MRSA",
  "remarks": [
    "Custom Synthea module for community-acquired methicillin-resistant Staphylococcus aureus (CA-MRSA) infection.",
    "First MRSA-specific phenotype (distinct from C. diff which is C. difficile).",
    "",
    "Generates THREE patient paths:",
    "  Path A (60%): CA-MRSA dx + clindamycin or linezolid",
    "  Path B (30%): CA-MRSA dx only (mild SSTI, drainage only)",
    "  Path C (10%): clindamycin/linezolid without CA-MRSA dx (TRICKY — these abx are also used for dental/anaerobic infections, VRE)",
    "",
    "Med distribution: 70% clindamycin, 30% linezolid (clinical realism).",
    "",
    "Age guard: >=18."
  ],
  "states": {
    "Initial": { "type": "Initial", "direct_transition": "Age_Guard" },
    "Age_Guard": { "type": "Guard", "allow": { "condition_type": "Age", "operator": ">=", "quantity": 18, "unit": "years" }, "direct_transition": "Set_Mrsa_Flag" },
    "Set_Mrsa_Flag": { "type": "SetAttribute", "attribute": "mrsa_positive", "value": true, "direct_transition": "Choose_Patient_Path" },
    "Choose_Patient_Path": {
      "type": "Simple",
      "distributed_transition": [
        { "transition": "Set_Path_A", "distribution": 0.60 },
        { "transition": "Set_Path_B", "distribution": 0.30 },
        { "transition": "Set_Path_C", "distribution": 0.10 }
      ]
    },
    "Set_Path_A": { "type": "SetAttribute", "attribute": "mrsa_has_dx", "value": true, "direct_transition": "Set_Path_A_Med" },
    "Set_Path_A_Med": { "type": "SetAttribute", "attribute": "mrsa_has_med", "value": true, "direct_transition": "Choose_Med" },
    "Set_Path_B": { "type": "SetAttribute", "attribute": "mrsa_has_dx", "value": true, "direct_transition": "Set_Path_B_Med" },
    "Set_Path_B_Med": { "type": "SetAttribute", "attribute": "mrsa_has_med", "value": false, "direct_transition": "Choose_Med" },
    "Set_Path_C": { "type": "SetAttribute", "remarks": ["TRICKY: clindamycin/linezolid without CA-MRSA dx"], "attribute": "mrsa_has_dx", "value": false, "direct_transition": "Set_Path_C_Med" },
    "Set_Path_C_Med": { "type": "SetAttribute", "attribute": "mrsa_has_med", "value": true, "direct_transition": "Choose_Med" },

    "Choose_Med": {
      "type": "Simple",
      "distributed_transition": [
        { "transition": "Set_Med_Clindamycin", "distribution": 0.70 },
        { "transition": "Set_Med_Linezolid", "distribution": 0.30 }
      ]
    },
    "Set_Med_Clindamycin": { "type": "SetAttribute", "attribute": "mrsa_med_choice", "value": "clindamycin", "direct_transition": "Set_Needs_First_Visit" },
    "Set_Med_Linezolid": { "type": "SetAttribute", "attribute": "mrsa_med_choice", "value": "linezolid", "direct_transition": "Set_Needs_First_Visit" },

    "Set_Needs_First_Visit": { "type": "SetAttribute", "attribute": "mrsa_needs_first_visit", "value": true, "direct_transition": "Wellness_Encounter" },
    "Wellness_Encounter": { "type": "Encounter", "wellness": true, "direct_transition": "Check_First_Visit" },
    "Check_First_Visit": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "mrsa_needs_first_visit", "operator": "==", "value": true }, "transition": "Check_Has_Diagnosis" },
        { "transition": "End_Wellness_Encounter" }
      ]
    },
    "Check_Has_Diagnosis": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "mrsa_has_dx", "operator": "==", "value": true }, "transition": "Diagnose_Mrsa" },
        { "transition": "Check_Med_NoDx" }
      ]
    },
    "Diagnose_Mrsa": { "type": "ConditionOnset", "assign_to_attribute": "mrsa_condition", "codes": [{ "system": "SNOMED-CT", "code": "423561003", "display": "Community-acquired methicillin-resistant Staphylococcus aureus infection" }], "direct_transition": "Check_Med_WithDx" },

    "Check_Med_WithDx": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "mrsa_has_med", "operator": "==", "value": true }, "transition": "Route_Med_WithDx" },
        { "transition": "Clear_First_Visit_Flag" }
      ]
    },
    "Route_Med_WithDx": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "mrsa_med_choice", "operator": "==", "value": "clindamycin" }, "transition": "Prescribe_Clinda_WithDx" },
        { "transition": "Prescribe_Linez_WithDx" }
      ]
    },
    "Prescribe_Clinda_WithDx": { "type": "MedicationOrder", "codes": [{ "system": "RxNorm", "code": "2582", "display": "clindamycin" }], "reason": "mrsa_condition", "direct_transition": "Clear_First_Visit_Flag" },
    "Prescribe_Linez_WithDx": { "type": "MedicationOrder", "codes": [{ "system": "RxNorm", "code": "190376", "display": "linezolid" }], "reason": "mrsa_condition", "direct_transition": "Clear_First_Visit_Flag" },

    "Check_Med_NoDx": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "mrsa_has_med", "operator": "==", "value": true }, "transition": "Route_Med_NoDx" },
        { "transition": "Clear_First_Visit_Flag" }
      ]
    },
    "Route_Med_NoDx": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "mrsa_med_choice", "operator": "==", "value": "clindamycin" }, "transition": "Prescribe_Clinda_NoDx" },
        { "transition": "Prescribe_Linez_NoDx" }
      ]
    },
    "Prescribe_Clinda_NoDx": { "type": "MedicationOrder", "codes": [{ "system": "RxNorm", "code": "2582", "display": "clindamycin" }], "direct_transition": "Clear_First_Visit_Flag" },
    "Prescribe_Linez_NoDx": { "type": "MedicationOrder", "codes": [{ "system": "RxNorm", "code": "190376", "display": "linezolid" }], "direct_transition": "Clear_First_Visit_Flag" },

    "Clear_First_Visit_Flag": { "type": "SetAttribute", "attribute": "mrsa_needs_first_visit", "value": false, "direct_transition": "End_Wellness_Encounter" },
    "End_Wellness_Encounter": { "type": "EncounterEnd", "direct_transition": "Followup_Delay" },
    "Followup_Delay": { "type": "Delay", "range": { "low": 6, "high": 12, "unit": "months" }, "direct_transition": "Wellness_Encounter" }
  },
  "gmf_version": 2
}
