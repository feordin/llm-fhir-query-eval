{
  "name": "PheKB Chronic Rhinosinusitis",
  "remarks": [
    "Custom Synthea module for chronic rhinosinusitis (CRS).",
    "First ENT phenotype.",
    "",
    "Generates THREE patient paths:",
    "  Path A (60%): CRS dx + intranasal mometasone",
    "  Path B (30%): CRS dx only (saline irrigation, supportive)",
    "  Path C (10%): mometasone without CRS dx (TRICKY — mometasone also used for asthma, allergic rhinitis, atopic dermatitis)",
    "",
    "Age guard: >=18."
  ],
  "states": {
    "Initial": { "type": "Initial", "direct_transition": "Age_Guard" },
    "Age_Guard": { "type": "Guard", "allow": { "condition_type": "Age", "operator": ">=", "quantity": 18, "unit": "years" }, "direct_transition": "Set_Crs_Flag" },
    "Set_Crs_Flag": { "type": "SetAttribute", "attribute": "crs_positive", "value": true, "direct_transition": "Choose_Patient_Path" },
    "Choose_Patient_Path": {
      "type": "Simple",
      "distributed_transition": [
        { "transition": "Set_Path_A", "distribution": 0.60 },
        { "transition": "Set_Path_B", "distribution": 0.30 },
        { "transition": "Set_Path_C", "distribution": 0.10 }
      ]
    },
    "Set_Path_A": { "type": "SetAttribute", "attribute": "crs_has_dx", "value": true, "direct_transition": "Set_Path_A_Med" },
    "Set_Path_A_Med": { "type": "SetAttribute", "attribute": "crs_has_med", "value": true, "direct_transition": "Set_Needs_First_Visit" },
    "Set_Path_B": { "type": "SetAttribute", "attribute": "crs_has_dx", "value": true, "direct_transition": "Set_Path_B_Med" },
    "Set_Path_B_Med": { "type": "SetAttribute", "attribute": "crs_has_med", "value": false, "direct_transition": "Set_Needs_First_Visit" },
    "Set_Path_C": { "type": "SetAttribute", "remarks": ["TRICKY: mometasone without CRS dx (cross-indicates allergic rhinitis, asthma)"], "attribute": "crs_has_dx", "value": false, "direct_transition": "Set_Path_C_Med" },
    "Set_Path_C_Med": { "type": "SetAttribute", "attribute": "crs_has_med", "value": true, "direct_transition": "Set_Needs_First_Visit" },

    "Set_Needs_First_Visit": { "type": "SetAttribute", "attribute": "crs_needs_first_visit", "value": true, "direct_transition": "Wellness_Encounter" },
    "Wellness_Encounter": { "type": "Encounter", "wellness": true, "direct_transition": "Check_First_Visit" },
    "Check_First_Visit": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "crs_needs_first_visit", "operator": "==", "value": true }, "transition": "Check_Has_Diagnosis" },
        { "transition": "End_Wellness_Encounter" }
      ]
    },
    "Check_Has_Diagnosis": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "crs_has_dx", "operator": "==", "value": true }, "transition": "Diagnose_Crs" },
        { "transition": "Check_Med_NoDx" }
      ]
    },
    "Diagnose_Crs": { "type": "ConditionOnset", "assign_to_attribute": "crs_condition", "codes": [{ "system": "SNOMED-CT", "code": "40055000", "display": "Chronic sinusitis" }], "direct_transition": "Check_Med_WithDx" },

    "Check_Med_WithDx": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "crs_has_med", "operator": "==", "value": true }, "transition": "Prescribe_Mom_WithDx" },
        { "transition": "Clear_First_Visit_Flag" }
      ]
    },
    "Prescribe_Mom_WithDx": { "type": "MedicationOrder", "codes": [{ "system": "RxNorm", "code": "108118", "display": "mometasone" }], "reason": "crs_condition", "direct_transition": "Clear_First_Visit_Flag" },

    "Check_Med_NoDx": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "crs_has_med", "operator": "==", "value": true }, "transition": "Prescribe_Mom_NoDx" },
        { "transition": "Clear_First_Visit_Flag" }
      ]
    },
    "Prescribe_Mom_NoDx": { "type": "MedicationOrder", "codes": [{ "system": "RxNorm", "code": "108118", "display": "mometasone" }], "direct_transition": "Clear_First_Visit_Flag" },

    "Clear_First_Visit_Flag": { "type": "SetAttribute", "attribute": "crs_needs_first_visit", "value": false, "direct_transition": "End_Wellness_Encounter" },
    "End_Wellness_Encounter": { "type": "EncounterEnd", "direct_transition": "Followup_Delay" },
    "Followup_Delay": { "type": "Delay", "range": { "low": 6, "high": 12, "unit": "months" }, "direct_transition": "Wellness_Encounter" }
  },
  "gmf_version": 2
}
