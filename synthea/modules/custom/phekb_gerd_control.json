{
  "name": "PheKB GERD Control",
  "remarks": [
    "Control module for PheKB GERD phenotype.",
    "Generates patients who do NOT have GERD.",
    "",
    "Controls per PheKB GERD algorithm must:",
    "  - Have no GERD diagnosis",
    "  - Have no GERD-related medications (PPIs)",
    "  - Have 2+ in-person visits in last 5 years",
    "",
    "Controls get NO Condition resources for GERD and NO PPIs."
  ],
  "states": {
    "Initial": { "type": "Initial", "direct_transition": "Age_Guard" },

    "Age_Guard": {
      "type": "Guard",
      "allow": { "condition_type": "Age", "operator": ">=", "quantity": 18, "unit": "years" },
      "direct_transition": "Set_Control_Flag"
    },

    "Set_Control_Flag": { "type": "SetAttribute", "attribute": "gerd_positive", "value": false, "direct_transition": "Wellness_Encounter" },

    "Wellness_Encounter": { "type": "Encounter", "wellness": true, "direct_transition": "End_Wellness_Encounter" },

    "End_Wellness_Encounter": { "type": "EncounterEnd", "direct_transition": "Followup_Delay" },

    "Followup_Delay": {
      "type": "Delay",
      "range": { "low": 12, "high": 24, "unit": "months" },
      "direct_transition": "Wellness_Encounter"
    }
  },
  "gmf_version": 2
}
