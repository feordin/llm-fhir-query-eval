{
  "name": "PheKB Warfarin Dose Response Control",
  "remarks": [
    "Control: age 40+ without warfarin or INR monitoring."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 40,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "wf_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Chronic_atrial_fibrillation"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Chronic_atrial_fibrillation": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Chronic_atrial_fibrillation",
          "distribution": 0.3
        },
        {
          "transition": "Maybe_Mimicker_Deep_venous_thrombosis",
          "distribution": 0.7
        }
      ]
    },
    "Diagnose_Mimicker_Chronic_atrial_fibrillation": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "426749004",
          "display": "Chronic atrial fibrillation"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Deep_venous_thrombosis"
    },
    "Maybe_Mimicker_Deep_venous_thrombosis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Deep_venous_thrombosis",
          "distribution": 0.15
        },
        {
          "transition": "Maybe_Mimicker_Pulmonary_embolism",
          "distribution": 0.85
        }
      ]
    },
    "Diagnose_Mimicker_Deep_venous_thrombosis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "128053003",
          "display": "Deep venous thrombosis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Pulmonary_embolism"
    },
    "Maybe_Mimicker_Pulmonary_embolism": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Pulmonary_embolism",
          "distribution": 0.1
        },
        {
          "transition": "Maybe_Mimicker_Heart_valve_replacement",
          "distribution": 0.9
        }
      ]
    },
    "Diagnose_Mimicker_Pulmonary_embolism": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "59282003",
          "display": "Pulmonary embolism"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Heart_valve_replacement"
    },
    "Maybe_Mimicker_Heart_valve_replacement": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Heart_valve_replacement",
          "distribution": 0.05
        },
        {
          "transition": "Maybe_Mimicker_Thrombophilia",
          "distribution": 0.95
        }
      ]
    },
    "Diagnose_Mimicker_Heart_valve_replacement": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "34068001",
          "display": "Heart valve replacement"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Thrombophilia"
    },
    "Maybe_Mimicker_Thrombophilia": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Thrombophilia",
          "distribution": 0.04
        },
        {
          "transition": "End_Wellness_Encounter",
          "distribution": 0.96
        }
      ]
    },
    "Diagnose_Mimicker_Thrombophilia": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "234467004",
          "display": "Thrombophilia"
        }
      ],
      "direct_transition": "End_Wellness_Encounter"
    }
  },
  "gmf_version": 2
}
