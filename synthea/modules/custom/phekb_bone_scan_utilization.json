{
  "name": "PheKB Bone Scan Utilization (PheKB-aligned)",
  "remarks": [
    "Custom Synthea module for bone scan utilization in prostate cancer patients.",
    "Aligned to PheKB algorithm: male prostate cancer patients age 35+ with bone scan procedure (radioisotope scan of bone).",
    "",
    "Generates SINGLE-PATH module: prostate cancer dx + bone scan procedure.",
    "Cohort definition (per PheKB): male, age 35+, prostate cancer dx, with bone scan within follow-up window.",
    "",
    "Sex guard: M only. Age guard: >=35."
  ],
  "states": {
    "Initial": { "type": "Initial", "direct_transition": "Sex_Guard" },
    "Sex_Guard": { "type": "Guard", "allow": { "condition_type": "Gender", "gender": "M" }, "direct_transition": "Age_Guard" },
    "Age_Guard": { "type": "Guard", "allow": { "condition_type": "Age", "operator": ">=", "quantity": 35, "unit": "years" }, "direct_transition": "Set_Bs_Flag" },
    "Set_Bs_Flag": { "type": "SetAttribute", "attribute": "bs_positive", "value": true, "direct_transition": "Set_Needs_First_Visit" },
    "Set_Needs_First_Visit": { "type": "SetAttribute", "attribute": "bs_needs_first_visit", "value": true, "direct_transition": "Wellness_Encounter" },
    "Wellness_Encounter": { "type": "Encounter", "wellness": true, "direct_transition": "Check_First_Visit" },
    "Check_First_Visit": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "bs_needs_first_visit", "operator": "==", "value": true }, "transition": "Diagnose_PCa" },
        { "transition": "End_Wellness_Encounter" }
      ]
    },
    "Diagnose_PCa": { "type": "ConditionOnset", "codes": [{ "system": "http://hl7.org/fhir/sid/icd-10-cm", "code": "C61", "display": "Malignant neoplasm of prostate" }], "direct_transition": "Bone_Scan_Procedure" },
    "Bone_Scan_Procedure": { "type": "Procedure", "codes": [{ "system": "SNOMED-CT", "code": "41747008", "display": "Radioisotope scan of bone" }], "duration": { "low": 30, "high": 90, "unit": "minutes" }, "direct_transition": "Clear_First_Visit_Flag" },
    "Clear_First_Visit_Flag": { "type": "SetAttribute", "attribute": "bs_needs_first_visit", "value": false, "direct_transition": "End_Wellness_Encounter" },
    "End_Wellness_Encounter": { "type": "EncounterEnd", "direct_transition": "Followup_Delay" },
    "Followup_Delay": { "type": "Delay", "range": { "low": 6, "high": 12, "unit": "months" }, "direct_transition": "Wellness_Encounter" }
  },
  "gmf_version": 2
}
