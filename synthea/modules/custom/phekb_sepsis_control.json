{
  "name": "PheKB Sepsis Control",
  "remarks": [
    "Control module for sepsis. Generates adult patients without sepsis dx, broad-spectrum antibiotics, or elevated lactate."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 18,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "sepsis_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Systemic_inflammatory_response_syndrome"
    },
    "Record_Normal_Lactate": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "mmol/L",
      "codes": [
        {
          "system": "LOINC",
          "code": "2524-7",
          "display": "Lactate [Moles/volume] in Serum or Plasma"
        }
      ],
      "range": {
        "low": 0.5,
        "high": 1.8
      },
      "direct_transition": "End_Wellness_Encounter"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Systemic_inflammatory_response_syndrome": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Systemic_inflammatory_response_syndrome",
          "distribution": 0.15
        },
        {
          "transition": "Maybe_Mimicker_Pneumonia",
          "distribution": 0.85
        }
      ]
    },
    "Diagnose_Mimicker_Systemic_inflammatory_response_syndrome": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "238149007",
          "display": "Systemic inflammatory response syndrome"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Pneumonia"
    },
    "Maybe_Mimicker_Pneumonia": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Pneumonia",
          "distribution": 0.25
        },
        {
          "transition": "Maybe_Mimicker_Urinary_tract_infectious_disease",
          "distribution": 0.75
        }
      ]
    },
    "Diagnose_Mimicker_Pneumonia": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "233604007",
          "display": "Pneumonia"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Urinary_tract_infectious_disease"
    },
    "Maybe_Mimicker_Urinary_tract_infectious_disease": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Urinary_tract_infectious_disease",
          "distribution": 0.2
        },
        {
          "transition": "Maybe_Mimicker_Acute_pancreatitis",
          "distribution": 0.8
        }
      ]
    },
    "Diagnose_Mimicker_Urinary_tract_infectious_disease": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "68566005",
          "display": "Urinary tract infectious disease"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Acute_pancreatitis"
    },
    "Maybe_Mimicker_Acute_pancreatitis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Acute_pancreatitis",
          "distribution": 0.08
        },
        {
          "transition": "Maybe_Mimicker_Cellulitis",
          "distribution": 0.92
        }
      ]
    },
    "Diagnose_Mimicker_Acute_pancreatitis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "197456007",
          "display": "Acute pancreatitis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Cellulitis"
    },
    "Maybe_Mimicker_Cellulitis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Cellulitis",
          "distribution": 0.1
        },
        {
          "transition": "Record_Normal_Lactate",
          "distribution": 0.9
        }
      ]
    },
    "Diagnose_Mimicker_Cellulitis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "128045006",
          "display": "Cellulitis"
        }
      ],
      "direct_transition": "Record_Normal_Lactate"
    }
  },
  "gmf_version": 2
}
