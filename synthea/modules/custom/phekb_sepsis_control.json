{
  "name": "PheKB Sepsis Control",
  "remarks": ["Control module for sepsis. Generates adult patients without sepsis dx, broad-spectrum antibiotics, or elevated lactate."],
  "states": {
    "Initial": { "type": "Initial", "direct_transition": "Age_Guard" },
    "Age_Guard": { "type": "Guard", "allow": { "condition_type": "Age", "operator": ">=", "quantity": 18, "unit": "years" }, "direct_transition": "Set_Control_Flag" },
    "Set_Control_Flag": { "type": "SetAttribute", "attribute": "sepsis_positive", "value": false, "direct_transition": "Wellness_Encounter" },
    "Wellness_Encounter": { "type": "Encounter", "wellness": true, "direct_transition": "Record_Normal_Lactate" },
    "Record_Normal_Lactate": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "mmol/L",
      "codes": [{ "system": "LOINC", "code": "2524-7", "display": "Lactate [Moles/volume] in Serum or Plasma" }],
      "range": { "low": 0.5, "high": 1.8 },
      "direct_transition": "End_Wellness_Encounter"
    },
    "End_Wellness_Encounter": { "type": "EncounterEnd", "direct_transition": "Followup_Delay" },
    "Followup_Delay": { "type": "Delay", "range": { "low": 12, "high": 24, "unit": "months" }, "direct_transition": "Wellness_Encounter" }
  },
  "gmf_version": 2
}
