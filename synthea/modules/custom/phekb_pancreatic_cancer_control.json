{
  "name": "PheKB Pancreatic Cancer Control",
  "remarks": [
    "Control module for pancreatic cancer. Generates patients age 45+ without pancreatic cancer dx and normal CA 19-9 (<37 U/mL)."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 45,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "panc_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Chronic_pancreatitis"
    },
    "Record_Normal_CA199": {
      "type": "Observation",
      "category": "laboratory",
      "unit": "U/mL",
      "codes": [
        {
          "system": "LOINC",
          "code": "24108-3",
          "display": "Cancer Ag 19-9 [Units/volume] in Serum or Plasma"
        }
      ],
      "range": {
        "low": 5,
        "high": 35
      },
      "direct_transition": "End_Wellness_Encounter"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Chronic_pancreatitis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Chronic_pancreatitis",
          "distribution": 0.15
        },
        {
          "transition": "Maybe_Mimicker_Acute_pancreatitis",
          "distribution": 0.85
        }
      ]
    },
    "Diagnose_Mimicker_Chronic_pancreatitis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "235494005",
          "display": "Chronic pancreatitis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Acute_pancreatitis"
    },
    "Maybe_Mimicker_Acute_pancreatitis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Acute_pancreatitis",
          "distribution": 0.1
        },
        {
          "transition": "Maybe_Mimicker_Gallstone",
          "distribution": 0.9
        }
      ]
    },
    "Diagnose_Mimicker_Acute_pancreatitis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "197456007",
          "display": "Acute pancreatitis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Gallstone"
    },
    "Maybe_Mimicker_Gallstone": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Gallstone",
          "distribution": 0.2
        },
        {
          "transition": "Maybe_Mimicker_Cyst_of_pancreas",
          "distribution": 0.8
        }
      ]
    },
    "Diagnose_Mimicker_Gallstone": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "256896000",
          "display": "Gallstone"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Cyst_of_pancreas"
    },
    "Maybe_Mimicker_Cyst_of_pancreas": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Cyst_of_pancreas",
          "distribution": 0.08
        },
        {
          "transition": "Maybe_Mimicker_Cholangiocarcinoma",
          "distribution": 0.92
        }
      ]
    },
    "Diagnose_Mimicker_Cyst_of_pancreas": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "31258000",
          "display": "Cyst of pancreas"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Cholangiocarcinoma"
    },
    "Maybe_Mimicker_Cholangiocarcinoma": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Cholangiocarcinoma",
          "distribution": 0.04
        },
        {
          "transition": "Record_Normal_CA199",
          "distribution": 0.96
        }
      ]
    },
    "Diagnose_Mimicker_Cholangiocarcinoma": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "70179006",
          "display": "Cholangiocarcinoma"
        }
      ],
      "direct_transition": "Record_Normal_CA199"
    }
  },
  "gmf_version": 2
}
