{
  "name": "PheKB Sickle Cell Disease Control",
  "remarks": [
    "Control module for PheKB sickle cell disease phenotype.",
    "Generates patients who do NOT have sickle cell disease.",
    "",
    "Control patients have sickle cell TRAIT (carrier status, not disease),",
    "which is the explicit exclusion criterion in the PheKB algorithm.",
    "This tests whether LLMs can distinguish SCD from sickle cell trait.",
    "",
    "SNOMED 16402000 = Sickle cell trait (disorder)",
    "ICD-10-CM D57.3 = Sickle cell trait"
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 1,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "scd_positive",
      "value": false,
      "direct_transition": "Set_Needs_First_Visit"
    },
    "Set_Needs_First_Visit": {
      "type": "SetAttribute",
      "attribute": "scd_needs_first_visit",
      "value": true,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Beta_thalassemia"
    },
    "Check_First_Visit": {
      "type": "Simple",
      "conditional_transition": [
        {
          "condition": {
            "condition_type": "Attribute",
            "attribute": "scd_needs_first_visit",
            "operator": "==",
            "value": true
          },
          "transition": "Diagnose_Sickle_Cell_Trait"
        },
        {
          "transition": "End_Wellness_Encounter"
        }
      ]
    },
    "Diagnose_Sickle_Cell_Trait": {
      "type": "ConditionOnset",
      "assign_to_attribute": "scd_trait_condition",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "16402000",
          "display": "Sickle cell trait"
        }
      ],
      "direct_transition": "Clear_First_Visit_Flag"
    },
    "Clear_First_Visit_Flag": {
      "type": "SetAttribute",
      "attribute": "scd_needs_first_visit",
      "value": false,
      "direct_transition": "End_Wellness_Encounter"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 6,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Beta_thalassemia": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Beta_thalassemia",
          "distribution": 0.05
        },
        {
          "transition": "Maybe_Mimicker_Iron_deficiency_anemia",
          "distribution": 0.95
        }
      ]
    },
    "Diagnose_Mimicker_Beta_thalassemia": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "65959000",
          "display": "Beta thalassemia"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Iron_deficiency_anemia"
    },
    "Maybe_Mimicker_Iron_deficiency_anemia": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Iron_deficiency_anemia",
          "distribution": 0.2
        },
        {
          "transition": "Maybe_Mimicker_Hemolytic_anemia",
          "distribution": 0.8
        }
      ]
    },
    "Diagnose_Mimicker_Iron_deficiency_anemia": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "87522002",
          "display": "Iron deficiency anemia"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Hemolytic_anemia"
    },
    "Maybe_Mimicker_Hemolytic_anemia": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Hemolytic_anemia",
          "distribution": 0.08
        },
        {
          "transition": "Maybe_Mimicker_Hereditary_spherocytosis",
          "distribution": 0.92
        }
      ]
    },
    "Diagnose_Mimicker_Hemolytic_anemia": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "61261009",
          "display": "Hemolytic anemia"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Hereditary_spherocytosis"
    },
    "Maybe_Mimicker_Hereditary_spherocytosis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Hereditary_spherocytosis",
          "distribution": 0.02
        },
        {
          "transition": "Check_First_Visit",
          "distribution": 0.98
        }
      ]
    },
    "Diagnose_Mimicker_Hereditary_spherocytosis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "55995005",
          "display": "Hereditary spherocytosis"
        }
      ],
      "direct_transition": "Check_First_Visit"
    }
  },
  "gmf_version": 2
}
