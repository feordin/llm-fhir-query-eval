{
  "name": "PheKB Clostridium difficile colitis Control",
  "remarks": [
    "Control module. Generates patients age 18+ without C. diff dx or vancomycin."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 18,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "cdiff_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Viral_gastroenteritis"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Viral_gastroenteritis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Viral_gastroenteritis",
          "distribution": 0.2
        },
        {
          "transition": "Maybe_Mimicker_Antibiotic_associated_diarrhea",
          "distribution": 0.8
        }
      ]
    },
    "Diagnose_Mimicker_Viral_gastroenteritis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "111843007",
          "display": "Viral gastroenteritis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Antibiotic_associated_diarrhea"
    },
    "Maybe_Mimicker_Antibiotic_associated_diarrhea": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Antibiotic_associated_diarrhea",
          "distribution": 0.15
        },
        {
          "transition": "Maybe_Mimicker_Bacterial_gastroenteritis",
          "distribution": 0.85
        }
      ]
    },
    "Diagnose_Mimicker_Antibiotic_associated_diarrhea": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "301469002",
          "display": "Antibiotic-associated diarrhea"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Bacterial_gastroenteritis"
    },
    "Maybe_Mimicker_Bacterial_gastroenteritis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Bacterial_gastroenteritis",
          "distribution": 0.08
        },
        {
          "transition": "Maybe_Mimicker_Salmonella_infection",
          "distribution": 0.92
        }
      ]
    },
    "Diagnose_Mimicker_Bacterial_gastroenteritis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "274080003",
          "display": "Bacterial gastroenteritis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Salmonella_infection"
    },
    "Maybe_Mimicker_Salmonella_infection": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Salmonella_infection",
          "distribution": 0.04
        },
        {
          "transition": "Maybe_Mimicker_Microscopic_colitis",
          "distribution": 0.96
        }
      ]
    },
    "Diagnose_Mimicker_Salmonella_infection": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "302231008",
          "display": "Salmonella infection"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Microscopic_colitis"
    },
    "Maybe_Mimicker_Microscopic_colitis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Microscopic_colitis",
          "distribution": 0.03
        },
        {
          "transition": "End_Wellness_Encounter",
          "distribution": 0.97
        }
      ]
    },
    "Diagnose_Mimicker_Microscopic_colitis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "235753003",
          "display": "Microscopic colitis"
        }
      ],
      "direct_transition": "End_Wellness_Encounter"
    }
  },
  "gmf_version": 2
}
