{
  "name": "PheKB Alcohol Use Disorder",
  "remarks": [
    "Custom Synthea module for alcohol use disorder.",
    "First substance use disorder phenotype.",
    "",
    "Generates THREE patient paths:",
    "  Path A (50%): AUD dx + naltrexone Rx",
    "  Path B (35%): AUD dx, no medication (most common — pharmacotherapy underutilized)",
    "  Path C (15%): Naltrexone without AUD dx (TRICKY — also for opioid use disorder)",
    "",
    "Diagnosis SNOMED variation:",
    "  60% Alcoholism (7200002)",
    "  40% Alcohol dependence (66590003)",
    "",
    "Age guard: >=18."
  ],
  "states": {
    "Initial": { "type": "Initial", "direct_transition": "Age_Guard" },
    "Age_Guard": { "type": "Guard", "allow": { "condition_type": "Age", "operator": ">=", "quantity": 18, "unit": "years" }, "direct_transition": "Set_AUD_Flag" },
    "Set_AUD_Flag": { "type": "SetAttribute", "attribute": "aud_positive", "value": true, "direct_transition": "Choose_Patient_Path" },
    "Choose_Patient_Path": {
      "type": "Simple",
      "distributed_transition": [
        { "transition": "Set_Path_A", "distribution": 0.50 },
        { "transition": "Set_Path_B", "distribution": 0.35 },
        { "transition": "Set_Path_C", "distribution": 0.15 }
      ]
    },
    "Set_Path_A": { "type": "SetAttribute", "attribute": "aud_has_dx", "value": true, "direct_transition": "Set_Path_A_Med" },
    "Set_Path_A_Med": { "type": "SetAttribute", "attribute": "aud_has_med", "value": true, "direct_transition": "Choose_Subtype" },
    "Set_Path_B": { "type": "SetAttribute", "attribute": "aud_has_dx", "value": true, "direct_transition": "Set_Path_B_Med" },
    "Set_Path_B_Med": { "type": "SetAttribute", "attribute": "aud_has_med", "value": false, "direct_transition": "Choose_Subtype" },
    "Set_Path_C": { "type": "SetAttribute", "remarks": ["TRICKY: naltrexone without AUD dx — could be OUD"], "attribute": "aud_has_dx", "value": false, "direct_transition": "Set_Path_C_Med" },
    "Set_Path_C_Med": { "type": "SetAttribute", "attribute": "aud_has_med", "value": true, "direct_transition": "Choose_Subtype" },

    "Choose_Subtype": {
      "type": "Simple",
      "distributed_transition": [
        { "transition": "Set_Subtype_Alcoholism", "distribution": 0.60 },
        { "transition": "Set_Subtype_Dependence", "distribution": 0.40 }
      ]
    },
    "Set_Subtype_Alcoholism": { "type": "SetAttribute", "attribute": "aud_subtype", "value": "alcoholism", "direct_transition": "Set_Needs_First_Visit" },
    "Set_Subtype_Dependence": { "type": "SetAttribute", "attribute": "aud_subtype", "value": "dependence", "direct_transition": "Set_Needs_First_Visit" },

    "Set_Needs_First_Visit": { "type": "SetAttribute", "attribute": "aud_needs_first_visit", "value": true, "direct_transition": "Wellness_Encounter" },
    "Wellness_Encounter": { "type": "Encounter", "wellness": true, "direct_transition": "Check_First_Visit" },
    "Check_First_Visit": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "aud_needs_first_visit", "operator": "==", "value": true }, "transition": "Check_Has_Diagnosis" },
        { "transition": "End_Wellness_Encounter" }
      ]
    },
    "Check_Has_Diagnosis": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "aud_has_dx", "operator": "==", "value": true }, "transition": "Route_By_Subtype" },
        { "transition": "Check_Med_NoDx" }
      ]
    },
    "Route_By_Subtype": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "aud_subtype", "operator": "==", "value": "alcoholism" }, "transition": "Diagnose_Alcoholism" },
        { "transition": "Diagnose_Dependence" }
      ]
    },
    "Diagnose_Alcoholism": { "type": "ConditionOnset", "assign_to_attribute": "aud_condition", "codes": [{ "system": "SNOMED-CT", "code": "7200002", "display": "Alcoholism" }], "direct_transition": "Check_Med_WithDx" },
    "Diagnose_Dependence": { "type": "ConditionOnset", "assign_to_attribute": "aud_condition", "codes": [{ "system": "SNOMED-CT", "code": "66590003", "display": "Alcohol dependence" }], "direct_transition": "Check_Med_WithDx" },

    "Check_Med_WithDx": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "aud_has_med", "operator": "==", "value": true }, "transition": "Prescribe_Naltrexone_WithDx" },
        { "transition": "Clear_First_Visit_Flag" }
      ]
    },
    "Prescribe_Naltrexone_WithDx": { "type": "MedicationOrder", "codes": [{ "system": "RxNorm", "code": "7243", "display": "naltrexone" }], "reason": "aud_condition", "direct_transition": "Clear_First_Visit_Flag" },

    "Check_Med_NoDx": {
      "type": "Simple",
      "conditional_transition": [
        { "condition": { "condition_type": "Attribute", "attribute": "aud_has_med", "operator": "==", "value": true }, "transition": "Prescribe_Naltrexone_NoDx" },
        { "transition": "Clear_First_Visit_Flag" }
      ]
    },
    "Prescribe_Naltrexone_NoDx": { "type": "MedicationOrder", "codes": [{ "system": "RxNorm", "code": "7243", "display": "naltrexone" }], "direct_transition": "Clear_First_Visit_Flag" },

    "Clear_First_Visit_Flag": { "type": "SetAttribute", "attribute": "aud_needs_first_visit", "value": false, "direct_transition": "End_Wellness_Encounter" },
    "End_Wellness_Encounter": { "type": "EncounterEnd", "direct_transition": "Followup_Delay" },
    "Followup_Delay": { "type": "Delay", "range": { "low": 6, "high": 12, "unit": "months" }, "direct_transition": "Wellness_Encounter" }
  },
  "gmf_version": 2
}
