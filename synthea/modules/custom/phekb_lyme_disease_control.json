{
  "name": "PheKB Lyme Disease Control",
  "remarks": [
    "Control module for Lyme disease. Generates patients age 1+ without Lyme dx or doxycycline."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Age_Guard"
    },
    "Age_Guard": {
      "type": "Guard",
      "allow": {
        "condition_type": "Age",
        "operator": ">=",
        "quantity": 1,
        "unit": "years"
      },
      "direct_transition": "Set_Control_Flag"
    },
    "Set_Control_Flag": {
      "type": "SetAttribute",
      "attribute": "lyme_positive",
      "value": false,
      "direct_transition": "Wellness_Encounter"
    },
    "Wellness_Encounter": {
      "type": "Encounter",
      "wellness": true,
      "direct_transition": "Maybe_Mimicker_Cellulitis"
    },
    "End_Wellness_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Followup_Delay"
    },
    "Followup_Delay": {
      "type": "Delay",
      "range": {
        "low": 12,
        "high": 24,
        "unit": "months"
      },
      "direct_transition": "Wellness_Encounter"
    },
    "Maybe_Mimicker_Cellulitis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Cellulitis",
          "distribution": 0.2
        },
        {
          "transition": "Maybe_Mimicker_Rheumatoid_arthritis",
          "distribution": 0.8
        }
      ]
    },
    "Diagnose_Mimicker_Cellulitis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "128045006",
          "display": "Cellulitis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Rheumatoid_arthritis"
    },
    "Maybe_Mimicker_Rheumatoid_arthritis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Rheumatoid_arthritis",
          "distribution": 0.1
        },
        {
          "transition": "Maybe_Mimicker_Bell_s_palsy",
          "distribution": 0.9
        }
      ]
    },
    "Diagnose_Mimicker_Rheumatoid_arthritis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "69896004",
          "display": "Rheumatoid arthritis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Bell_s_palsy"
    },
    "Maybe_Mimicker_Bell_s_palsy": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Bell_s_palsy",
          "distribution": 0.06
        },
        {
          "transition": "Maybe_Mimicker_Babesiosis",
          "distribution": 0.94
        }
      ]
    },
    "Diagnose_Mimicker_Bell_s_palsy": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "193093009",
          "display": "Bell's palsy"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Babesiosis"
    },
    "Maybe_Mimicker_Babesiosis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Babesiosis",
          "distribution": 0.04
        },
        {
          "transition": "Maybe_Mimicker_Anaplasmosis",
          "distribution": 0.96
        }
      ]
    },
    "Diagnose_Mimicker_Babesiosis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "21061004",
          "display": "Babesiosis"
        }
      ],
      "direct_transition": "Maybe_Mimicker_Anaplasmosis"
    },
    "Maybe_Mimicker_Anaplasmosis": {
      "type": "Simple",
      "distributed_transition": [
        {
          "transition": "Diagnose_Mimicker_Anaplasmosis",
          "distribution": 0.03
        },
        {
          "transition": "End_Wellness_Encounter",
          "distribution": 0.97
        }
      ]
    },
    "Diagnose_Mimicker_Anaplasmosis": {
      "type": "ConditionOnset",
      "codes": [
        {
          "system": "http://snomed.info/sct",
          "code": "13906002",
          "display": "Anaplasmosis"
        }
      ],
      "direct_transition": "End_Wellness_Encounter"
    }
  },
  "gmf_version": 2
}
