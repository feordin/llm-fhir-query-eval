    "implementation_guide": "US Core 5.0.0",
    "multi_query": true,
    "algorithm_path": "comprehensive",
    "algorithm_path_description": "Union of breast cancer dx codes (Paths A+B) and endocrine therapy/HER2 therapy Rx (Paths A+C). Path C is small (~15%) because chemoprevention is a niche use.",
