      "ICD-10-CM",
      "LOINC"
    ],
    "required_codes": [
      {
        "system": "http://hl7.org/fhir/sid/icd-10-cm",
        "code": "M41.9",
        "display": "Scoliosis, unspecified",
        "source": "PheKB + UMLS verified"
      },
      {
        "system": "http://loinc.org",
        "code": "38208-5",
        "display": "Pain severity - Reported",
        "source": "PheKB + UMLS verified"
      }
    ],
    "complexity": "expert",
    "tags": [
      "multi-query",
      "comprehensive",
      "pediatric",
      "post-op",
      "pain",
      "scoliosis"
    ],
    "patient_filters": {
      "min_age_years": 6,
      "max_age_years": 21
    },
    "multi_query": true,
