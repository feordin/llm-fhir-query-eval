  "id": "phekb-post-event-pain-comprehensive",
  "source": "phekb",
  "source_id": "post-event-pain",
  "name": "Post-event Pain - Comprehensive Query (Pediatric Scoliosis + Pain Score)",
  "description": "Tests ability to find pediatric scoliosis-surgery patients with post-operative pain assessment. Per PheKB algorithm, the cohort requires age ≥6 + scoliosis dx + surgery + ≥3 NRS pain scores per encounter.",
  "prompt": "Find pediatric scoliosis patients with post-operative pain severity scores.",
  "prompts": {
    "naive": "Find pediatric pain patients.",
    "broad": "Find pediatric scoliosis surgery patients with documented post-operative pain severity scores (NRS 0-10) — used in pain pharmacogenetics studies.",
    "expert": "Run two queries. (1) Condition?code=http://hl7.org/fhir/sid/icd-10-cm|M41.9 — scoliosis. (2) Observation?code=http://loinc.org|38208-5&value-quantity=ge4 — pain score >=4. Union the patient IDs."
  },
