{
  "id": "phekb-hepatitis-c-dx",
  "source": "phekb",
  "source_id": "hepatitis-c",
  "name": "Hepatitis C - Diagnosis Code Query (Acute + Chronic)",
  "description": "Tests ability to find hepatitis C virus (HCV) infection patients via diagnosis codes. HCV is documented under multiple SNOMED codes by acuity: Viral hepatitis C (parent), Acute hepatitis C, Chronic hepatitis C. Most diagnosed cases are chronic (>80%) since acute HCV is often asymptomatic and undetected. Synthea distributes patients across these codes. An LLM querying only the parent will miss patients coded with the acuity-specific subtypes.",
  "prompt": "Find all patients with a diagnosis of hepatitis C virus infection, including acute and chronic forms.",
  "prompts": {
    "naive": "Find all patients with hepatitis C.",
    "broad": "Find all patients diagnosed with hepatitis C virus (HCV) infection \u2014 including the parent viral hepatitis C concept, acute hepatitis C, and chronic hepatitis C. Most diagnosed HCV is chronic.",
    "expert": "I need to identify all hepatitis C patients. HCV is documented under multiple SNOMED codes by acuity: Viral hepatitis type C (50711007) is the parent, with subtype variants Chronic hepatitis C (128302006) and Acute hepatitis C (235866006). The CSTE 'Acute Hepatitis C Virus Infection (Disorders)' VSAC (OID 2.16.840.1.113762.1.4.1146.2679) documents the acute codes. Search Condition resources for all three codes."
  },
  "metadata": {
    "implementation_guide": "US Core 5.0.0",
    "algorithm_path": "diagnosis-path",
    "algorithm_path_description": "Patients with HCV diagnosis codes (Paths A and B). The parent + acuity subtypes pattern is common for infectious diseases.",
    "code_systems": [
      "SNOMED CT",
      "ICD-10-CM"
    ],
