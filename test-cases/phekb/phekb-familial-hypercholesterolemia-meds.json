{
  "id": "phekb-familial-hypercholesterolemia-meds",
  "source": "phekb",
  "source_id": "familial-hypercholesterolemia",
  "name": "Familial Hypercholesterolemia - Statin Therapy Query",
  "description": "Tests ability to find FH patients via statin (HMG-CoA reductase inhibitor) prescriptions. The PheKB FH algorithm uses a 30% LDL reduction adjustment for patients on lipid-lowering therapy. High-intensity statins (atorvastatin 40-80mg, rosuvastatin 20-40mg) are first-line for FH. Synthea distributes patients across 5 statins. An LLM querying only atorvastatin will miss patients on simvastatin/rosuvastatin/pravastatin/lovastatin.",
  "prompt": "Find patients prescribed statin medications used for cholesterol management, including atorvastatin, simvastatin, rosuvastatin, pravastatin, or lovastatin.",
  "prompts": {
    "naive": "Find patients on statins.",
    "broad": "Find patients prescribed any HMG-CoA reductase inhibitor (statin) for cholesterol management \u2014 atorvastatin, simvastatin, rosuvastatin, pravastatin, or lovastatin.",
    "expert": "I need MedicationRequest resources for any statin. Use these RxNorm ingredient codes: 83367 (atorvastatin), 36567 (simvastatin), 301542 (rosuvastatin), 42463 (pravastatin), 6472 (lovastatin). Combine in a single comma-separated code search."
  },
  "metadata": {
    "implementation_guide": "US Core 5.0.0",
    "algorithm_path": "medication-path",
    "algorithm_path_description": "Patients with statin orders (Paths A and C). Statins have heavy cross-indication use beyond FH \u2014 they're first-line for general high cholesterol, secondary prevention after MI, and primary prevention based on ASCVD risk. Path C (statins for non-FH) is therefore very large.",
    "code_systems": [
      "RxNorm"
    ],
