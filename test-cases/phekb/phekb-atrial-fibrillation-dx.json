{
  "id": "phekb-atrial-fibrillation-dx",
  "source": "phekb",
  "source_id": "atrial-fibrillation-demonstration-project",
  "name": "Atrial Fibrillation - Diagnosis Code Query",
  "description": "Tests ability to find patients with atrial fibrillation by diagnosis code. The PheKB AF algorithm identifies cases as patients with an AF diagnosis and absence of heart transplant. This test case focuses on the core inclusion criterion: finding Condition resources coded as atrial fibrillation.",
  "prompt": "Find all patients diagnosed with atrial fibrillation.",
  "prompts": {
    "naive": "Find all patients diagnosed with atrial fibrillation.",
    "expert": "I need to identify patients with atrial fibrillation by searching their diagnosis records. Atrial fibrillation has a specific SNOMED code, and the query should target Condition resources. Be aware that AF may also be documented as atrial flutter (a related but distinct arrhythmia) in some patients, though for this query we want specifically atrial fibrillation. The PheKB AF algorithm uses the diagnosis code as the primary inclusion criterion, with exclusion of patients who have had a heart transplant. This query focuses on the inclusion side -- finding all patients with an AF diagnosis on their problem list or encounter records."
  },
  "metadata": {
    "implementation_guide": "US Core 5.0.0",
    "algorithm_path": "case-inclusion",
    "algorithm_path_description": "Patients with atrial fibrillation diagnosis codes recorded as Condition resources. This is the primary case identification path in the PheKB AF algorithm.",
