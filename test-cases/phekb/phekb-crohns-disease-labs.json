{
  "id": "phekb-crohns-disease-labs",
  "source": "phekb",
  "source_id": "crohns-disease",
  "name": "Crohn's Disease - Fecal Calprotectin Lab Query (Elevated)",
  "description": "Tests ability to find Crohn's patients via elevated fecal calprotectin. Calprotectin is a neutrophil-derived protein elevated in active intestinal inflammation. The clinical cutoff for active IBD is typically >250 mcg/g (some labs use >150). The Synthea module generates calprotectin >500 mcg/g for active Crohn's patients.",
  "prompt": "Find patients with elevated fecal calprotectin lab results greater than 250 micrograms per gram of stool — the clinical threshold suggesting active inflammatory bowel disease.",
  "prompts": {
    "naive": "Find patients with high calprotectin.",
    "broad": "Find patients with elevated fecal calprotectin (a stool marker of intestinal inflammation) — values greater than 250 mcg/g of stool, suggesting active IBD.",
    "expert": "I need to identify patients with evidence of active intestinal inflammation via an elevated fecal calprotectin result. Query Observation resources for the fecal calprotectin test (coded in LOINC as calprotectin measured by mass per mass in stool) and filter to results above the clinical threshold for active IBD — generally above 250 micrograms per gram, a level that distinguishes inflammatory bowel disease from functional disorders like IBS. This captures Crohn's patients through their laboratory evidence rather than their diagnosis or medication record."
  },
