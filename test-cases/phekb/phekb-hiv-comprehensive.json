    "multi_query": true,
    "algorithm_path": "comprehensive",
    "algorithm_path_description": "Union of HIV dx codes, ART Rx, and AIDS-defining CD4 counts. Tests comprehensive identification across diagnosis, treatment, and lab evidence streams.",
