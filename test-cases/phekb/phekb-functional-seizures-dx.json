  "source_id": "functional-seizures",
  "name": "Functional Seizures (PNES) - Diagnosis Code Query",
  "description": "Tests ability to find psychogenic non-epileptic seizure (PNES) patients by SNOMED diagnosis code. First psychogenic neurologic phenotype distinct from epilepsy. SNOMED uses the older term 'Dissociative convulsions'.",
  "prompt": "Find all patients with a diagnosis of functional seizures (also known as psychogenic non-epileptic seizures or dissociative convulsions).",
  "prompts": {
    "naive": "Find patients with PNES.",
    "broad": "Find patients diagnosed with functional seizures or psychogenic non-epileptic seizures — episodes resembling epileptic seizures but without abnormal cortical electrical activity, often related to psychological stressors.",
    "expert": "Search Condition resources for SNOMED 191714002 (Dissociative convulsions). Query: Condition?code=http://snomed.info/sct|191714002"
  },
