{
  "id": "phekb-appendicitis-comprehensive",
  "source": "phekb",
  "source_id": "appendicitis",
  "name": "Appendicitis - Comprehensive Provider Query (Diagnosis + Procedure)",
  "description": "Simulates a surgeon who needs to identify all appendicitis patients for an outcomes study. The prompt explains that some patients may have an appendectomy procedure documented without a separate appendicitis diagnosis code, requiring the LLM to generate both a Condition query and a Procedure query. This is the hardest appendicitis test \u2014 it requires clinical reasoning about how appendicitis evidence can be captured in different FHIR resource types.",
  "prompt": "Find all patients with appendicitis. Search both diagnoses and appendectomy procedures to capture the complete population.",
  "prompts": {
    "naive": "Find all patients with appendicitis. Search both diagnoses and appendectomy procedures to capture the complete population.",
    "expert": "I am conducting a surgical outcomes study on appendicitis and need to identify my complete appendicitis patient population. I know from experience that not all appendicitis patients have a formal diagnosis code in their chart \u2014 some patients went directly to surgery and only have an appendectomy procedure documented without a separate appendicitis diagnosis. Please run multiple FHIR queries to capture the full population:\n\n1. Patients with an acute appendicitis diagnosis on their problem list\n2. Patients who have had an appendectomy procedure performed\n\nFor each query, return the matching resources. I want to see the union of all patients found across both approaches to ensure I capture everyone."
  },
  "metadata": {
    "implementation_guide": "US Core 5.0.0",
    "algorithm_paths": "all-case-types",
    "algorithm_path_description": "Comprehensive multi-query approach that mirrors how a real surgeon would identify the full appendicitis population. Requires the LLM to generate 2 separate FHIR queries (Condition + Procedure) and combine results. Tests clinical reasoning about procedure-only documentation patterns.",
    "code_systems": [
      "SNOMED CT"
    ],
    "required_codes": [
      {
        "system": "http://snomed.info/sct",
        "code": "85189001",
        "display": "Acute appendicitis",
        "source": "UMLS verified, code variation"
      },
      {
        "system": "http://snomed.info/sct",
        "code": "74400008",
        "display": "Appendicitis",
        "source": "UMLS verified, code variation"
      }
    ],
    "complexity": "expert",
    "multi_query": true,
    "expected_queries": [
      "Condition?code=http://snomed.info/sct|85189001,http://snomed.info/sct|74400008",
      "Procedure?code=http://snomed.info/sct|80146002"
    ],
    "tags": [
      "multi-query",
      "comprehensive",
      "provider-perspective",
      "condition",
      "procedure",
      "surgery",
      "appendicitis"
    ]
  },
  "expected_query": {
    "resource_type": "Patient",
    "parameters": {},
    "url": "Condition?code=http://snomed.info/sct|85189001,http://snomed.info/sct|74400008",
    "notes": "This test case expects MULTIPLE queries (see metadata.expected_queries). The expected_query.url is the minimum viable query. Evaluation unions patient IDs from both queries to get the complete appendicitis population."
  },
