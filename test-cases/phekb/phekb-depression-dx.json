{
  "id": "phekb-depression-dx",
  "source": "phekb",
  "source_id": "depression",
  "name": "Depression - Diagnosis Code Query (Multi-Subtype)",
  "description": "Tests ability to find depression patients via diagnosis codes. The PheKB depression algorithm classifies into severity types \u2014 depression with psychosis, major depressive disorder, non-major depressive disorder. Synthea distributes patients across SNOMED codes for the depression family: Major depressive disorder, Major depression single episode, Recurrent major depression, Dysthymia, and the parent Depressive disorder. An LLM that queries only one code (e.g., MDD) will miss patients coded as recurrent or dysthymia.",
  "prompt": "Find all patients with a diagnosis of depression, including major depressive disorder (single episode and recurrent) and dysthymia (persistent depressive disorder).",
  "prompts": {
    "naive": "Find all patients with depression.",
    "broad": "Find all patients diagnosed with any form of depression \u2014 including major depressive disorder (both single-episode and recurrent variants), dysthymia (persistent depressive disorder), and other depressive disorders.",
    "expert": "I need to identify all depression patients in our population. Depression is documented under multiple related SNOMED codes: Major depressive disorder (370143000) is the most common, with subtypes Major depression single episode (36923009) and Recurrent major depression (66344007). Dysthymia (78667006) represents persistent low-grade depression. The parent concept Depressive disorder (35489007) is sometimes used for less specific documentation. Search Condition resources for all five codes."
  },
  "metadata": {
    "implementation_guide": "US Core 5.0.0",
    "algorithm_path": "diagnosis-path",
    "algorithm_path_description": "Patients with depression diagnosis codes (Paths A and B). Maps to PheKB depression algorithm criterion for ICD-9/ICD-10 depression codes. Does NOT find Path C patients (on SSRIs without formal dx) \u2014 a substantial subset because SSRIs are widely prescribed for many indications.",
    "code_systems": [
      "SNOMED CT",
      "ICD-10-CM"
    ],
    "required_codes": [
      {
        "system": "http://snomed.info/sct",
        "code": "370143000",
        "display": "Major depressive disorder",
        "source": "UMLS verified"
      },
      {
        "system": "http://snomed.info/sct",
        "code": "36923009",
        "display": "Major depression, single episode (disorder)",
