  "id": "phekb-severe-childhood-obesity-labs",
  "source": "phekb",
  "source_id": "severe-childhood-obesity",
  "name": "Severe Childhood Obesity - Elevated BMI Query",
  "description": "Tests ability to find pediatric obesity patients via elevated BMI Observations. While adult obesity uses BMI≥30, pediatric obesity should use age/sex-specific BMI percentiles (≥95th = obese, ≥99th = severe). For testing purposes, this case uses BMI≥30 as the severe threshold (corresponds to roughly 99th percentile in adolescents).",
  "prompt": "Find patients with elevated BMI lab/measurement results greater than or equal to 30 kg/m².",
  "prompts": {
    "naive": "Find patients with high BMI.",
    "broad": "Find patients with body mass index (BMI) measurements at or above 30 kg/m² — the threshold for class I obesity in adults, corresponding roughly to the 99th percentile in adolescents (severe pediatric obesity).",
    "expert": "I need Observation resources with elevated BMI. Use LOINC code 39156-5 (Body mass index [Ratio]). Filter by value-quantity at or above 30 kg/m². Query: Observation?code=http://loinc.org|39156-5&value-quantity=ge30||kg/m2"
  },
  "metadata": {
    "implementation_guide": "US Core 5.0.0",
    "algorithm_path": "labs-path",
    "algorithm_path_description": "Patients with elevated BMI Observations. Note: adult obesity threshold (≥30); pediatric should use age-percentile cutoffs.",
