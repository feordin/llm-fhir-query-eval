{
  "id": "phekb-breast-cancer-dx",
  "source": "phekb",
  "source_id": "breast-cancer",
  "name": "Breast Cancer - Diagnosis Code Query (Multi-Subtype)",
  "description": "Tests ability to find breast cancer patients via diagnosis codes. The PheKB breast cancer phenotype requires either ICD diagnostic codes or pathology reports. Synthea distributes patients across SNOMED codes for the breast cancer family: Malignant neoplasm of breast (parent), Carcinoma of breast, Infiltrating duct carcinoma (IDC, most common), Lobular carcinoma (ILC), Invasive carcinoma. An LLM querying only the parent code will miss patients coded with histology-specific codes \u2014 IDC alone accounts for ~70% of invasive breast cancers and is often coded directly.",
  "prompt": "Find all patients with a diagnosis of breast cancer, including invasive ductal carcinoma, invasive lobular carcinoma, and other malignant neoplasms of the breast.",
  "prompts": {
    "naive": "Find all patients with breast cancer.",
    "broad": "Find all patients diagnosed with any form of breast cancer \u2014 including the parent malignant neoplasm of breast concept, carcinoma of breast (general), invasive ductal carcinoma (IDC, the most common subtype), invasive lobular carcinoma (ILC), and other invasive breast carcinomas.",
    "expert": "I need to identify all breast cancer patients in our population. Breast cancer is documented under multiple SNOMED codes by histology: Malignant neoplasm of breast (254837009) is the parent, Carcinoma of breast (254838004) is a general code, Infiltrating duct carcinoma of breast (408643008, IDC) and Lobular carcinoma of breast (278054005, ILC) are the dominant histologic subtypes (~70% and ~10% of invasive cancers respectively), and Invasive carcinoma of breast (713609000) is a less specific but commonly used code. All five codes appear in the ASCO 'Breast Cancer' VSAC (OID 2.16.840.1.113883.3.1444.3.102). Search Condition resources for all five codes."
  },
  "metadata": {
    "implementation_guide": "US Core 5.0.0",
    "algorithm_path": "diagnosis-path",
    "algorithm_path_description": "Patients with breast cancer diagnosis codes (Paths A and B). Maps to PheKB breast cancer female/male case definition: 1+ diagnostic code OR 2+ history codes on distinct days.",
