{
  "id": "phekb-depression-meds",
  "source": "phekb",
  "source_id": "depression",
  "name": "Depression - Antidepressant Medication Query",
  "description": "Tests ability to find depression patients via antidepressant prescriptions. The PheKB algorithm uses antidepressant medications as one of four longitudinal data sources. Synthea distributes patients across multiple drug classes \u2014 SSRIs (sertraline, fluoxetine, escitalopram, citalopram), SNRI (venlafaxine), and atypical (bupropion). An LLM that only queries one drug or one class will substantially underestimate the depression population.",
  "prompt": "Retrieve medication orders for patients prescribed antidepressants such as SSRIs (selective serotonin reuptake inhibitors), SNRIs (serotonin-norepinephrine reuptake inhibitors), or atypical antidepressants.",
  "prompts": {
    "naive": "Find patients on antidepressants.",
    "broad": "Find patients prescribed antidepressant medications. The most common classes are SSRIs (sertraline/Zoloft, fluoxetine/Prozac, escitalopram/Lexapro, citalopram/Celexa, paroxetine/Paxil), SNRIs (venlafaxine/Effexor, duloxetine/Cymbalta), and atypicals like bupropion (Wellbutrin).",
    "expert": "I need to find all patients on antidepressant therapy. Synthea generates these at the SCD level \u2014 search MedicationRequest for these RxNorm codes: 312938 (Sertraline 100 MG), 310385 (Fluoxetine 20 MG cap), 351250 (Escitalopram 20 MG), 200371 (Citalopram 20 MG), 313580 (Venlafaxine 100 MG), and 993537 (Bupropion HCl 200 MG ER [Wellbutrin]). Note that querying ingredient codes will not match SCD-coded prescriptions in HAPI FHIR \u2014 you must query the specific SCD codes."
  },
  "metadata": {
    "implementation_guide": "US Core 5.0.0",
    "algorithm_path": "medication-path",
    "algorithm_path_description": "Patients on antidepressants (Paths A and C). Maps to PheKB depression algorithm's antidepressant medication criterion. Includes Path C tricky patients on SSRIs without a formal depression diagnosis.",
