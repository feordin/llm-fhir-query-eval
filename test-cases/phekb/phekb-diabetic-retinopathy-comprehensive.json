      "MedicationRequest?code=http://www.nlm.nih.gov/research/umls/rxnorm|595060,http://www.nlm.nih.gov/research/umls/rxnorm|1232150,http://www.nlm.nih.gov/research/umls/rxnorm|253337",
      "Procedure?code=http://snomed.info/sct|314971001"
    ],
