  "id": "phekb-acute-kidney-injury-comprehensive",
  "source": "phekb",
  "source_id": "acute-kidney-injury",
  "name": "AKI - Comprehensive Provider Query (Multi-Resource)",
  "description": "Provider-level query identifying AKI patients via Condition (AKI dx) + Observation (elevated creatinine).",
  "prompt": "I need to identify my complete AKI patient population. Some patients have a coded AKI diagnosis. Others have only a documented elevated creatinine without yet getting a formal AKI diagnosis. Run multiple FHIR queries \u2014 diagnosis and creatinine \u2014 and union the patient sets.",
  "prompts": {
    "naive": "Find all my AKI patients.",
    "broad": "Find all AKI patients \u2014 by diagnosis or by elevated creatinine (\u22651.5 mg/dL). Run multiple queries and union the patient sets.",
    "expert": "Run two queries. (1) Condition?code=http://snomed.info/sct|14669001 \u2014 AKI dx. (2) Observation?code=http://loinc.org|2160-0&value-quantity=ge1.5||mg/dL \u2014 elevated creatinine. Union the patient IDs."
  },
