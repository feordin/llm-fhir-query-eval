{
  "id": "phekb-hypothyroidism-labs",
  "source": "phekb",
  "source_id": "hypothyroidism",
  "name": "Hypothyroidism - Abnormal TSH Lab Query",
  "description": "Tests ability to find hypothyroidism patients via abnormal Thyroid Stimulating Hormone (TSH) values. The PheKB algorithm defines a case threshold of TSH > 5 mIU/L. This test exercises Observation queries with value-quantity filters. Returns Path A patients (with full presentation) and Path D tricky patients (abnormal labs only, never treated).",
  "prompt": "Find laboratory observations for thyroid stimulating hormone tests where the result was greater than 5 mIU/L, indicating possible hypothyroidism.",
  "prompts": {
    "naive": "Find patients with high TSH lab values.",
    "broad": "Find lab observations for thyroid stimulating hormone (TSH, also called thyrotropin) where the value is above the upper limit of normal (typically > 5 milli-international units per liter), which suggests primary hypothyroidism.",
    "expert": "I need to find Observation resources for elevated TSH. The standard LOINC code for TSH in serum or plasma is 3016-3 (Thyrotropin:ACnc:Pt:Ser/Plas:Qn). The PheKB hypothyroidism algorithm uses a threshold of TSH > 5 mIU/L. Use a value-quantity filter with the gt prefix and unit mIU/L. The query should look like: Observation?code=http://loinc.org|3016-3&value-quantity=gt5|http://unitsofmeasure.org|m[IU]/L. Note that some FHIR servers accept simpler unit notation."
  },
  "metadata": {
    "implementation_guide": "US Core 5.0.0",
    "algorithm_path": "lab-path",
    "algorithm_path_description": "Patients with elevated TSH (Paths A and D). Includes Path D tricky patients who have abnormal labs but were never given a hypothyroidism diagnosis or replacement therapy.",
    "code_systems": [
      "LOINC"
    ],
    "required_codes": [
      {
        "system": "http://loinc.org",
        "code": "3016-3",
        "display": "Thyrotropin [Units/volume] in Serum or Plasma",
        "source": "Synthea built-in module"
      }
    ],
    "complexity": "hard",
    "tags": [
      "observation",
      "endocrinology",
      "hypothyroidism",
      "value-quantity",
      "lab-threshold"
    ]
  },
