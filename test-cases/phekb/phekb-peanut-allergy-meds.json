{
  "id": "phekb-peanut-allergy-meds",
  "source": "phekb",
  "source_id": "peanut-allergy",
  "name": "Peanut Allergy - Epinephrine Auto-Injector Prescription",
  "description": "Tests ability to find peanut allergy patients via epinephrine auto-injector prescriptions. Synthea encodes the auto-injector as RxNorm 1660014 (1 ML epinephrine 1 MG/ML Injection). Note: epinephrine has many indications beyond peanut allergy (other anaphylaxis triggers, cardiac arrest, etc.) — making this a high-cross-indication test.",
  "prompt": "Find patients prescribed epinephrine for severe allergic reaction risk.",
  "prompts": {
    "naive": "Find patients on epinephrine.",
    "broad": "Find patients prescribed an epinephrine auto-injector — typically prescribed for severe allergic reactions including anaphylaxis from food allergens such as peanuts.",
    "expert": "Identify patients who have been prescribed an epinephrine auto-injector by querying MedicationRequest resources. The relevant RxNorm code is for the injectable epinephrine formulation used in auto-injector devices for anaphylaxis rescue. This medication path has high cross-indication: epinephrine auto-injectors are prescribed for any cause of severe anaphylaxis — including bee sting allergy, other food allergies, and drug hypersensitivity — so a medication-only cohort will substantially over-count patients specifically identified for peanut allergy."
  },
  "metadata": {
    "implementation_guide": "US Core 5.0.0",
    "algorithm_path": "medication-path",
    "algorithm_path_description": "Patients prescribed epinephrine auto-injector. High cross-indication (any severe allergy).",
    "code_systems": [
      "RxNorm"
    ],
    "required_codes": [
      {
        "system": "http://www.nlm.nih.gov/research/umls/rxnorm",
        "code": "1660014",
        "display": "1 ML epinephrine 1 MG/ML Injection",
        "source": "UMLS verified, Synthea code"
      }
    ],
    "complexity": "medium",
    "tags": [
