{
  "id": "phekb-type-1-diabetes-meds",
  "source": "phekb",
  "source_id": "type-1-diabetes",
  "name": "Type 1 Diabetes - Insulin-Only Therapy Query",
  "description": "Tests ability to find type 1 diabetes patients via insulin prescriptions. T1D management requires insulin from disease onset (lifelong). Unlike T2D where metformin is first-line, T1D patients are NEVER on metformin/sulfonylureas/DPP4 inhibitors as primary therapy — only insulin formulations. Synthea distributes patients across insulin types: regular human insulin, glargine (long-acting), aspart protamine (intermediate), and the parent insulin ingredient. An LLM that searches for metformin will return zero T1D patients.",
  "prompt": "Find patients prescribed insulin formulations used to treat type 1 diabetes, including regular human insulin, insulin glargine, and other insulin variants.",
  "prompts": {
    "naive": "Find patients on insulin.",
    "broad": "Find patients prescribed any insulin formulation — including regular human insulin, insulin glargine (long-acting), insulin aspart protamine (intermediate-acting), or the parent insulin concept. Type 1 diabetes patients require insulin therapy from disease onset.",
    "expert": "I need MedicationRequest resources for any insulin product. Use these RxNorm codes: 5856 (insulin parent ingredient), 253182 (insulin regular human ingredient), 274783 (insulin glargine ingredient), 575068 (insulin aspart protamine ingredient), 311036 (Humulin R 100 UNT/mL Injectable Solution SCD). Important: do NOT include metformin (RxNorm 6809) or other oral antidiabetics — those are T2D-specific and would not appear in T1D patients."
  },
  "metadata": {
    "implementation_guide": "US Core 5.0.0",
    "algorithm_path": "medication-path",
    "algorithm_path_description": "Patients with insulin medication orders. Insulin Path C is small because insulin is highly specific to diabetes (T1D and insulin-treated T2D, gestational DM, hospital-only-protocols). Tests whether LLM correctly identifies insulin-only therapy as the T1D signature.",
