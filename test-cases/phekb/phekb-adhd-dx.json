  "id": "phekb-adhd-dx",
  "source": "phekb",
  "source_id": "adhd-phenotype-algorithm",
  "name": "ADHD - Diagnosis Code Query",
  "description": "Tests ability to find ADHD patients by searching for diagnosis codes. Covers PheKB algorithm Path 2 where patients have ADHD ICD codes in 2+ visits on separate days, and also Path 1 patients who have both diagnosis codes and ADHD medications.",
  "prompt": "Find all patients with a diagnosis of attention deficit hyperactivity disorder (ADHD).",
  "prompts": {
    "naive": "Find all patients with a diagnosis of attention deficit hyperactivity disorder (ADHD).",
    "expert": "I need to find patients with a documented ADHD diagnosis. ADHD may be coded under several related terms in different terminology systems -- attention deficit hyperactivity disorder is the current preferred SNOMED term, but older records might reference attention deficit disorder or hyperkinetic disorder. The query should target Condition resources. In behavioral health, diagnosis coding is often less complete than in other specialties, so be aware that this query alone may miss patients who are being treated for ADHD but were never formally coded in our system. Still, the diagnosis query should use the primary SNOMED code for ADHD."
  },
  "metadata": {
    "implementation_guide": "US Core 5.0.0",
    "algorithm_path": "paths-1-2",
    "algorithm_path_description": "Patients with ADHD diagnosis codes (SNOMED). Path 1 patients have ADHD codes plus medications, Path 2 patients have ADHD codes in 2+ visits without requiring medications.",
    "code_systems": [
      "SNOMED CT"
    ],
    "required_codes": [
      {
        "system": "http://snomed.info/sct",
        "code": "406506008",
        "display": "Attention deficit hyperactivity disorder",
        "source": "UMLS verified, code variation"
      },
      {
        "system": "http://snomed.info/sct",
        "code": "31177006",
        "display": "ADHD combined type",
        "source": "UMLS verified, code variation"
      },
      {
        "system": "http://snomed.info/sct",
        "code": "192127007",
        "display": "Child attention deficit disorder",
        "source": "UMLS verified, code variation"
      }
    ],
    "complexity": "easy",
    "tags": [
      "condition",
      "psychiatry",
      "adhd",
      "diagnosis-code"
    ]
  },
