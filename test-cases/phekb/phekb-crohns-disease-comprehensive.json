      "Condition?code=http://snomed.info/sct|34000006,http://snomed.info/sct|7620006,http://snomed.info/sct|196977009,http://snomed.info/sct|1197732001,http://snomed.info/sct|1197733006",
      "MedicationRequest?code=http://www.nlm.nih.gov/research/umls/rxnorm|52582,http://www.nlm.nih.gov/research/umls/rxnorm|191831,http://www.nlm.nih.gov/research/umls/rxnorm|327361,http://www.nlm.nih.gov/research/umls/rxnorm|847083,http://www.nlm.nih.gov/research/umls/rxnorm|1256",
