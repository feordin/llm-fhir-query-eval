{
  "id": "phekb-rheumatoid-arthritis-labs",
  "source": "phekb",
  "source_id": "rheumatoid-arthritis",
  "name": "Rheumatoid Arthritis - Positive Rheumatoid Factor Lab Query",
  "description": "Tests ability to find rheumatoid arthritis patients via positive rheumatoid factor (RF). The Harvard eMERGE RA algorithm includes RA_COD_LAB_RFpos1 as a feature with high beta weight (1.639), so a positive RF strongly increases the predicted RA probability. The standard upper limit of normal for RF is approximately 14 IU/mL. This test exercises Observation queries with value-quantity filters using a greater-than threshold.",
  "prompt": "Find laboratory observations for rheumatoid factor tests where the result was greater than 14 IU/mL, indicating positive RF and supporting a diagnosis of seropositive rheumatoid arthritis.",
  "prompts": {
    "naive": "Find patients with positive rheumatoid factor.",
    "broad": "Find lab observations for rheumatoid factor (RF) where the value is above the upper limit of normal — typically greater than 14 international units per milliliter (IU/mL). A positive RF is one of the classification criteria for seropositive rheumatoid arthritis.",
    "expert": "I need to find patients with a positive rheumatoid factor laboratory result, which is a high-weight serologic feature in the PheKB Harvard eMERGE RA prediction algorithm. Search Observation resources using the LOINC code for rheumatoid factor (units per volume) in serum or plasma, and apply a value-quantity filter for results above the standard upper limit of normal — a value greater than fourteen IU/mL by convention. A positive RF is strongly associated with seropositive RA but is not diagnostic alone; some seropositive controls without clinical RA will be captured by this query."
  },
  "metadata": {
    "implementation_guide": "US Core 5.0.0",
    "algorithm_path": "lab-path",
    "algorithm_path_description": "Patients with positive RF labs (high-weight feature in PheKB ML algorithm). Most RF-positive patients are also RA cases (high specificity), but some seropositive controls exist. Tests value-quantity filtering on a less common LOINC.",
    "code_systems": [
      "LOINC"
    ],
    "required_codes": [
      {
        "system": "http://loinc.org",
        "code": "11572-5",
        "display": "Rheumatoid factor [Units/volume] in Serum or Plasma",
        "source": "UMLS verified, RA algorithm feature"
      }
    ],
    "complexity": "hard",
    "tags": [
      "observation",
      "rheumatology",
      "rheumatoid-arthritis",
      "value-quantity",
      "lab-threshold",
      "rheumatoid-factor"
    ]
  },
