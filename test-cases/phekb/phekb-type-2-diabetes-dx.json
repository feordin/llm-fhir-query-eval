{
  "id": "phekb-type-2-diabetes-dx",
  "source": "phekb",
  "source_id": "type-2-diabetes-mellitus",
  "name": "Type 2 Diabetes - Diagnosis Code Query",
  "description": "Tests ability to find T2DM patients by searching for diagnosis codes. Covers PheKB algorithm paths 1-3 and 5 where patients have formal T2DM diagnosis codes recorded as Condition resources.",
  "prompt": "Find all patients diagnosed with type 2 diabetes mellitus.",
  "prompts": {
    "naive": "Find all patients diagnosed with type 2 diabetes mellitus.",
    "expert": "I need to identify patients with type 2 diabetes by searching their documented diagnoses. Keep in mind that diabetes may be coded under different terminology systems -- some records use ICD-10 codes while others use SNOMED CT clinical findings. The query should look at Condition resources, which may appear on the problem list or as encounter diagnoses. The key is finding the specific type 2 diabetes code rather than a broader diabetes search, since type 1 and type 2 have distinct codes and conflating them would be clinically inappropriate."
  },
  "metadata": {
    "implementation_guide": "US Core 5.0.0",
    "algorithm_path": "paths-1-3-5",
    "algorithm_path_description": "Patients with T2DM diagnosis codes (ICD-9/ICD-10/SNOMED). These patients have Condition resources with T2DM codes.",
    "code_systems": [
      "SNOMED CT"
    ],
    "required_codes": [
      {
        "system": "http://snomed.info/sct",
        "code": "44054006",
        "display": "Type 2 diabetes mellitus",
        "source": "UMLS verified, code variation"
      },
      {
        "system": "http://snomed.info/sct",
        "code": "73211009",
        "display": "Diabetes mellitus",
        "source": "UMLS verified, code variation"
      },
      {
        "system": "http://snomed.info/sct",
        "code": "9414007",
        "display": "Impaired glucose tolerance",
        "source": "UMLS verified, code variation"
      }
    ],
    "complexity": "easy",
    "tags": [
      "condition",
      "endocrinology",
      "type-2-diabetes",
      "diagnosis-code"
    ]
  },
