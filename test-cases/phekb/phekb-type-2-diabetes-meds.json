  "id": "phekb-type-2-diabetes-meds",
  "source": "phekb",
  "source_id": "type-2-diabetes-mellitus",
  "name": "Type 2 Diabetes - Medication Query",
  "description": "Tests ability to find T2DM patients by searching for diabetes medication prescriptions. This is critical for PheKB algorithm Path 4 where patients have NO diagnosis code but ARE prescribed T2DM medications. Also catches patients from paths 1-2 who have both diagnosis and medications.",
  "prompt": "Find all medication orders for type 2 diabetes medications.",
  "prompts": {
    "naive": "Find all medication orders for type 2 diabetes medications.",
    "expert": "I need to find all patients who have been prescribed oral hypoglycemic agents or other diabetes-specific medications. The medication classes to look for include biguanides like metformin (the most commonly prescribed first-line agent), sulfonylureas such as glipizide and glyburide, thiazolidinediones like pioglitazone, DPP-4 inhibitors such as sitagliptin, and GLP-1 receptor agonists. Patients may be on various formulations and dosages of these medications, so the query should search MedicationRequest resources using the specific drug product codes. Note that some of these patients may not have a formal diabetes diagnosis in the system -- they may have been started on metformin by an outside provider."
  },
  "metadata": {
    "implementation_guide": "US Core 5.0.0",
    "algorithm_path": "paths-1-2-4",
    "algorithm_path_description": "Patients with T2DM medication prescriptions. Path 4 patients have ONLY medications and labs, no diagnosis code. This tests whether LLMs search MedicationRequest, not just Condition.",
