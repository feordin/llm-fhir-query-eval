    "complexity": "expert",
    "expected_queries": [
      "Condition?code=http://snomed.info/sct|21897009,http://snomed.info/sct|371631005,http://snomed.info/sct|197480006",
      "MedicationRequest?code=http://www.nlm.nih.gov/research/umls/rxnorm|312941,http://www.nlm.nih.gov/research/umls/rxnorm|349332,http://www.nlm.nih.gov/research/umls/rxnorm|866083,http://www.nlm.nih.gov/research/umls/rxnorm|308048"
    ],
