{
  "id": "phekb-anxiety-comprehensive",
  "source": "phekb",
  "source_id": "anxiety-algorithm",
  "name": "Anxiety Disorder - Comprehensive Multi-Query",
  "description": "Comprehensive test for the PheKB anxiety phenotype algorithm. A psychiatrist needs to identify their complete anxiety patient population for a treatment outcomes study. This requires searching both Condition resources (formal diagnoses) and MedicationRequest resources (anti-anxiety prescriptions), because some patients may be prescribed medications by primary care without a formal anxiety diagnosis in the psychiatry system. Tests whether LLMs can construct multiple FHIR queries across resource types to capture the full cohort.",
  "prompt": "Find all patients with an anxiety disorder. Search both diagnoses and anti-anxiety medication prescriptions to capture the complete population.",
  "prompts": {
    "naive": "Find all patients with an anxiety disorder. Search both diagnoses and anti-anxiety medication prescriptions to capture the complete population.",
    "expert": "A psychiatrist is conducting a treatment outcomes study and needs to identify their complete anxiety patient population. They explain that while many patients have a formal anxiety diagnosis on record, some patients are prescribed anti-anxiety medications such as sertraline, escitalopram, buspirone, or alprazolam by their primary care provider without a formal anxiety diagnosis appearing in the psychiatry system. The psychiatrist needs to find all patients who either have an anxiety disorder diagnosis or have been prescribed any of these anti-anxiety medications."
  },
  "metadata": {
    "implementation_guide": "US Core 5.0.0",
    "algorithm_path": "comprehensive",
    "algorithm_path_description": "Full PheKB anxiety case identification combining diagnosis codes and medication evidence. Requires multi-query strategy: Condition search for anxiety diagnoses plus MedicationRequest search for anti-anxiety medications to catch patients without formal diagnosis codes.",
    "multi_query": true,
    "code_systems": [
      "SNOMED CT",
      "RxNorm"
    ],
