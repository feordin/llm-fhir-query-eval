  "source_id": "peanut-allergy",
  "name": "Peanut Allergy - Diagnosis Code Query (Pediatric, Ages 1-17)",
  "description": "Tests ability to find peanut allergy patients via diagnosis code with pediatric age restriction (1-17). Second pediatric phenotype (after SECO). Reuses PatientFilters schema with chained patient.birthdate filter.",
  "prompt": "Find pediatric patients (ages 1-17) with a documented peanut allergy.",
  "prompts": {
    "naive": "Find kids with peanut allergy.",
    "broad": "Find pediatric patients (ages 1 through 17) with a documented diagnosis of peanut allergy.",
    "expert": "I need pediatric patients (ages 1-17) with peanut allergy. SNOMED 91935009 (Allergy to peanut). FHIR has no patient.age — use chained patient.birthdate. With reference date 2026-04-28: ages 1-17 inclusive means birthdate in (2008-04-28, 2025-04-28]. Query: Condition?code=http://snomed.info/sct|91935009&patient.birthdate=gt2008-04-28&patient.birthdate=le2025-04-28"
  },
  "metadata": {
    "implementation_guide": "US Core 5.0.0",
    "algorithm_path": "diagnosis-path",
    "algorithm_path_description": "Pediatric patients (1-17) with peanut allergy diagnosis. Reuses PatientFilters schema.",
