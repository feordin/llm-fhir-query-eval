        "system": "http://snomed.info/sct",
        "code": "91935009",
        "display": "Allergy to peanut",
        "source": "UMLS verified"
      }
    ],
    "complexity": "hard",
    "tags": [
      "condition",
      "allergy",
      "peanut-allergy",
      "pediatric",
