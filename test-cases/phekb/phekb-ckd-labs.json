  "source_id": "ckd",
  "name": "Chronic Kidney Disease - Reduced eGFR Lab Query",
  "description": "Tests ability to find chronic kidney disease patients via reduced eGFR. The Columbia CKD V4.2 algorithm uses eGFR (CKD-EPI formula) as the primary staging variable: <60 mL/min/1.73 m\u00b2 indicates CKD Stage 3 or worse. This test case uses a less-than threshold (lt60) and exercises the most quantitative phenotype in our suite, where staging is entirely lab-driven.",
  "prompt": "Find laboratory observations for estimated glomerular filtration rate (eGFR) where the value is below 60 mL/min/1.73 m\u00b2, indicating chronic kidney disease stage 3 or worse.",
  "prompts": {
    "naive": "Find patients with low eGFR.",
    "broad": "Find Observation resources for estimated glomerular filtration rate (eGFR) measurements where the value is less than 60 mL/min/1.73 m\u00b2. An eGFR below 60 sustained for at least 3 months meets KDIGO criteria for chronic kidney disease stage 3 or higher.",
    "expert": "I need Observation resources for reduced eGFR. Use LOINC 62238-1 (Glomerular filtration rate by Creatinine-based formula CKD-EPI) \u2014 this is the algorithm-specified equation. Apply a value-quantity filter with the lt prefix at threshold 60. The query should look like: Observation?code=http://loinc.org|62238-1&value-quantity=lt60. Note that LOINC 33914-3 (eGFR by MDRD) and 48642-3/48643-1 (race-based variants) may also appear in some data; the CKD-EPI code is preferred per current KDIGO 2012 guidelines."
  },
  "metadata": {
    "implementation_guide": "US Core 5.0.0",
    "algorithm_path": "lab-path",
    "algorithm_path_description": "Patients with reduced eGFR (Paths A and C). Tests the value-quantity less-than filter pattern with a quantitative threshold tied directly to disease staging. The eGFR < 60 cutoff is the binary threshold separating CKD Stage 1-2 from Stage 3-5.",
    "code_systems": [
      "LOINC"
    ],
    "required_codes": [
      {
        "system": "http://loinc.org",
        "code": "62238-1",
        "display": "Glomerular filtration rate [Volume Rate/Area] in Serum, Plasma or Blood by Creatinine-based formula (CKD-EPI)/1.73 sq M",
        "source": "UMLS verified, CKD-EPI per algorithm"
      }
    ],
    "complexity": "hard",
    "tags": [
      "observation",
      "nephrology",
      "ckd",
      "value-quantity",
      "less-than-threshold",
      "egfr",
      "ckd-epi"
    ]
  },
