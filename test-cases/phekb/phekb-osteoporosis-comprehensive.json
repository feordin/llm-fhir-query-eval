{
  "id": "phekb-osteoporosis-comprehensive",
  "source": "phekb",
  "source_id": "osteoporosis",
  "name": "Osteoporosis - Comprehensive Provider Query (Multi-Resource)",
  "description": "Provider-level query identifying all osteoporosis patients via Condition (osteoporosis dx) + MedicationRequest (bisphosphonate Rx) + Observation (low DEXA T-score). Path D patients have low T-score without formal diagnosis (under-coded osteoporosis).",
  "prompt": "I need to identify my complete osteoporosis patient population for a bone health quality initiative. Some patients have a coded osteoporosis diagnosis. Others are on bisphosphonates without ever getting a formal diagnosis, and some have a documented low DEXA T-score (\u2264 -2.5) but no formal coded diagnosis. Run multiple FHIR queries \u2014 diagnosis, bisphosphonate medications, and DEXA scan results \u2014 and union the patient sets.",
  "prompts": {
    "naive": "Find all my osteoporosis patients.",
    "broad": "Find all osteoporosis patients \u2014 by diagnosis, bisphosphonate medications, or low DEXA T-score (\u2264 -2.5). Run multiple queries and union the patient sets.",
    "expert": "Run three queries. (1) Condition?code=http://snomed.info/sct|64859006 \u2014 osteoporosis dx. (2) MedicationRequest?code=http://www.nlm.nih.gov/research/umls/rxnorm|73056,http://www.nlm.nih.gov/research/umls/rxnorm|77655 \u2014 bisphosphonates. (3) Observation?code=http://loinc.org|38265-5&value-quantity=le-2.5 \u2014 low DEXA T-score. Union the patient IDs."
  },
