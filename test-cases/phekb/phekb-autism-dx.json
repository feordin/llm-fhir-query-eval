  "id": "phekb-autism-dx",
  "source": "phekb",
  "source_id": "autism",
  "name": "Autism Spectrum Disorder - Diagnosis Code Query",
  "description": "Tests ability to find ASD patients by searching for autism spectrum disorder diagnosis codes. Covers the primary inclusion criteria of the PheKB autism algorithm: patients with ICD-9 codes 299.0, 299.80, 299.9 (mapped to ICD-10/SNOMED). The SNOMED code 35919005 (Autism spectrum disorder) is the broadest parent concept encompassing autistic disorder, Asperger syndrome, and PDD-NOS.",
  "prompt": "Find all patients diagnosed with autism spectrum disorder.",
  "prompts": {
    "naive": "Find all patients diagnosed with autism spectrum disorder.",
    "expert": "I need to identify patients with an autism spectrum disorder diagnosis. ASD encompasses what were previously separate diagnoses -- autistic disorder, Asperger syndrome, and pervasive developmental disorder not otherwise specified (PDD-NOS) -- which are now unified under the autism spectrum disorder umbrella in SNOMED CT. The query should search Condition resources for the ASD code. In neurodevelopmental phenotyping, some patients may have been diagnosed under older terminology (especially Asperger syndrome) that maps to different ICD codes but should be captured under the broader SNOMED ASD concept. The PheKB algorithm uses ICD-9 codes 299.0, 299.80, and 299.9 which all map to the SNOMED ASD parent concept."
  },
  "metadata": {
    "implementation_guide": "US Core 5.0.0",
    "algorithm_path": "inclusion-criteria",
    "algorithm_path_description": "Patients with ASD diagnosis codes (ICD-9 299.0/299.80/299.9 mapped to SNOMED). These patients have Condition resources with autism spectrum disorder codes.",
    "code_systems": [
      "SNOMED CT"
    ],
