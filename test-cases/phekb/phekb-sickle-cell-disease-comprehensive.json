{
  "id": "phekb-sickle-cell-disease-comprehensive",
  "source": "phekb",
  "source_id": "sickle-cell-disease",
  "name": "Sickle Cell Disease - Comprehensive Provider Query",
  "description": "Simulates a hematologist identifying their complete SCD population. Requires multiple FHIR queries because not all SCD patients have a formal diagnosis documented \u2014 some are only identifiable through hydroxyurea prescriptions. An LLM that only searches Condition resources will miss 11 of 30 patients (37%). The PheKB algorithm uses diagnosis codes + ongoing care evidence, but real-world identification requires searching both diagnoses AND medications.",
  "prompt": "I need to identify my complete sickle cell disease patient population for a quality improvement initiative focused on hydroxyurea utilization. I know from experience that not all SCD patients have a formal diagnosis code in their chart \u2014 some patients were diagnosed at outside hematology practices and their records transferred incompletely. Others may have been started on hydroxyurea without the underlying diagnosis being formally documented in our problem list.\n\nPlease run multiple FHIR queries to capture the full population:\n1. Patients with any sickle cell disease diagnosis (HbSS, HbSC, sickle cell-thalassemia)\n2. Patients prescribed hydroxyurea (the standard disease-modifying therapy)\n\nFor each query, return the matching resources. I want to see the union of all patients found across these approaches.",
  "metadata": {
    "implementation_guide": "US Core 5.0.0",
    "multi_query": true,
    "algorithm_path": "comprehensive",
    "algorithm_path_description": "Union of all identification paths: diagnosis codes (Paths A+B) and hydroxyurea prescriptions (Paths A+C). An LLM must run both queries and union the results to achieve 100% recall.",
    "expected_queries": [
      "Condition?code=http://snomed.info/sct|127040003,http://snomed.info/sct|35434009,http://snomed.info/sct|36472007",
      "MedicationRequest?code=http://www.nlm.nih.gov/research/umls/rxnorm|5552"
    ],
    "code_systems": [
      "SNOMED CT",
      "RxNorm"
    ],
    "required_codes": [
      {
        "system": "http://snomed.info/sct",
        "code": "127040003",
