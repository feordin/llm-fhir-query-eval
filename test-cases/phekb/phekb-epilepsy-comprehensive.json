    "implementation_guide": "US Core 5.0.0",
    "multi_query": true,
    "algorithm_path": "comprehensive",
    "algorithm_path_description": "Union of epilepsy dx + AED Rx + EEG Procedure. Tests Condition + MedicationRequest + Procedure cross-resource union.",
