{
  "id": "phekb-type-2-diabetes-labs",
  "source": "phekb",
  "source_id": "type-2-diabetes-mellitus",
  "name": "Type 2 Diabetes - Abnormal Lab Query",
  "description": "Tests ability to find patients with elevated hemoglobin A1c lab results indicating diabetes. This covers PheKB algorithm paths 3 and 4 where abnormal lab values are required evidence. Tests whether the LLM can construct a value-based Observation query with proper LOINC codes and thresholds.",
  "prompt": "Find all hemoglobin A1c lab results at or above 6.5 percent.",
  "prompts": {
    "naive": "Find all hemoglobin A1c lab results at or above 6.5 percent.",
    "expert": "I need to retrieve laboratory observations for hemoglobin A1c (glycated hemoglobin) testing where the result meets or exceeds the diagnostic threshold of 6.5 percent. The A1c test is the standard screening and monitoring test for diabetes, and results at or above 6.5% are diagnostic for diabetes mellitus per ADA guidelines. The query needs to target Observation resources with the correct LOINC code for HbA1c and include a value-quantity filter for the threshold. Be aware that a single patient may have multiple A1c readings over time, and we want all results meeting the threshold, not just the most recent."
  },
  "metadata": {
    "implementation_guide": "US Core 5.0.0",
    "algorithm_path": "paths-3-4",
    "algorithm_path_description": "Patients with abnormal HbA1c >= 6.5%. Tests value-quantity search on Observations. The hardest query type because it requires both the right LOINC code AND a value filter.",
    "code_systems": [
      "LOINC"
    ],
    "required_codes": [
      {
        "system": "http://loinc.org",
        "code": "4548-4",
        "display": "Hemoglobin A1c/Hemoglobin.total in Blood",
        "source": "document"
      }
    ],
    "lab_thresholds": {
      "hba1c_case": ">= 6.5%"
    },
    "complexity": "hard",
    "tags": [
      "observation",
      "laboratory",
      "endocrinology",
      "type-2-diabetes",
      "value-filter",
      "loinc"
    ]
  },
