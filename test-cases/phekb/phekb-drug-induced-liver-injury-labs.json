  "name": "DILI - Lab Threshold Query (ALT >=5x ULN)",
  "description": "Tests ability to find DILI cases via the PheKB-published lab threshold: ALT >=5x ULN (>=225 U/L). This is the lab-only path that catches DILI suspects regardless of whether a dx code was assigned — central to the published PheKB algorithm.",
  "prompt": "Find patients with markedly elevated alanine aminotransferase (ALT) at or above 225 U/L, suggesting acute liver injury.",
  "prompts": {
    "naive": "Find patients with high ALT.",
    "broad": "Find patients with severely elevated alanine aminotransferase (ALT) — at least 5 times the upper limit of normal (>=225 U/L) — indicating significant hepatocellular injury.",
    "expert": "Search Observation for LOINC 1742-6 (ALT) with value-quantity ge225 U/L. Query: Observation?code=http://loinc.org|1742-6&value-quantity=ge225"
  },
