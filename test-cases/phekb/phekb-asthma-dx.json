  "id": "phekb-asthma-dx",
  "source": "phekb",
  "source_id": "asthma",
  "name": "Asthma - Diagnosis Code Query",
  "description": "Tests ability to find asthma patients by searching for diagnosis codes. Covers the standard identification path where patients have a formal asthma diagnosis recorded as a Condition resource. The PheKB asthma algorithm requires ICD codes from 493.x family (ICD-9) or J45 (ICD-10), mapped to SNOMED CT 195967001.",
  "prompt": "Find all patients with a diagnosis of asthma.",
  "prompts": {
    "naive": "Find all patients with a diagnosis of asthma.",
    "expert": "I need to identify patients with asthma by searching their documented diagnoses. Asthma has a single primary SNOMED concept code, but in practice it may be coded at various levels of specificity (mild intermittent, mild persistent, moderate persistent, severe persistent, or unspecified). The general asthma SNOMED code should serve as the parent concept. Search Condition resources for this code. The PheKB asthma algorithm typically requires two or more asthma ICD codes from separate visits to establish a case, but the FHIR query itself should find all Condition resources with asthma codes regardless of visit count."
  },
  "metadata": {
    "implementation_guide": "US Core 5.0.0",
    "algorithm_path": "diagnosis-path",
    "algorithm_path_description": "Patients with asthma diagnosis codes. These patients have Condition resources with asthma SNOMED codes. The PheKB algorithm requires two or more asthma ICD codes from separate visits, but the FHIR query itself just searches for the diagnosis code.",
    "code_systems": [
      "SNOMED CT"
    ],
    "required_codes": [
