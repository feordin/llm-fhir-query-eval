  "id": "phekb-osteoporosis-labs",
  "source": "phekb",
  "source_id": "osteoporosis",
  "name": "Osteoporosis - Low DEXA T-score Query (≤ -2.5)",
  "description": "Tests ability to find osteoporosis patients via DEXA bone density scan T-score ≤ -2.5 (the WHO criterion for osteoporosis). First DEXA T-score lab phenotype. Includes Path D patients (low T-score without formal osteoporosis diagnosis — undiagnosed disease).",
  "prompt": "Find patients with DEXA bone density T-scores at or below -2.5.",
  "prompts": {
    "naive": "Find patients with low bone density.",
    "broad": "Find patients with bone density T-score at or below -2.5 — the WHO diagnostic criterion for osteoporosis on DEXA bone density scan.",
    "expert": "I need to identify patients with objectively low bone mineral density as measured by DEXA scan. Search Observation resources for DXA T-score results, using the LOINC code for DXA radius and ulna T-score, and filter to values at or below negative two-point-five — the WHO diagnostic threshold for osteoporosis. This captures both formally diagnosed patients and those with radiologically confirmed bone loss who lack a coded diagnosis (under-coded osteoporosis), so the cohort may be broader than a diagnosis-only query would return."
  },
  "metadata": {
    "implementation_guide": "US Core 5.0.0",
    "algorithm_path": "labs-path",
    "algorithm_path_description": "Patients with low DEXA T-score Observations (osteoporotic range). Includes Path D (no formal dx).",
    "code_systems": [
      "LOINC"
    ],
    "required_codes": [
