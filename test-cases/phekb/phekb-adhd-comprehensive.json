{
  "id": "phekb-adhd-comprehensive",
  "source": "phekb",
  "source_id": "adhd-phenotype-algorithm",
  "name": "ADHD - Comprehensive Provider Query (All Paths)",
  "description": "Simulates an experienced clinician who understands that ADHD case identification requires searching across multiple evidence types. Some patients have a formal diagnosis code, while others were started on stimulant medications by an outside provider or psychiatrist without the diagnosis being added to the problem list. This tests whether the LLM can generate multiple FHIR queries and reason about the clinical informatics challenge of incomplete diagnostic coding in behavioral health.",
  "prompt": "Find all patients with ADHD. Search both diagnoses and ADHD medication prescriptions to capture the complete population.",
  "prompts": {
    "naive": "Find all patients with ADHD. Search both diagnoses and ADHD medication prescriptions to capture the complete population.",
    "expert": "I need to identify my complete ADHD patient population for a behavioral health quality initiative. From experience, I know that not all patients with ADHD have a formal diagnosis code in their chart. Some were started on stimulant medications like methylphenidate or mixed amphetamine salts by an outside psychiatrist, and the ADHD diagnosis was never formally documented in our system. Others are on non-stimulant ADHD medications like atomoxetine or lisdexamfetamine. Please run multiple FHIR queries to capture the full ADHD population:\n\n1. Patients with an ADHD diagnosis on their problem list\n2. Patients who have been prescribed ADHD medications, including stimulants (methylphenidate, amphetamine/dextroamphetamine) and non-stimulants (atomoxetine, lisdexamfetamine)\n\nFor each query, return the matching resources. I want to see the union of all patients found across both approaches."
  },
  "metadata": {
    "implementation_guide": "US Core 5.0.0",
    "algorithm_paths": "all-paths",
    "algorithm_path_description": "Comprehensive multi-query approach that mirrors how a real clinician would identify the full ADHD population. Path 1 patients have diagnosis + meds, Path 2 patients have diagnosis only (2+ visits), and meds-only patients have stimulant prescriptions without a formal diagnosis code. Requires generating 2 FHIR queries and combining results.",
    "code_systems": [
      "SNOMED CT",
      "RxNorm"
    ],
    "required_codes": [
