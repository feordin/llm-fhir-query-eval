        "code": "854834",
        "display": "lisdexamfetamine dimesylate 30 MG Oral Capsule",
        "source": "document"
      }
    ],
    "complexity": "expert",
    "multi_query": true,
    "expected_queries": [
      "Condition?code=http://snomed.info/sct|406506008,http://snomed.info/sct|31177006,http://snomed.info/sct|192127007",
      "MedicationRequest?code=http://www.nlm.nih.gov/research/umls/rxnorm|1091392,http://www.nlm.nih.gov/research/umls/rxnorm|541892,http://www.nlm.nih.gov/research/umls/rxnorm|349594,http://www.nlm.nih.gov/research/umls/rxnorm|854834"
    ],
