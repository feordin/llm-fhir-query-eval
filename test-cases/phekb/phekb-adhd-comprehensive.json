        "code": "192127007",
        "display": "Child attention deficit disorder",
        "source": "UMLS verified, code variation"
      },
      {
        "system": "http://www.nlm.nih.gov/research/umls/rxnorm",
        "code": "1091392",
        "display": "methylphenidate hydrochloride 20 MG Oral Tablet",
