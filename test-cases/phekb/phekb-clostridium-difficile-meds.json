{
  "id": "phekb-clostridium-difficile-meds",
  "source": "phekb",
  "source_id": "clostridium-difficile",
  "name": "Clostridium difficile - Medication Query (Vancomycin)",
  "description": "Tests ability to find C. diff patients via vancomycin prescriptions. Heavy cross-indication: IV vancomycin is also used for MRSA bacteremia, endocarditis, and other gram-positive infections.",
  "prompt": "Find patients prescribed vancomycin for Clostridium difficile colitis.",
  "prompts": {
    "naive": "Find patients on C. diff medications.",
    "broad": "Find patients prescribed vancomycin — a glycopeptide antibiotic used as first-line treatment for C. difficile colitis (oral) and for serious gram-positive infections like MRSA (IV).",
    "expert": "Identify patients treated with vancomycin by searching MedicationRequest resources for vancomycin prescriptions coded in RxNorm. This is a medication-proxy path for C. difficile infection, but vancomycin carries substantial cross-indication: it is also a first-line agent for MRSA bacteremia, endocarditis, and other severe gram-positive infections, so this cohort will include patients treated for conditions other than C. diff. A medication-only query therefore represents an upper-bound estimate of the C. diff population."
  },
