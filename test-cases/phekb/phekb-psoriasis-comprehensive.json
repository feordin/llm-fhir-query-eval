{
  "id": "phekb-psoriasis-comprehensive",
  "source": "phekb",
  "source_id": "psoriasis",
  "name": "Psoriasis - Comprehensive Provider Query (Multi-Resource)",
  "description": "Provider-level query identifying psoriasis patients via Condition + MedicationRequest. Path C (med only) reflects methotrexate use without psoriasis dx — most commonly RA cross-indication in real datasets.",
  "prompt": "I need to identify my complete psoriasis patient population for a dermatology biologics program. Some patients have a coded psoriasis diagnosis. Others are on systemic methotrexate for inflammatory disease without a formal psoriasis diagnosis. Run multiple FHIR queries — diagnosis and methotrexate — and union the patient sets.",
  "prompts": {
    "naive": "Find all psoriasis patients.",
    "broad": "Find all psoriasis patients — by diagnosis or by methotrexate prescriptions for systemic therapy. Run multiple queries and union the patient sets.",
    "expert": "Run two queries. (1) Condition?code=http://snomed.info/sct|9014002 — psoriasis dx. (2) MedicationRequest?code=http://www.nlm.nih.gov/research/umls/rxnorm|105585 — methotrexate. Union the patient IDs."
  },
