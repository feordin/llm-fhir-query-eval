{
  "id": "phekb-endometriosis-meds",
  "source": "phekb",
  "source_id": "endometriosis",
  "name": "Endometriosis - Medication Query (Leuprolide)",
  "description": "Tests ability to find endometriosis patients via leuprolide (GnRH agonist) injections. Cross-indication: leuprolide also used for prostate cancer ADT — sex restriction in module rules out that overlap.",
  "prompt": "Find female patients prescribed leuprolide for endometriosis.",
  "prompts": {
    "naive": "Find patients on endometriosis medications.",
    "broad": "Find female patients prescribed leuprolide — a GnRH agonist used for endometriosis to suppress estrogen and shrink endometrial implants.",
    "expert": "I need to find female patients who have been prescribed leuprolide acetate, the GnRH agonist used in hormonal suppression therapy for endometriosis. Search MedicationRequest resources for leuprolide acetate using its RxNorm code, and restrict results to female patients using a patient gender filter. Leuprolide is cross-indicated for prostate cancer androgen-deprivation therapy in males, but the female sex restriction eliminates that overlap — within the female cohort, leuprolide prescriptions are a strong but imperfect signal for endometriosis, as some may reflect treatment for uterine fibroids or precocious puberty."
  },
  "metadata": {
    "implementation_guide": "US Core 5.0.0",
    "algorithm_path": "medication-path",
    "algorithm_path_description": "Female patients on leuprolide (GnRH agonist; cross-indicated with prostate cancer in males, but sex-restricted here).",
