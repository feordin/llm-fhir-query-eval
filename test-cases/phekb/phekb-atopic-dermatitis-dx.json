  "id": "phekb-atopic-dermatitis-dx",
  "source": "phekb",
  "source_id": "atopic-dermatitis-algorithm",
  "name": "Atopic Dermatitis - Diagnosis Code Query",
  "description": "Tests ability to find atopic dermatitis patients by searching for diagnosis codes. Covers PheKB algorithm paths 1-2 where patients have a formal atopic dermatitis diagnosis code recorded as a Condition resource. Path 1 requires 2+ visits plus 2+ AD medication prescriptions, Path 2 requires 3+ visits with no medication requirement.",
  "prompt": "Find all patients diagnosed with atopic dermatitis or eczema.",
  "prompts": {
    "naive": "Find all patients diagnosed with atopic dermatitis or eczema.",
    "expert": "I need to identify patients with atopic dermatitis (also commonly called eczema) by searching for diagnosis codes. Atopic dermatitis has a specific SNOMED code, and the query should search Condition resources. In clinical practice, atopic dermatitis and eczema are sometimes used interchangeably, though atopic dermatitis is the more precise clinical term. The PheKB algorithm for atopic dermatitis requires diagnosis codes from multiple visits on separate days to establish a case, but the FHIR query should first capture all patients with any atopic dermatitis Condition resource."
  },
  "metadata": {
    "implementation_guide": "US Core 5.0.0",
    "algorithm_path": "paths-1-2",
    "algorithm_path_description": "Patients with atopic dermatitis diagnosis codes (ICD-9 691.8 / ICD-10 L20.x / SNOMED). These patients have Condition resources with atopic dermatitis codes from 2+ or 3+ visits on separate days.",
    "code_systems": [
      "SNOMED CT"
    ],
    "required_codes": [
      {
        "system": "http://snomed.info/sct",
        "code": "24079001",
        "display": "Atopic dermatitis",
        "source": "UMLS verified, code variation"
      },
      {
        "system": "http://snomed.info/sct",
        "code": "43116000",
        "display": "Eczema",
        "source": "UMLS verified, code variation"
      }
    ],
    "complexity": "easy",
    "tags": [
      "condition",
      "dermatology",
      "atopic-dermatitis",
      "eczema",
      "diagnosis-code"
    ]
  },
