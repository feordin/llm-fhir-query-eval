{
  "id": "phekb-gerd-dx",
  "source": "phekb",
  "source_id": "gerd",
  "name": "GERD - Diagnosis Code Query (Multi-Code)",
  "description": "Tests ability to find GERD patients via diagnosis codes. The PheKB GERD algorithm requires 2+ ICD diagnoses on separate visits (530.81 GERD or 530.11 reflux esophagitis) PLUS PPI use, OR 3+ diagnoses alone. Synthea uses SNOMED for FHIR Conditions: GERD parent (235595009), Acid reflux (698065002), and Heartburn (16331000) \u2014 though the latter two are 'finding' not 'disorder' codes, they appear in real-world EHR coding when documentation is informal.",
  "prompt": "Find all patients with a diagnosis of gastroesophageal reflux disease (GERD), including documented acid reflux or heartburn.",
  "prompts": {
    "naive": "Find all patients with GERD.",
    "broad": "Find all patients diagnosed with gastroesophageal reflux disease (GERD), or related findings such as acid reflux or heartburn that have been documented as a diagnosis or problem.",
    "expert": "I need to identify all GERD patients. GERD is documented under multiple SNOMED codes: Gastroesophageal reflux disease (235595009) is the canonical disorder code, but real-world EHR documentation also uses related findings such as Acid reflux (698065002) and Heartburn (16331000). Search Condition resources for all three codes. ICD-10 alternates would be K21.0 (GERD with esophagitis) and K21.9 (without esophagitis), but Synthea data uses SNOMED only."
  },
  "metadata": {
    "implementation_guide": "US Core 5.0.0",
    "algorithm_path": "diagnosis-path",
    "algorithm_path_description": "Patients with GERD diagnosis codes (Paths A and B). Maps to PheKB GERD algorithm criterion of 2+ ICD-9 530.81/530.11 codes. Does NOT find Path C patients (on PPIs without GERD dx \u2014 the dominant real-world pattern).",
    "code_systems": [
      "SNOMED CT",
      "ICD-10-CM"
    ],
    "required_codes": [
      {
        "system": "http://snomed.info/sct",
        "code": "235595009",
        "display": "Gastroesophageal reflux disease",
        "source": "UMLS verified, parent disorder concept"
      },
      {
        "system": "http://snomed.info/sct",
        "code": "698065002",
        "display": "Acid reflux",
        "source": "VSAC GastroesophagealReflux value set"
      },
      {
        "system": "http://snomed.info/sct",
        "code": "16331000",
        "display": "Heartburn",
        "source": "VSAC GastroesophagealReflux value set"
      }
    ],
    "complexity": "easy",
    "tags": [
      "condition",
      "gastroenterology",
      "gerd",
      "diagnosis-code",
      "code-variation"
    ]
  },
