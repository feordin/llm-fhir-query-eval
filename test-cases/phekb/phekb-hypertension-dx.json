{
  "id": "phekb-hypertension-dx",
  "source": "phekb",
  "source_id": "hypertension",
  "name": "Hypertension - Diagnosis Code Query (Multi-Subtype)",
  "description": "Tests ability to find hypertension patients via diagnosis codes. The PheKB resistant-hypertension algorithm uses ICD-9 401.* / ICD-10 I10 as the parent code, plus subtypes for hypertensive heart disease (402.*), hypertensive renal disease (403.*), and hypertensive heart-and-renal disease (404.*). Synthea distributes patients across NCQA's 'Essential Hypertension' VSAC family which includes benign, malignant, systolic, and labile variants. An LLM querying only the parent SNOMED code will miss the more specific subtypes that some EHR systems use.",
  "prompt": "Find all patients with a diagnosis of hypertension, including essential hypertension, benign and malignant variants, and systolic hypertension.",
  "prompts": {
    "naive": "Find all patients with hypertension.",
    "broad": "Find all patients diagnosed with any form of hypertension \u2014 essential hypertension (the most common general code), benign or malignant essential hypertension, systolic essential hypertension, or labile (variable) essential hypertension.",
    "expert": "I need to identify all hypertension patients. Hypertension is documented under multiple SNOMED codes from NCQA's 'Essential Hypertension' VSAC (OID 2.16.840.1.113883.3.464.1003.104.11.1029): Essential hypertension (59621000) is the parent, with subtype variants Benign essential hypertension (1201005), Malignant essential hypertension (78975002), Systolic essential hypertension (429457004), and Labile essential hypertension (371125006). Search Condition resources for all five codes."
  },
  "metadata": {
    "implementation_guide": "US Core 5.0.0",
    "algorithm_path": "diagnosis-path",
    "algorithm_path_description": "Patients with HTN diagnosis codes (Paths A and B). Maps to PheKB algorithm criterion of ICD-9 401.* / ICD-10 I10 codes.",
