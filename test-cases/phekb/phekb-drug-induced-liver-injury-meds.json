{
  "id": "phekb-drug-induced-liver-injury-meds",
  "source": "phekb",
  "source_id": "drug-induced-liver-injury",
  "name": "DILI - Medication Query (Methotrexate as offending drug)",
  "description": "Tests ability to find DILI patients via the offending drug. Methotrexate is one of many documented hepatotoxins. This is a TRICKY query because most methotrexate users (RA, psoriasis, malignancy) do NOT develop DILI — the meds-only path catches an at-risk pool much larger than the actual DILI cohort. Real PheKB algorithm specifies institution-specific drug lists; we use methotrexate as a representative hepatotoxin.",
  "prompt": "Find patients prescribed methotrexate, a known hepatotoxin used in rheumatoid arthritis and psoriasis.",
  "prompts": {
    "naive": "Find patients on methotrexate.",
    "broad": "Find patients prescribed methotrexate — a documented hepatotoxin used for rheumatoid arthritis, psoriasis, and other inflammatory conditions, monitored for liver toxicity.",
    "expert": "Search MedicationRequest for RxNorm 105585 (methotrexate). Query: MedicationRequest?code=http://www.nlm.nih.gov/research/umls/rxnorm|105585"
  },
  "metadata": {
    "implementation_guide": "US Core 5.0.0",
    "algorithm_path": "medication-path",
    "algorithm_path_description": "Patients on methotrexate (representative hepatotoxin; massive cross-indication with RA, psoriasis).",
