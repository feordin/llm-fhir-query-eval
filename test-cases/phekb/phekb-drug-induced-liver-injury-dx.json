      },
      {
        "system": "http://hl7.org/fhir/sid/icd-10-cm",
        "code": "R74.01",
        "display": "Elevation of levels of liver transaminase levels",
        "source": "PheKB doc (ICD-9 790.4* crosswalk) + UMLS verified"
      }
    ],
    "complexity": "hard",
