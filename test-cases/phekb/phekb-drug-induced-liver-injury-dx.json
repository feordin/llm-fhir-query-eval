{
  "id": "phekb-drug-induced-liver-injury-dx",
  "source": "phekb",
  "source_id": "drug-induced-liver-injury",
  "name": "DILI - Diagnosis Code Query (Multi-System)",
  "description": "Tests ability to find DILI patients across SNOMED + ICD-10 codes. Per the published PheKB DILI algorithm, real-world cohorts are coded under multiple systems including hepatic-failure (K72.0), toxic liver disease (K71.9), and elevated transaminases (R74.01) — not just the post-coordinated SNOMED 'Drug-induced disorder of liver'.",
  "prompt": "Find all patients with a diagnosis of drug-induced liver injury or related liver injury indicators (toxic liver disease, acute hepatic failure, elevated transaminases).",
  "prompts": {
    "naive": "Find patients with DILI.",
    "broad": "Find patients with drug-induced liver injury or any documented liver injury suggestive of drug toxicity — toxic liver disease, hepatic failure, or persistently elevated transaminases.",
    "expert": "Search Condition for SNOMED 427399008 (Drug-induced disorder of liver), ICD-10 K71.9 (Toxic liver disease), K72.0 (Acute hepatic failure), R74.01 (Elevated liver transaminase). Query: Condition?code=http://snomed.info/sct|427399008,http://hl7.org/fhir/sid/icd-10-cm|K71.9,http://hl7.org/fhir/sid/icd-10-cm|K72.0,http://hl7.org/fhir/sid/icd-10-cm|R74.01"
  },
  "metadata": {
    "implementation_guide": "US Core 5.0.0",
    "algorithm_path": "diagnosis-path",
    "algorithm_path_description": "Patients with DILI dx across SNOMED + multiple ICD-10 liver injury codes (PheKB-aligned).",
    "code_systems": [
      "SNOMED CT",
      "ICD-10-CM"
    ],
    "required_codes": [
      {
        "system": "http://snomed.info/sct",
        "code": "427399008",
        "display": "Drug-induced disorder of liver",
        "source": "PheKB doc + UMLS verified"
      },
      {
        "system": "http://hl7.org/fhir/sid/icd-10-cm",
        "code": "K71.9",
        "display": "Toxic liver disease, unspecified",
        "source": "PheKB doc (ICD-9 573* crosswalk) + UMLS verified"
      },
      {
        "system": "http://hl7.org/fhir/sid/icd-10-cm",
        "code": "K72.0",
        "display": "Acute and subacute hepatic failure",
