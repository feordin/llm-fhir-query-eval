{
  "id": "phekb-heart-failure-dx",
  "source": "phekb",
  "source_id": "heart-failure",
  "name": "Heart Failure - Diagnosis Code Query (Multi-Subtype)",
  "description": "Tests ability to find heart failure patients via diagnosis codes. The PheKB HF algorithm distinguishes HF with reduced EF (HFrEF, EF<50%) from HF with preserved EF (HFpEF, EF>=50%). Synthea distributes patients across SNOMED codes for the HF family: parent Heart failure, Congestive heart failure, Chronic CHF, HFrEF, HFpEF. An LLM querying only the parent code will miss patients coded with the more specific HFrEF/HFpEF codes \u2014 and vice versa.",
  "prompt": "Find all patients with a diagnosis of heart failure, including congestive heart failure, heart failure with reduced ejection fraction (HFrEF), and heart failure with preserved ejection fraction (HFpEF).",
  "prompts": {
    "naive": "Find all patients with heart failure.",
    "broad": "Find all patients diagnosed with any form of heart failure \u2014 including congestive heart failure (CHF), chronic heart failure, heart failure with reduced ejection fraction (HFrEF, also called systolic heart failure), and heart failure with preserved ejection fraction (HFpEF, also called diastolic heart failure).",
    "expert": "I need to identify all heart failure patients in our population. Heart failure is documented under multiple related SNOMED codes, distinguished by ejection fraction phenotype: Heart failure (84114007) is the parent concept, Congestive heart failure (42343007) and Chronic congestive heart failure (88805009) are common general codes, and Heart failure with reduced ejection fraction (703272007, HFrEF) and Heart failure with normal ejection fraction (446221000, HFpEF) capture the specific physiologic subtypes. Search Condition resources for all five codes."
  },
  "metadata": {
    "implementation_guide": "US Core 5.0.0",
    "algorithm_path": "diagnosis-path",
    "algorithm_path_description": "Patients with HF diagnosis codes (Paths A and B). Maps to PheKB HF algorithm criterion of ICD-9 428.X / SNOMED 84114007 descendant traversal. Does NOT find Path C patients (on HF medications without dx) or Path D (low EF on echo without dx).",
    "code_systems": [
      "SNOMED CT",
      "ICD-10-CM"
    ],
