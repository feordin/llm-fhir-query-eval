{
  "id": "phekb-crohns-disease-biologic-without-dx",
  "source": "phekb",
  "source_id": "crohns-disease",
  "name": "Crohn's Disease - Biologic WITHOUT Diagnosis (Negation / RA Contamination)",
  "description": "**Negation test for cross-indication detection.** Find patients prescribed anti-TNF biologics (infliximab, adalimumab) or ustekinumab who do NOT have a Crohn's disease diagnosis. These are typically rheumatoid arthritis or psoriasis patients on the same biologics. This is the OPPOSITE of `phekb-crohns-disease-biologic-disambig` — that test finds the intersection (Crohn's-on-biologic), this test finds the difference (non-Crohn's on the SAME biologic). Important for pharmacovigilance: if an adverse event is reported for adalimumab, you need to know whether the affected patient is on it for Crohn's, RA, or psoriasis.",
  "prompt": "Find patients prescribed Crohn's-class biologics (infliximab, adalimumab, ustekinumab) who do NOT have a Crohn's disease diagnosis. These are typically rheumatoid arthritis or psoriasis patients on the same biologics — important to identify when conducting drug safety surveillance.",
  "prompts": {
    "naive": "Find biologic patients without Crohn's.",
    "broad": "Find patients prescribed anti-TNF biologics (infliximab, adalimumab) or ustekinumab who do NOT have a Crohn's disease diagnosis. The expected population is mostly rheumatoid arthritis patients (anti-TNFs are first-line for RA). Use a two-query subtraction approach since FHIR does not support negative chains.",
    "expert": "I need to find patients who have been prescribed anti-TNF biologics or ustekinumab but do NOT have a documented Crohn's disease diagnosis — these are the cross-indicated patients, most commonly those treated for rheumatoid arthritis or psoriasis. Because FHIR does not support a native 'NOT EXISTS' filter, this requires two separate queries: first retrieve all patients with a MedicationRequest for the relevant biologics (infliximab, adalimumab, ustekinumab coded in RxNorm), then retrieve all patients with a Crohn's disease Condition (using SNOMED codes covering the full set of Crohn's variants), and return the set difference — biologic patients minus Crohn's-diagnosed patients. The resulting cohort represents cross-indication contamination rather than Crohn's disease cases."
  },
  "metadata": {
    "implementation_guide": "US Core 5.0.0",
    "multi_query": true,
    "negation": true,
    "algorithm_path": "negation-via-subtraction",
    "algorithm_path_description": "Set difference (biologic Rx patients) MINUS (Crohn's-diagnosed patients). The result is the cross-indicated population (RA-on-biologic, etc).",
    "expected_queries": [
      "MedicationRequest?code=http://www.nlm.nih.gov/research/umls/rxnorm|191831,http://www.nlm.nih.gov/research/umls/rxnorm|327361,http://www.nlm.nih.gov/research/umls/rxnorm|847083",
      "Condition?code=http://snomed.info/sct|34000006,http://snomed.info/sct|7620006,http://snomed.info/sct|196977009,http://snomed.info/sct|1197732001,http://snomed.info/sct|1197733006"
    ],
