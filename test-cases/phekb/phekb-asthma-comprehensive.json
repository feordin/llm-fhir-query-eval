{
  "id": "phekb-asthma-comprehensive",
  "source": "phekb",
  "source_id": "asthma",
  "name": "Asthma - Comprehensive Provider Query (All Paths)",
  "description": "Simulates an experienced healthcare provider who knows that not all asthma patients have proper diagnosis codes in the EMR. The prompt explicitly asks the LLM to search across multiple evidence types (diagnoses and medications) to find the complete asthma population. This is the ultimate test of LLM clinical informatics capability for the asthma phenotype -- it requires generating multiple FHIR queries and understanding the clinical reasoning behind each approach.",
  "prompt": "Find all patients with asthma. Search both diagnoses and asthma medication prescriptions to capture the complete population.",
  "prompts": {
    "naive": "Find all patients with asthma. Search both diagnoses and asthma medication prescriptions to capture the complete population.",
    "expert": "I need to identify my complete asthma patient population for a respiratory disease management program. I know from experience that not all asthma patients have a formal diagnosis code on their problem list -- some patients were started on inhalers or controller medications by an outside pulmonologist or allergist, and the diagnosis was never formally recorded in our system. Please run multiple FHIR queries to capture the full population:\n\n1. Patients with an asthma diagnosis on their problem list\n2. Patients who have been prescribed asthma medications including rescue inhalers (albuterol), inhaled corticosteroids (fluticasone, budesonide), and leukotriene receptor antagonists (montelukast)\n\nFor each query, return the matching resources. I want to see the union of all patients found across these approaches to get the most complete picture of my asthma population."
  },
  "metadata": {
    "implementation_guide": "US Core 5.0.0",
    "algorithm_paths": "all-paths",
    "algorithm_path_description": "Comprehensive multi-query approach that mirrors how a real clinician would identify the full asthma population. Requires the LLM to generate 2 separate FHIR queries and combine results. Tests clinical reasoning, FHIR query construction, and multi-resource search strategy.",
    "code_systems": [
      "SNOMED CT",
      "RxNorm"
    ],
