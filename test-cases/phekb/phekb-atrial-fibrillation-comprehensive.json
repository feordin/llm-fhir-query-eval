{
  "id": "phekb-atrial-fibrillation-comprehensive",
  "source": "phekb",
  "source_id": "atrial-fibrillation-demonstration-project",
  "name": "Atrial Fibrillation - Comprehensive Provider Query (Diagnosis + Medications)",
  "description": "Simulates a cardiologist preparing an anticoagulation quality measure who needs to identify the complete AF patient population. The clinician knows that some patients may be on anticoagulants prescribed by their primary care physician without a formal AF diagnosis code in the specialist system. This requires the LLM to generate multiple FHIR queries across Condition and MedicationRequest resources and combine the results.",
  "prompt": "Find all patients with atrial fibrillation. Search both diagnoses and AF-related medication prescriptions to capture the complete population.",
  "prompts": {
    "naive": "Find all patients with atrial fibrillation. Search both diagnoses and AF-related medication prescriptions to capture the complete population.",
    "expert": "I am a cardiologist preparing our practice's anticoagulation quality measure for atrial fibrillation patients. I need to identify every patient in our system who has atrial fibrillation, but I know from experience that our problem lists are incomplete. Some patients were started on blood thinners like warfarin or apixaban by their primary care doctor and never had the AF diagnosis formally entered here. Others are on rate control medications like metoprolol or rhythm control drugs like amiodarone that were continued from a hospital discharge without updating their diagnosis list. Please search for:\n\n1. Patients with an atrial fibrillation diagnosis on their problem list\n2. Patients who have active prescriptions for anticoagulants (warfarin, apixaban), antiarrhythmic medications (amiodarone), or rate-control agents (metoprolol) commonly used for AF\n\nI need the union of both groups to get the complete picture."
  },
  "metadata": {
    "implementation_guide": "US Core 5.0.0",
    "algorithm_paths": "all-paths",
    "algorithm_path_description": "Comprehensive multi-query approach that mirrors how a real cardiologist would identify the full AF population. Requires the LLM to generate 2 separate FHIR queries (diagnosis + medications) and combine results. Tests clinical reasoning about incomplete problem lists and medication-only evidence of AF.",
    "code_systems": [
      "SNOMED CT",
      "RxNorm"
    ],
    "required_codes": [
