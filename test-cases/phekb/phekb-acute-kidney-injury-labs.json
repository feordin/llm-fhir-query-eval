  "source_id": "acute-kidney-injury",
  "name": "AKI - Elevated Creatinine Lab Query",
  "description": "Tests ability to find AKI patients via elevated serum creatinine. KDIGO criteria use creatinine elevation from baseline; for this test we use absolute threshold ≥1.5 mg/dL as a proxy (covers the typical AKI cutoff range).",
  "prompt": "Find patients with elevated serum creatinine results at or above 1.5 mg/dL.",
  "prompts": {
    "naive": "Find patients with high creatinine.",
    "broad": "Find patients with serum creatinine measurements at or above 1.5 mg/dL — reflective of impaired kidney function or acute kidney injury.",
    "expert": "Search Observation resources with LOINC 2160-0 (Creatinine in Serum) where value-quantity ≥ 1.5 mg/dL. Query: Observation?code=http://loinc.org|2160-0&value-quantity=ge1.5||mg/dL"
  },
  "metadata": {
    "implementation_guide": "US Core 5.0.0",
    "algorithm_path": "labs-path",
    "algorithm_path_description": "Patients with elevated creatinine. Includes Path D (no formal AKI dx).",
