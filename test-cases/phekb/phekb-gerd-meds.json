{
  "id": "phekb-gerd-meds",
  "source": "phekb",
  "source_id": "gerd",
  "name": "GERD - PPI Medication Query",
  "description": "Tests ability to find GERD patients via proton pump inhibitor (PPI) prescriptions. The PheKB GERD algorithm uses 2+ GERD-related medication prescriptions as part of case definition. PPIs are the dominant treatment class. Synthea distributes patients across 5 PPIs. An LLM querying only omeprazole will miss patients on the equally-common pantoprazole, lansoprazole, esomeprazole, or rabeprazole.",
  "prompt": "Find patients prescribed proton pump inhibitors (PPIs) used to treat GERD, including omeprazole, pantoprazole, lansoprazole, esomeprazole, and rabeprazole.",
  "prompts": {
    "naive": "Find patients on PPIs.",
    "broad": "Find patients prescribed any proton pump inhibitor (PPI) \u2014 the standard treatment class for GERD. Include omeprazole, pantoprazole, lansoprazole, esomeprazole, and rabeprazole.",
    "expert": "I need MedicationRequest resources for any PPI. Use these RxNorm ingredient codes: 7646 (omeprazole), 40790 (pantoprazole), 17128 (lansoprazole), 283742 (esomeprazole), 114979 (rabeprazole). Combine in a single comma-separated code search."
  },
  "metadata": {
    "implementation_guide": "US Core 5.0.0",
    "algorithm_path": "medication-path",
    "algorithm_path_description": "Patients with PPI medication orders (Paths A and C). Captures both diagnosed GERD patients and the very large Path C population \u2014 PPIs are arguably the most cross-prescribed drug class (dyspepsia, NSAID-associated gastritis, H. pylori eradication, prophylaxis in critically ill, empirical relief of upper GI symptoms).",
    "code_systems": [
      "RxNorm"
    ],
    "required_codes": [
      {
        "system": "http://www.nlm.nih.gov/research/umls/rxnorm",
        "code": "7646",
