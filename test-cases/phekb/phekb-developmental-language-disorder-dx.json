      },
      {
        "system": "http://hl7.org/fhir/sid/icd-10-cm",
        "code": "F80.89",
        "display": "Other developmental disorders of speech and language",
        "source": "PheKB APT-DLD doc + UMLS verified"
      }
    ],
    "complexity": "medium",
    "tags": [
