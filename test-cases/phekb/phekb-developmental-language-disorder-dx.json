  "id": "phekb-developmental-language-disorder-dx",
  "source": "phekb",
  "source_id": "developmental-language-disorder",
  "name": "Developmental Language Disorder - Diagnosis Code Query (Multi-Code)",
  "description": "Tests ability to find DLD patients across the 3 PheKB-published ICD-10 inclusion codes (F80.1, F80.2, F80.89). Per APT-DLD algorithm (Walters et al. 2020), real-world cohorts use multiple subtype codes — F80.89 most broadly, F80.2 for mixed presentations, F80.1 for expressive-only.",
  "prompt": "Find pediatric patients with a diagnosis of developmental language disorder including expressive, receptive-expressive, and other developmental disorders of speech and language.",
  "prompts": {
    "naive": "Find children with DLD.",
    "broad": "Find pediatric patients diagnosed with developmental language disorder — including expressive, mixed receptive-expressive, and other developmental disorders of speech and language.",
    "expert": "Search Condition for ICD-10 F80.1 (Expressive language disorder), F80.2 (Mixed receptive-expressive language disorder), F80.89 (Other developmental disorders of speech and language). Restrict to pediatric. Query: Condition?code=http://hl7.org/fhir/sid/icd-10-cm|F80.1,http://hl7.org/fhir/sid/icd-10-cm|F80.2,http://hl7.org/fhir/sid/icd-10-cm|F80.89"
  },
  "metadata": {
    "implementation_guide": "US Core 5.0.0",
    "algorithm_path": "diagnosis-path",
    "algorithm_path_description": "Pediatric patients with any DLD inclusion code (PheKB APT-DLD algorithm, Step 1 Broad Search).",
    "code_systems": [
      "ICD-10-CM"
    ],
    "required_codes": [
      {
        "system": "http://hl7.org/fhir/sid/icd-10-cm",
