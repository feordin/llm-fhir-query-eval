  "id": "phekb-ace-inhibitor-cough-dx",
  "source": "phekb",
  "source_id": "ace-inhibitor-ace-i-induced-cough",
  "name": "ACE Inhibitor Cough - Cough Diagnosis Query",
  "description": "Tests ability to find patients with a documented cough diagnosis. In the PheKB ACE inhibitor-induced cough algorithm, cough noted as an adverse event or allergy associated with ACE inhibitor use identifies cases. Since FHIR Condition resources capture documented diagnoses, this test queries for cough using the SNOMED CT code. Patients found here who also have ACEi prescriptions are potential ACEi-induced cough cases.",
  "prompt": "Find all patients who have a documented diagnosis of cough.",
  "prompts": {
    "naive": "Find all patients who have a documented diagnosis of cough.",
    "expert": "I need to find patients with a documented cough diagnosis as part of a medication safety investigation into ACE inhibitor-induced cough. Cough is a well-known class effect of ACE inhibitors, occurring in 5-20% of patients on these medications. The query should search Condition resources for the cough diagnosis code. Keep in mind that cough may be coded as a symptom finding rather than a disease diagnosis, so use the appropriate SNOMED clinical finding code. This query is the first step -- the results will later be cross-referenced with ACE inhibitor prescription records to identify likely drug-induced cases."
  },
  "metadata": {
    "implementation_guide": "US Core 5.0.0",
    "algorithm_path": "case-cough-identification",
    "algorithm_path_description": "Identifies patients with documented cough diagnosis. In the ACEi-induced cough phenotype, cases have cough noted as an adverse event of ACE inhibitor therapy. This single-resource query tests whether LLMs choose the correct SNOMED code for cough.",
    "code_systems": [
      "SNOMED CT"
    ],
    "required_codes": [
      {
        "system": "http://snomed.info/sct",
        "code": "49727002",
        "display": "Cough",
        "source": "umls"
      }
    ],
    "complexity": "medium",
