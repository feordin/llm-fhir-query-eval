{
  "id": "phekb-endometriosis-comprehensive",
  "source": "phekb",
  "source_id": "endometriosis",
  "name": "Endometriosis - Comprehensive Provider Query (Multi-Resource)",
  "description": "Provider-level query identifying endometriosis patients via Condition + MedicationRequest. Path C (med only) reflects leuprolide use without endometriosis dx \u2014 could indicate undiagnosed pelvic pain or off-label use.",
  "prompt": "I need to identify my complete endometriosis patient population for a women's health quality program. Some female patients have a coded endometriosis diagnosis. Others are on leuprolide for chronic pelvic pain or hormonal suppression without a formal endometriosis diagnosis. Run multiple FHIR queries \u2014 diagnosis and leuprolide \u2014 and union the patient sets.",
  "prompts": {
    "naive": "Find all endometriosis patients.",
    "broad": "Find all female endometriosis patients \u2014 by diagnosis or by leuprolide (GnRH agonist) prescriptions. Run multiple queries and union the patient sets.",
    "expert": "Run two queries (female-restricted). (1) Condition?code=http://snomed.info/sct|76376003&patient.gender=female \u2014 endometriosis dx. (2) MedicationRequest?code=http://www.nlm.nih.gov/research/umls/rxnorm|752899&patient.gender=female \u2014 leuprolide. Union the patient IDs."
  },
