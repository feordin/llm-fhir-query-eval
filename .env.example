# FHIR Server Configuration
FHIR_SERVER_URL=http://localhost:5826
FHIR_VERSION=r4

# LLM Provider API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# NIH UMLS Terminology Services key (for the Tier 2/3 UMLS + VSAC tools)
UMLS_API_KEY=your_umls_api_key_here

# MCP Server (Optional)
MCP_SERVER_URL=

# Azure (only needed for the MIMIC-IV $import scripts: scripts/setup_mimic_server.sh,
# scripts/mimic_load.py). Your own subscription / storage — no defaults are baked in.
FHIR_SUBSCRIPTION=your-azure-subscription-id
FHIR_IMPORT_STORAGE=your-storage-account-name
FHIR_IMPORT_STORAGE_RG=your-storage-account-resource-group
FHIR_IMPORT_CONTAINER=fhir-mimic

# Storage Paths (relative to project root)
TEST_CASES_DIR=test-cases
DATA_DIR=data

# API Configuration
API_TITLE=FHIR Query Evaluation API
API_VERSION=0.1.0
